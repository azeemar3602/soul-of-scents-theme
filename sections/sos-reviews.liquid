{{ 'sos-reviews.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading      = section.settings.heading | default: 'Reviews'
  assign per_page     = section.settings.per_page | default: 20
  assign show_count   = section.settings.show_count
  assign bg_color     = section.settings.bg_color
  assign padding_top  = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
-%}

<section
  class="sos-reviews"
  data-sos-reviews
  data-product-id="{{ product.id }}"
  data-shop-domain="{{ 'soul-of-scents-4.myshopify.com' }}"
  data-per-page="{{ per_page }}"
  data-api-token="{{ section.settings.judgeme_api_token }}"
  style="background-color: {{ bg_color }}; padding-top: {{ padding_top }}px; padding-bottom: {{ padding_bottom }}px;"
>
  <div class="sos-reviews__header">
    <h2 class="sos-reviews__heading">
      {{ heading }}
      {%- if show_count -%}
        <span class="sos-reviews__count" data-review-count></span>
      {%- endif -%}
    </h2>
    <a
      class="sos-reviews__write-btn"
      href="#"
      data-write-review
    >Write a review</a>
  </div>

  <div class="sos-reviews__track-wrap">
    <div class="sos-reviews__track" data-track>
      <div class="sos-reviews__loading">Loading reviews…</div>
    </div>
    <button class="sos-reviews__nav sos-reviews__nav--prev" data-prev aria-label="Previous" disabled>
      <svg width="9" height="15" viewBox="0 0 9 15" fill="none"><path d="M8 1L1.5 7.5L8 14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <button class="sos-reviews__nav sos-reviews__nav--next" data-next aria-label="Next">
      <svg width="9" height="15" viewBox="0 0 9 15" fill="none"><path d="M1 1L7.5 7.5L1 14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
  </div>
</section>

<script>
(function () {
  const section  = document.querySelector('[data-sos-reviews]');
  if (!section) return;

  const track    = section.querySelector('[data-track]');
  const countEl  = section.querySelector('[data-review-count]');
  const prevBtn  = section.querySelector('[data-prev]');
  const nextBtn  = section.querySelector('[data-next]');
  const writeBtn = section.querySelector('[data-write-review]');

  const productId  = section.dataset.productId;
  const shopDomain = section.dataset.shopDomain;
  const perPage    = section.dataset.perPage || 20;

  /* ── helpers ── */
  function stars(rating) {
    let s = '';
    for (let i = 1; i <= 5; i++) {
      s += `<svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M7 1L8.545 5.09H13L9.59 7.71L10.91 12L7 9.27L3.09 12L4.41 7.71L1 5.09H5.455L7 1Z"
          fill="${i <= rating ? '#C4956A' : 'none'}"
          stroke="${i <= rating ? '#C4956A' : '#C4956A'}"
          stroke-width="0.8"/>
      </svg>`;
    }
    return s;
  }

  function timeAgo(dateStr) {
    const diff = Math.floor((Date.now() - new Date(dateStr)) / 1000);
    if (diff < 86400)      return 'Today';
    if (diff < 172800)     return '1 day ago';
    if (diff < 2592000)    return Math.floor(diff / 86400) + ' days ago';
    if (diff < 5184000)    return '1 month ago';
    if (diff < 31536000)   return Math.floor(diff / 2592000) + ' months ago';
    return Math.floor(diff / 31536000) + ' years ago';
  }

  function renderCard(r) {
    const name = r.reviewer ? r.reviewer.name : (r.author || 'Anonymous');
    const initial = name.charAt(0).toUpperCase();
    return `
      <div class="sos-reviews__card">
        <div class="sos-reviews__card-top">
          <div class="sos-reviews__stars">${stars(r.rating)}</div>
          <span class="sos-reviews__date">${timeAgo(r.created_at)}</span>
        </div>
        <p class="sos-reviews__title">${r.title || ''}</p>
        <p class="sos-reviews__author">${name}</p>
        <p class="sos-reviews__body">${r.body || ''}</p>
      </div>`;
  }

  /* ── fetch ── */
  async function load() {
    try {
      const apiToken = section.dataset.apiToken;
      if (!apiToken) {
        track.innerHTML = '<p class="sos-reviews__empty">Add your Judge.me API token in theme settings.</p>';
        return;
      }
      const params = new URLSearchParams({
        api_token: apiToken,
        shop_domain: shopDomain,
        per_page: perPage
      });
      if (productId) params.set('product_id', productId);

      const data = await new Promise((resolve, reject) => {
                const xhr = new XMLHttpRequest();
                        xhr.open('GET', 'https://judge.me/api/v1/reviews?' + params);
                                xhr.onload = () => { try { resolve(JSON.parse(xhr.responseText)); } catch(e) { reject(e); } };
                                        xhr.onerror = reject;
                                                xhr.send();
                                                      });
                                                      const reviews = data.reviews || [];

      if (!reviews.length) {
        track.innerHTML = '<p class="sos-reviews__empty">No reviews yet. Be the first!</p>';
        return;
      }

      if (countEl) countEl.textContent = data.reviews_count ?? reviews.length;

      track.innerHTML = reviews.map(renderCard).join('');

      /* write-review link */
      if (writeBtn) {
        writeBtn.href = `https://judge.me/reviews/new?shop_domain=${shopDomain}&product_id=${productId}`;
      }

      initCarousel();

    } catch (e) {
      track.innerHTML = '<p class="sos-reviews__empty">Could not load reviews.</p>';
      console.error('sos-reviews:', e);
    }
  }

  /* ── carousel ── */
  function initCarousel() {
    const cards    = track.querySelectorAll('.sos-reviews__card');
    if (!cards.length) return;
    const cardW    = () => cards[0].offsetWidth + 24; // gap
    let pos = 0;

    function update() {
      const max = track.scrollWidth - track.parentElement.offsetWidth;
      prevBtn.disabled = pos <= 0;
      nextBtn.disabled = pos >= max - 4;
      track.style.transform = `translateX(-${pos}px)`;
    }

    prevBtn.addEventListener('click', () => { pos = Math.max(0, pos - cardW()); update(); });
    nextBtn.addEventListener('click', () => {
      const max = track.scrollWidth - track.parentElement.offsetWidth;
      pos = Math.min(max, pos + cardW());
      update();
    });

    update();
  }

  load();
})();
</script>

{% schema %}
{
  "name": "Reviews (Judge.me)",
  "tag": "section",
  "class": "section-sos-reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Reviews"
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "Show review count next to heading",
      "default": true
    },
    {
      "type": "text",
      "id": "judgeme_api_token",
      "label": "Judge.me Public API Token",
      "info": "Find it in Judge.me app → Settings → API → Public Token"
    },
    {
      "type": "range",
      "id": "per_page",
      "label": "Number of reviews to load",
      "min": 4,
      "max": 50,
      "step": 1,
      "default": 20
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    { "name": "Reviews (Judge.me)" }
  ]
}
{% endschema %}