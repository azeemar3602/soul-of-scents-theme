{%- comment -%}
  Soul of Scents — Account Dashboard (page-template version)
  Mirrors templates/customers/account.liquid but renders on a regular Shopify
  page so it works when "New customer accounts" is the only available option
  (i.e. the legacy /account customer template can't be used).

  Customer-aware: when the visitor isn't signed in, we render a sign-in CTA
  instead of the dashboard. The `customer` object is populated on every page
  for the logged-in shopper.

  Assign to a page in Shopify admin → set template to `page.account-dashboard`.
{%- endcomment -%}

{{ 'sos-account.css' | asset_url | stylesheet_tag }}

{%- if customer == blank -%}
  <div class="sos-account sos-account--signedout" style="max-width:560px;margin:80px auto;padding:0 24px;text-align:center;">
    <h1 style="font-family:var(--g-font-2, 'EB Garamond', Georgia, serif); font-weight:400; font-size:clamp(32px, 4vw, 48px); margin:0 0 16px;">Sign in to your account</h1>
    <p style="font-size:15px; color:#6f6862; line-height:1.6; margin:0 0 28px;">
      Access your archetype results, past orders, favourites, addresses, and settings — all in one place.
    </p>
    <a class="sos-account__btn" href="/account" style="display:inline-flex;align-items:center;justify-content:center;height:46px;padding:0 32px;background:#030303;color:#fff;border-radius:4px;font-size:13px;letter-spacing:.06em;text-transform:uppercase;text-decoration:none;">Sign in</a>
    <p style="margin-top:24px;font-size:13px;color:#6f6862;">
      Don't have an account yet? <a href="/account/register" style="color:#030303;text-decoration:underline;text-underline-offset:3px;">Create one</a>.
    </p>
  </div>
{%- else -%}

{%- liquid
  assign archetype_name        = customer.metafields.custom.archetype_name
  assign archetype_image       = customer.metafields.custom.archetype_image
  assign archetype_image_url   = customer.metafields.custom.archetype_image_url
  assign quiz_taken_date       = customer.metafields.custom.quiz_taken_date
  assign archetype_date_legacy = customer.metafields.custom.archetype_date
  assign archetype_result_url  = customer.metafields.custom.archetype_result_url

  if quiz_taken_date == blank
    assign quiz_taken_date = archetype_date_legacy
  endif

  assign has_archetype = false
  if archetype_name != blank
    assign has_archetype = true
  endif

  assign archetype_image_src = ''
  if archetype_image_url != blank
    assign archetype_image_src = archetype_image_url
  elsif archetype_image != blank
    assign archetype_image_src = archetype_image | img_url: '160x160'
  endif

  assign quiz_url = '/pages/quiz'
  assign wishlist_page = pages[settings.page_wishlist]
  assign wishlist_url = '/'
  if wishlist_page.url != blank
    assign wishlist_url = wishlist_page.url
  endif

  assign recent_orders = customer.orders | slice: 0, 6
-%}

<div class="sos-account" id="sosAccount">
  <aside class="sos-account__sidebar" aria-label="Account navigation">
    <nav class="sos-account__nav" role="tablist">
      <a class="sos-account__navlink is-active" data-tab="overview" href="#overview" role="tab">Overview</a>
      <a class="sos-account__navlink sos-account__navlink--with-caret" data-tab="archetype" href="#archetype" role="tab">My Archetype Results</a>
      <a class="sos-account__navlink" data-tab="orders" href="#orders" role="tab">My orders</a>
      <a class="sos-account__navlink" data-tab="buy-again" href="#buy-again" role="tab">Buy again</a>
      <a class="sos-account__navlink" data-tab="favorites" href="#favorites" role="tab">My favorites</a>
      <a class="sos-account__navlink" data-tab="addresses" href="#addresses" role="tab">My addresses</a>
      <a class="sos-account__navlink" data-tab="cards" href="#cards" role="tab">My cards</a>
      <a class="sos-account__navlink" data-tab="settings" href="#settings" role="tab">Settings</a>
      <a class="sos-account__navlink" data-tab="support" href="#support" role="tab">Support</a>
    </nav>
  </aside>

  <main class="sos-account__main">

    <section id="overview" class="sos-account__panel is-active" role="tabpanel">
      <p class="sos-account__breadcrumb"><a href="/">Home</a> / Account</p>
      <div class="sos-account__section">
        <div class="sos-account__section-head"><h2 class="sos-account__section-title">My Archetype</h2></div>
        {%- if has_archetype -%}
          <div class="sos-account__archetype">
            {%- if archetype_image_src != blank -%}
              <img src="{{ archetype_image_src }}" alt="{{ archetype_name | escape }}" class="sos-account__archetype-image" width="56" height="56" loading="lazy">
            {%- else -%}
              <span class="sos-account__archetype-image" aria-hidden="true"></span>
            {%- endif -%}
            <div>
              <p class="sos-account__archetype-name">{{ archetype_name }}</p>
              {%- if quiz_taken_date != blank -%}<p class="sos-account__archetype-meta">Quiz taken on {{ quiz_taken_date | date: '%b %e, %Y' }}</p>{%- endif -%}
            </div>
            <div class="sos-account__archetype-actions">
              <a class="sos-account__btn" href="{{ archetype_result_url | default: '#archetype' }}">View Archetype</a>
              <a class="sos-account__linkbtn" href="{{ quiz_url }}">Repeat the Quiz</a>
            </div>
          </div>
        {%- else -%}
          <div class="sos-account__empty"><p>You haven't taken the archetype quiz yet.</p><a class="sos-account__btn" href="{{ quiz_url }}">Take the Quiz</a></div>
        {%- endif -%}
      </div>
      <div class="sos-account__section">
        <div class="sos-account__section-head"><h2 class="sos-account__section-title">My Orders</h2><a class="sos-account__showall" href="#orders" data-jump="orders">Show all &rsaquo;</a></div>
        {%- if customer.orders.size > 0 -%}
          {%- assign overview_order = customer.orders.first -%}
          {%- render 'sos-order-card', order: overview_order, compact: false -%}
        {%- else -%}
          <div class="sos-account__empty"><p>No orders yet.</p></div>
        {%- endif -%}
      </div>
    </section>

    <section id="archetype" class="sos-account__panel" role="tabpanel">
      <p class="sos-account__breadcrumb"><a href="/">Home</a> / <a href="#overview" data-jump="overview">Account</a> / Archetype</p>
      <div class="sos-account__section">
        <div class="sos-account__section-head"><h2 class="sos-account__section-title">My Archetype</h2></div>
        {%- if has_archetype -%}
          <div class="sos-account__archetype">
            {%- if archetype_image_src != blank -%}
              <img src="{{ archetype_image_src }}" alt="{{ archetype_name | escape }}" class="sos-account__archetype-image" width="56" height="56" loading="lazy">
            {%- else -%}
              <span class="sos-account__archetype-image" aria-hidden="true"></span>
            {%- endif -%}
            <div>
              <p class="sos-account__archetype-name">{{ archetype_name }}</p>
              {%- if quiz_taken_date != blank -%}<p class="sos-account__archetype-meta">Quiz taken on {{ quiz_taken_date | date: '%b %e, %Y' }}</p>{%- endif -%}
            </div>
            <div class="sos-account__archetype-actions">
              <a class="sos-account__btn" href="{{ archetype_result_url | default: '#archetype' }}">View Archetype</a>
              <a class="sos-account__btn sos-account__btn--ghost" href="#" onclick="event.preventDefault(); if (navigator.share) { navigator.share({ title: '{{ archetype_name | escape }}', url: window.location.href }); } else { navigator.clipboard.writeText(window.location.href); this.textContent='Link copied'; }">Share Results</a>
              <a class="sos-account__linkbtn" href="{{ quiz_url }}">Get sample bundle</a>
            </div>
          </div>
        {%- else -%}
          <div class="sos-account__empty"><p>You haven't taken the archetype quiz yet.</p><a class="sos-account__btn" href="{{ quiz_url }}">Take the Quiz</a></div>
        {%- endif -%}
      </div>
    </section>

    <section id="orders" class="sos-account__panel" role="tabpanel">
      <p class="sos-account__breadcrumb"><a href="/">Home</a> / <a href="#overview" data-jump="overview">Account</a> / Orders</p>
      <div class="sos-account__section">
        <div class="sos-account__section-head">
          <h2 class="sos-account__section-title">My Orders</h2>
          {%- if customer.orders.size > 1 -%}<a class="sos-account__showall" href="/account/orders">Show all &rsaquo;</a>{%- endif -%}
        </div>
        {%- if customer.orders.size > 0 -%}
          {%- for order in recent_orders -%}{%- render 'sos-order-card', order: order, compact: false -%}{%- endfor -%}
        {%- else -%}
          <div class="sos-account__empty"><p>You haven't placed any orders yet.</p></div>
        {%- endif -%}
      </div>
    </section>

    <section id="buy-again" class="sos-account__panel" role="tabpanel">
      <p class="sos-account__breadcrumb"><a href="/">Home</a> / <a href="#overview" data-jump="overview">Account</a> / Buy again</p>
      <div class="sos-account__section">
        <div class="sos-account__section-head"><h2 class="sos-account__section-title">Did you enjoy your last purchase?</h2></div>
        <p style="font-size:13px;color:var(--sos-muted, #6f6862);margin:0 0 14px;line-height:1.55;max-width:600px;">Reorder favorites from previous purchases. Tap any product below to add it to your cart again.</p>
        {%- if customer.orders.size > 0 -%}
          {%- assign printed_handles = '' -%}
          <div class="sos-account__product-grid">
            {%- for order in customer.orders limit: 8 -%}
              {%- for line in order.line_items -%}
                {%- assign h = line.product.handle -%}
                {%- unless printed_handles contains h -%}
                  {%- assign printed_handles = printed_handles | append: ',' | append: h -%}
                  {%- assign p = line.product -%}
                  {%- if p != blank -%}
                    <div class="sos-account__product-card sos-account__fav-card">
                      <a href="{{ p.url }}" aria-label="{{ p.title | escape }}">
                        {%- if line.image -%}
                          <img src="{{ line.image | image_url: width: 360 }}" alt="{{ p.title | escape }}" loading="lazy" width="360" height="360">
                        {%- elsif p.featured_image -%}
                          <img src="{{ p.featured_image | image_url: width: 360 }}" alt="{{ p.title | escape }}" loading="lazy" width="360" height="360">
                        {%- endif -%}
                      </a>
                    </div>
                  {%- endif -%}
                {%- endunless -%}
              {%- endfor -%}
            {%- endfor -%}
          </div>
        {%- else -%}
          <div class="sos-account__empty"><p>Once you place an order, your reorderable items will appear here.</p><a class="sos-account__btn" href="/collections/all">Browse the shop</a></div>
        {%- endif -%}
      </div>
    </section>

    <section id="favorites" class="sos-account__panel" role="tabpanel">
      <p class="sos-account__breadcrumb"><a href="/">Home</a> / <a href="#overview" data-jump="overview">Account</a> / Favorites</p>
      <div class="sos-account__section">
        <div class="sos-account__section-head">
          <h2 class="sos-account__section-title">My Favorites</h2>
          {%- if wishlist_page.url != blank -%}<a class="sos-account__showall" href="{{ wishlist_url }}">View full wishlist &rsaquo;</a>{%- endif -%}
        </div>
        <div class="sos-account__product-grid" id="sosFavoritesGrid" data-empty-msg="No favorites saved yet."></div>
        <div class="sos-account__empty sos-account__hide" id="sosFavoritesEmpty"><p>You haven't saved any favorites yet.</p><a class="sos-account__btn sos-account__btn--ghost" href="/collections/all">Browse products</a></div>
      </div>
    </section>

    <section id="addresses" class="sos-account__panel" role="tabpanel">
      <p class="sos-account__breadcrumb"><a href="/">Home</a> / <a href="#overview" data-jump="overview">Account</a> / Addresses</p>
      <div class="sos-account__section">
        <div class="sos-account__section-head"><h2 class="sos-account__section-title">My addresses</h2></div>
        {%- if customer.default_address -%}
          <div class="sos-account__address">
            <div>
              <p class="sos-account__address-label">Standard Address</p>
              <address class="sos-account__address-body">{{ customer.default_address.first_name }} {{ customer.default_address.last_name }}<br>{{ customer.default_address.address1 }}{% if customer.default_address.address2 != blank %}<br>{{ customer.default_address.address2 }}{% endif %}<br>{{ customer.default_address.zip }} {{ customer.default_address.city }}{% if customer.default_address.country != blank %}, {{ customer.default_address.country }}{% endif %}</address>
            </div>
            <a class="sos-account__address-edit" href="/account/addresses">EDIT</a>
          </div>
        {%- endif -%}
        {%- for address in customer.addresses -%}
          {%- if customer.default_address and address.id == customer.default_address.id -%}{%- continue -%}{%- endif -%}
          <div class="sos-account__address">
            <div>
              <p class="sos-account__address-label">Address</p>
              <address class="sos-account__address-body">{{ address.first_name }} {{ address.last_name }}<br>{{ address.address1 }}{% if address.address2 != blank %}<br>{{ address.address2 }}{% endif %}<br>{{ address.zip }} {{ address.city }}{% if address.country != blank %}, {{ address.country }}{% endif %}</address>
            </div>
            <a class="sos-account__address-edit" href="/account/addresses">EDIT</a>
          </div>
        {%- endfor -%}
        {%- if customer.addresses.size == 0 -%}<div class="sos-account__empty"><p>You have no saved addresses.</p></div>{%- endif -%}
        <a class="sos-account__btn sos-account__btn--block" href="/account/addresses" style="margin-top:18px;">Add a new address</a>
      </div>
    </section>

    <section id="cards" class="sos-account__panel" role="tabpanel">
      <p class="sos-account__breadcrumb"><a href="/">Home</a> / <a href="#overview" data-jump="overview">Account</a> / Cards</p>
      <div class="sos-account__section">
        <div class="sos-account__section-head"><h2 class="sos-account__section-title">My cards</h2></div>
        <div class="sos-account__card-row"><div class="sos-account__card-info"><strong>Standard Card</strong><small>Visa &middot;&middot;&middot;&middot; &middot;&middot;&middot;&middot; &middot;&middot;&middot;&middot; ----</small></div><span class="sos-account__address-edit" aria-disabled="true" style="opacity:0.4; cursor:not-allowed;">EDIT</span></div>
        <div class="sos-account__card-row"><div class="sos-account__card-info"><strong>Card</strong><small>Visa &middot;&middot;&middot;&middot; &middot;&middot;&middot;&middot; &middot;&middot;&middot;&middot; ----</small></div><span class="sos-account__address-edit" aria-disabled="true" style="opacity:0.4; cursor:not-allowed;">EDIT</span></div>
        <p style="margin:14px 0 0; font-size:12px; color:var(--sos-muted, #6f6862); line-height:1.55;">Saved payment methods are managed by Shopify checkout. To add or change a card, use the payment step at checkout. (Theme code does not have access to your card details.)</p>
        <a class="sos-account__btn sos-account__btn--block" href="/cart" style="margin-top:18px;">Add a new card at checkout</a>
      </div>
    </section>

    <section id="settings" class="sos-account__panel" role="tabpanel">
      <p class="sos-account__breadcrumb"><a href="/">Home</a> / <a href="#overview" data-jump="overview">Account</a> / Settings</p>
      <div class="sos-account__section">
        <div class="sos-account__section-head"><h2 class="sos-account__section-title">Settings</h2></div>
        <div class="sos-account__settings-row"><p class="sos-account__settings-label">First name*</p><p class="sos-account__settings-value">{{ customer.first_name | default: '—' }}</p><a class="sos-account__settings-edit" href="mailto:{{ shop.email }}?subject=Update%20account%20name">EDIT</a></div>
        <div class="sos-account__settings-row"><p class="sos-account__settings-label">Last name*</p><p class="sos-account__settings-value">{{ customer.last_name | default: '—' }}</p><a class="sos-account__settings-edit" href="mailto:{{ shop.email }}?subject=Update%20account%20name">EDIT</a></div>
        <div class="sos-account__settings-row"><p class="sos-account__settings-label">Email*</p><p class="sos-account__settings-value">{{ customer.email }}</p><a class="sos-account__settings-edit" href="mailto:{{ shop.email }}?subject=Update%20account%20email">EDIT</a></div>
        <a class="sos-account__delete-account" href="mailto:{{ shop.email }}?subject=Delete%20my%20account">Delete account</a>
        <p style="margin-top:18px; font-size:12px; color:var(--sos-muted, #6f6862); line-height:1.55;">Profile changes (name / email / account deletion) are handled by our support team to keep your order history secure.</p>
      </div>
    </section>

    <section id="support" class="sos-account__panel" role="tabpanel">
      <p class="sos-account__breadcrumb"><a href="/">Home</a> / <a href="#overview" data-jump="overview">Account</a> / Support</p>
      <div class="sos-account__section">
        <div class="sos-account__section-head"><h2 class="sos-account__section-title">How can we assist you?</h2></div>
        <div class="sos-account__support-grid">
          <a class="sos-account__support-link" href="/pages/faq">FAQ</a>
          <a class="sos-account__support-link" href="/pages/quiz">Archetype Quiz</a>
          <a class="sos-account__support-link" href="/pages/shipping">Shipping</a>
          <a class="sos-account__support-link" href="/blogs/magazine">Blog</a>
          <a class="sos-account__support-link" href="/pages/returns">Returns &amp; Exchanges</a>
          <a class="sos-account__support-link" href="/pages/gift-guide">Gift Guide</a>
        </div>
        <a class="sos-account__btn sos-account__btn--block" href="/pages/contact">Get in touch</a>
      </div>
    </section>

    <p style="margin-top:32px;font-size:12px;color:var(--sos-muted, #6f6862);text-align:right;">
      <a href="/account/logout" style="color:inherit;text-decoration:underline;text-underline-offset:3px;">Log out</a>
    </p>

  </main>
</div>

<script>
(function(){
  var TABS = ['overview','archetype','orders','buy-again','favorites','addresses','cards','settings','support'];
  var nav = document.querySelectorAll('.sos-account__navlink');
  var panels = document.querySelectorAll('.sos-account__panel');
  function activate(id) {
    if (!id || TABS.indexOf(id) === -1) { id = 'overview'; }
    nav.forEach(function(a){ a.classList.toggle('is-active', a.dataset.tab === id); });
    panels.forEach(function(p){ p.classList.toggle('is-active', p.id === id); });
  }
  function activateFromHash(){
    var id = (window.location.hash || '').replace('#','');
    activate(id);
  }
  activateFromHash();
  window.addEventListener('hashchange', activateFromHash);
  // Explicit click handlers so tab switching works even if hashchange is delayed
  // or the page is inside an iframe / preview frame where hash events get swallowed.
  nav.forEach(function(a){
    a.addEventListener('click', function(e){
      var id = a.dataset.tab;
      if (id && TABS.indexOf(id) !== -1) {
        e.preventDefault();
        if (history && history.replaceState) {
          history.replaceState(null, '', '#' + id);
        } else {
          window.location.hash = '#' + id;
        }
        activate(id);
        // gentle scroll to top of the main panel area
        var main = document.querySelector('.sos-account__main');
        if (main && main.scrollIntoView) {
          main.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    });
  });
  // "Show all >" inline jumps inside panels
  document.querySelectorAll('[data-jump]').forEach(function(el){
    el.addEventListener('click', function(e){
      var target = el.getAttribute('data-jump');
      if (target) {
        e.preventDefault();
        if (history && history.replaceState) {
          history.replaceState(null, '', '#' + target);
        } else {
          window.location.hash = '#' + target;
        }
        activate(target);
      }
    });
  });
})();
(function(){
  // Hydrate the Favorites tab from the theme's existing wishlist storage.
  // theme.js (line ~4622) stores product handles in localStorage key 'localWishlist'.
  var grid = document.getElementById('sosFavoritesGrid');
  var empty = document.getElementById('sosFavoritesEmpty');
  if (!grid) return;

  function formatMoney(cents){
    var amount = (cents / 100);
    var symbol = (window.Shopify && Shopify.currency && Shopify.currency.active === 'EUR') ? '€' : '';
    var formatted = amount.toFixed(2).replace('.', ',');
    return symbol + formatted;
  }

  function readWishlist(){
    try {
      var raw = localStorage.getItem('localWishlist');
      if (!raw) return [];
      var parsed = JSON.parse(raw);
      return Array.isArray(parsed) ? parsed : [];
    } catch(e) { return []; }
  }

  function showEmpty(){
    grid.classList.add('sos-account__hide');
    if (empty) empty.classList.remove('sos-account__hide');
  }
  function showGrid(){
    grid.classList.remove('sos-account__hide');
    if (empty) empty.classList.add('sos-account__hide');
  }

  function renderCard(product){
    var url   = product.url || ('/products/' + product.handle);
    var img   = product.featured_image || (product.media && product.media[0] && product.media[0].preview_image && product.media[0].preview_image.src) || '';
    var title = product.title || product.handle;
    var vendor = product.vendor || '';
    var price = product.price_varies
      ? ('from ' + formatMoney(product.price_min))
      : formatMoney(product.price);
    var card = document.createElement('div');
    card.className = 'sos-account__product-card sos-account__fav-card';
    card.setAttribute('data-handle', product.handle);
    card.innerHTML = ''
      + '<a href="' + url + '" aria-label="' + (title.replace(/"/g,'&quot;')) + '" class="sos-account__fav-link">'
      +   (img ? '<img src="' + img + '" alt="' + (title.replace(/"/g,'&quot;')) + '" loading="lazy" width="360" height="360">' : '')
      +   '<div class="sos-account__fav-meta">'
      +     '<p class="sos-account__fav-title">' + title + '</p>'
      +     (vendor ? '<p class="sos-account__fav-vendor">' + vendor + '</p>' : '')
      +     '<p class="sos-account__fav-price">' + price + '</p>'
      +   '</div>'
      + '</a>'
      + '<button type="button" class="sos-account__fav-remove" aria-label="Remove from favorites" data-handle="' + product.handle + '">&times;</button>';
    return card;
  }

  function removeHandle(handle){
    var list = readWishlist();
    var next = list.filter(function(h){ return h !== handle; });
    try { localStorage.setItem('localWishlist', JSON.stringify(next)); } catch(e){}
    // also keep the global theme wishlist UI count in sync if visible
    var countEl = document.querySelector('.js-wishlist-count');
    if (countEl) countEl.textContent = next.length;
    return next;
  }

  function hydrate(){
    var handles = readWishlist();
    grid.innerHTML = '';
    if (!handles.length) { showEmpty(); return; }
    showGrid();
    var pending = handles.length;
    var fetched = [];
    var root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || '/';
    handles.forEach(function(h){
      fetch(root + 'products/' + encodeURIComponent(h) + '.js', { credentials: 'same-origin' })
        .then(function(r){ return r.ok ? r.json() : null; })
        .then(function(p){
          if (p) fetched.push(p);
        })
        .catch(function(){ /* ignore one-off failures */ })
        .finally(function(){
          pending -= 1;
          if (pending === 0) {
            // Preserve original wishlist order
            var byHandle = {};
            fetched.forEach(function(p){ byHandle[p.handle] = p; });
            handles.forEach(function(h){
              if (byHandle[h]) grid.appendChild(renderCard(byHandle[h]));
            });
            if (!grid.children.length) showEmpty();
            // attach remove handlers
            grid.querySelectorAll('.sos-account__fav-remove').forEach(function(btn){
              btn.addEventListener('click', function(e){
                e.preventDefault();
                e.stopPropagation();
                var handle = btn.getAttribute('data-handle');
                var card = btn.closest('.sos-account__fav-card');
                removeHandle(handle);
                if (card) card.remove();
                if (!grid.children.length) showEmpty();
              });
            });
          }
        });
    });
  }

  hydrate();
  // Re-hydrate if user adds/removes a favorite in another tab while this one is open
  window.addEventListener('storage', function(e){ if (e.key === 'localWishlist') hydrate(); });
})();
</script>

{%- endif -%}

