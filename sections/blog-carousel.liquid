{{ 'blog-carousel.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign blog_handle      = section.settings.blog
  assign posts_to_show    = section.settings.posts_to_show
  assign offset           = section.settings.offset
  assign layout_mode      = section.settings.layout_mode
  assign grid_style       = section.settings.grid_style
  assign cards_per_view   = section.settings.cards_per_view
  assign tab_cards        = section.settings.tab_cards
  assign mob_cards        = section.settings.mob_cards
  assign grid_cols        = section.settings.grid_cols
  assign section_width    = section.settings.section_width
  assign custom_width     = section.settings.custom_width
  assign heading_text     = section.settings.heading_text
  assign show_header      = section.settings.show_header
  assign show_nav         = section.settings.show_nav
  assign show_date        = section.settings.show_date
  assign show_read_time   = section.settings.show_read_time
  assign show_tag         = section.settings.show_tag
  assign show_excerpt     = section.settings.show_excerpt
  assign card_border_radius = section.settings.card_border_radius
  assign card_aspect      = section.settings.card_aspect
  assign bg_color         = section.settings.bg_color
  assign text_color       = section.settings.text_color
  assign tag_color        = section.settings.tag_color
  assign meta_color       = section.settings.meta_color
  assign nav_color        = section.settings.nav_color
  assign nav_bg_color     = section.settings.nav_bg_color
  assign heading_size     = section.settings.heading_size
  assign title_size       = section.settings.title_size
  assign meta_size        = section.settings.meta_size
  assign tag_size         = section.settings.tag_size
  assign card_gap         = section.settings.card_gap
  assign padding_top      = section.settings.padding_top
  assign padding_bottom   = section.settings.padding_bottom
  assign margin_top       = section.settings.margin_top
  assign margin_bottom    = section.settings.margin_bottom
-%}

{%- capture width_style -%}
  {%- case section_width -%}
    {%- when 'full' -%}max-width:100%;
    {%- when 'container' -%}max-width:var(--page-width,1200px);
    {%- when 'boxed' -%}max-width:1000px;
    {%- when 'custom' -%}max-width:{{ custom_width }}px;
  {%- endcase -%}
{%- endcapture -%}

{%- capture aspect_value -%}
  {%- case card_aspect -%}
    {%- when 'portrait' -%}3/4
    {%- when 'square' -%}1/1
    {%- when 'landscape' -%}4/3
    {%- when 'wide' -%}16/9
  {%- endcase -%}
{%- endcapture -%}

{%- if blog_handle != blank -%}
  {%- assign blog_obj = blogs[blog_handle] -%}
{%- endif -%}

{%- assign is_grid = false -%}
{%- if layout_mode == 'grid' -%}
  {%- assign is_grid = true -%}
{%- endif -%}

{%- capture clock_icon -%}
<svg width="13" height="13" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="display:block;flex-shrink:0;overflow:visible">
  <circle cx="12" cy="12" r="10" stroke="{{ meta_color }}" stroke-width="2" fill="none"/>
  <line x1="12" y1="6" x2="12" y2="12" stroke="{{ meta_color }}" stroke-width="2" stroke-linecap="round"/>
  <line x1="12" y1="12" x2="16" y2="14" stroke="{{ meta_color }}" stroke-width="2" stroke-linecap="round"/>
</svg>
{%- endcapture -%}

{%- capture clock_icon_overlay -%}
<svg width="13" height="13" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="display:block;flex-shrink:0;overflow:visible">
  <circle cx="12" cy="12" r="10" stroke="rgba(255,255,255,0.65)" stroke-width="2" fill="none"/>
  <line x1="12" y1="6" x2="12" y2="12" stroke="rgba(255,255,255,0.65)" stroke-width="2" stroke-linecap="round"/>
  <line x1="12" y1="12" x2="16" y2="14" stroke="rgba(255,255,255,0.65)" stroke-width="2" stroke-linecap="round"/>
</svg>
{%- endcapture -%}

<div
  id="BlogCarousel-{{ section.id }}"
  class="blog-carousel blog-carousel--{{ layout_mode }}"
  data-layout="{{ layout_mode }}"
  data-grid-style="{{ grid_style }}"
  data-cards-per-view="{{ cards_per_view }}"
  data-tab-cards="{{ tab_cards }}"
  data-mob-cards="{{ mob_cards }}"
  data-grid-cols="{{ grid_cols }}"
  data-card-gap="{{ card_gap }}"
  style="
    --bc-padding-top:{{ padding_top }}px;
    --bc-padding-bottom:{{ padding_bottom }}px;
    --bc-margin-top:{{ margin_top }}px;
    --bc-margin-bottom:{{ margin_bottom }}px;
    --bc-card-radius:{{ card_border_radius }}px;
    --bc-card-aspect:{{ aspect_value | strip }};
    --bc-bg:{{ bg_color }};
    --bc-text:{{ text_color }};
    --bc-tag-color:{{ tag_color }};
    --bc-meta-color:{{ meta_color }};
    --bc-nav-color:{{ nav_color }};
    --bc-nav-bg:{{ nav_bg_color }};
    --bc-heading-size:{{ heading_size }}px;
    --bc-title-size:{{ title_size }}px;
    --bc-meta-size:{{ meta_size }}px;
    --bc-tag-size:{{ tag_size }}px;
    --bc-gap:{{ card_gap }}px;
    --bc-cards-per-view:{{ cards_per_view }};
    --bc-grid-cols:{{ grid_cols }};
  "
>
      <div class="blog-carousel__inner" style="{{ width_style }} margin-inline: auto;">

    {%- if show_header -%}
      <div class="blog-carousel__header">
        {%- if heading_text != blank -%}
          <h2 class="blog-carousel__heading">{{ heading_text }}</h2>
        {%- endif -%}
        {%- if show_nav and layout_mode == 'carousel' -%}
          <div class="blog-carousel__nav">
            <button class="blog-carousel__nav-btn blog-carousel__nav-btn--prev" type="button" aria-label="Previous" disabled>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="display:block;overflow:visible">
                <polyline points="15 18 9 12 15 6" fill="none" stroke="{{ nav_color }}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <button class="blog-carousel__nav-btn blog-carousel__nav-btn--next" type="button" aria-label="Next">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="display:block;overflow:visible">
                <polyline points="9 18 15 12 9 6" fill="none" stroke="{{ nav_color }}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- assign articles_to_render = blog_obj.articles | default: nil -%}

    {%- if is_grid -%}

      <div class="blog-carousel__grid blog-carousel__grid--{{ grid_style }}">
        {%- if articles_to_render -%}
          {%- assign rendered = 0 -%}
          {%- assign skipped = 0 -%}
          {%- assign fetch_limit = posts_to_show | plus: offset -%}
          {%- for article in articles_to_render limit: fetch_limit -%}
            {%- if skipped < offset -%}
              {%- assign skipped = skipped | plus: 1 -%}
              {%- continue -%}
            {%- endif -%}
            {%- if rendered >= posts_to_show -%}{%- break -%}{%- endif -%}
            {%- assign rendered = rendered | plus: 1 -%}

            {%- if grid_style == 'overlay' -%}
              <a href="{{ article.url }}" class="blog-carousel__card blog-carousel__card--overlay">
                <div class="blog-carousel__card-img">
                  {%- if article.image -%}
                    <img
                      src="{{ article.image | image_url: width: 800 }}"
                      srcset="{{ article.image | image_url: width: 400 }} 400w, {{ article.image | image_url: width: 600 }} 600w, {{ article.image | image_url: width: 800 }} 800w"
                      sizes="(max-width:749px) 90vw, (max-width:999px) 45vw, 25vw"
                      alt="{{ article.title | escape }}"
                      width="{{ article.image.width }}"
                      height="{{ article.image.height }}"
                      loading="lazy"
                    >
                  {%- else -%}
                    <div class="blog-carousel__card-placeholder">{{ 'image' | placeholder_svg_tag }}</div>
                  {%- endif -%}
                  <div class="blog-carousel__overlay">
                    {%- if show_tag and article.tags.size > 0 -%}
                      <span class="blog-carousel__tag blog-carousel__tag--overlay">{{ article.tags.first }}</span>
                    {%- endif -%}
                    <h3 class="blog-carousel__card-title blog-carousel__card-title--overlay">{{ article.title }}</h3>
                    <div class="blog-carousel__card-meta blog-carousel__card-meta--overlay">
                      {%- if show_date -%}
                        <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%b %d, %Y' }}</time>
                      {%- endif -%}
                      {%- if show_read_time -%}
                        {%- assign words = article.content | strip_html | split: ' ' | size -%}
                        {%- assign read_time = words | divided_by: 200 -%}
                        {%- if read_time == 0 -%}{%- assign read_time = 1 -%}{%- endif -%}
                        <span class="blog-carousel__read-time">
                          {{ clock_icon_overlay }}
                          {{ read_time }} min read
                        </span>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
              </a>

            {%- else -%}
              <a href="{{ article.url }}" class="blog-carousel__card">
                <div class="blog-carousel__card-img">
                  {%- if article.image -%}
                    <img
                      src="{{ article.image | image_url: width: 800 }}"
                      srcset="{{ article.image | image_url: width: 400 }} 400w, {{ article.image | image_url: width: 600 }} 600w, {{ article.image | image_url: width: 800 }} 800w"
                      sizes="(max-width:749px) 90vw, (max-width:999px) 45vw, 25vw"
                      alt="{{ article.title | escape }}"
                      width="{{ article.image.width }}"
                      height="{{ article.image.height }}"
                      loading="lazy"
                    >
                  {%- else -%}
                    <div class="blog-carousel__card-placeholder">{{ 'image' | placeholder_svg_tag }}</div>
                  {%- endif -%}
                </div>
                <div class="blog-carousel__card-body">
                  {%- if show_tag and article.tags.size > 0 -%}
                    <span class="blog-carousel__tag">{{ article.tags.first }}</span>
                  {%- endif -%}
                  <h3 class="blog-carousel__card-title">{{ article.title }}</h3>
                  {%- if show_excerpt and article.excerpt_or_content != blank -%}
                    <p class="blog-carousel__card-excerpt">{{ article.excerpt_or_content | strip_html | truncate: 100 }}</p>
                  {%- endif -%}
                  <div class="blog-carousel__card-meta">
                    {%- if show_date -%}
                      <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%b %d, %Y' }}</time>
                    {%- endif -%}
                    {%- if show_read_time -%}
                      {%- assign words = article.content | strip_html | split: ' ' | size -%}
                      {%- assign read_time = words | divided_by: 200 -%}
                      {%- if read_time == 0 -%}{%- assign read_time = 1 -%}{%- endif -%}
                      <span class="blog-carousel__read-time">
                        {{ clock_icon }}
                        {{ read_time }} min read
                      </span>
                    {%- endif -%}
                  </div>
                </div>
              </a>
            {%- endif -%}
          {%- endfor -%}

        {%- else -%}
          {%- for i in (1..8) -%}
            <div class="blog-carousel__card">
              <div class="blog-carousel__card-img"><div class="blog-carousel__card-placeholder">{{ 'image' | placeholder_svg_tag }}</div></div>
              <div class="blog-carousel__card-body">
                <span class="blog-carousel__tag">Topic Tag</span>
                <h3 class="blog-carousel__card-title">Punchy SEO optimized blog post title</h3>
                <div class="blog-carousel__card-meta">
                  <time>April 15, 2025</time>
                  <span class="blog-carousel__read-time">{{ clock_icon }}5 min read</span>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

    {%- else -%}

      <div class="blog-carousel__track-wrapper">
        <div class="blog-carousel__track">
          {%- if articles_to_render -%}
            {%- assign rendered = 0 -%}
            {%- assign skipped = 0 -%}
            {%- assign fetch_limit = posts_to_show | plus: offset -%}
            {%- for article in articles_to_render limit: fetch_limit -%}
              {%- if skipped < offset -%}
                {%- assign skipped = skipped | plus: 1 -%}
                {%- continue -%}
              {%- endif -%}
              {%- if rendered >= posts_to_show -%}{%- break -%}{%- endif -%}
              {%- assign rendered = rendered | plus: 1 -%}
              <a href="{{ article.url }}" class="blog-carousel__card">
                <div class="blog-carousel__card-img">
                  {%- if article.image -%}
                    <img
                      src="{{ article.image | image_url: width: 600 }}"
                      srcset="{{ article.image | image_url: width: 300 }} 300w, {{ article.image | image_url: width: 450 }} 450w, {{ article.image | image_url: width: 600 }} 600w"
                      sizes="(max-width:749px) 90vw, 25vw"
                      alt="{{ article.title | escape }}"
                      width="{{ article.image.width }}"
                      height="{{ article.image.height }}"
                      loading="lazy"
                    >
                  {%- else -%}
                    <div class="blog-carousel__card-placeholder">{{ 'image' | placeholder_svg_tag }}</div>
                  {%- endif -%}
                </div>
                <div class="blog-carousel__card-body">
                  {%- if show_tag and article.tags.size > 0 -%}
                    <span class="blog-carousel__tag">{{ article.tags.first }}</span>
                  {%- endif -%}
                  <h3 class="blog-carousel__card-title">{{ article.title }}</h3>
                  {%- if show_excerpt and article.excerpt_or_content != blank -%}
                    <p class="blog-carousel__card-excerpt">{{ article.excerpt_or_content | strip_html | truncate: 100 }}</p>
                  {%- endif -%}
                  <div class="blog-carousel__card-meta">
                    {%- if show_date -%}
                      <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%b %d, %Y' }}</time>
                    {%- endif -%}
                    {%- if show_read_time -%}
                      {%- assign words = article.content | strip_html | split: ' ' | size -%}
                      {%- assign read_time = words | divided_by: 200 -%}
                      {%- if read_time == 0 -%}{%- assign read_time = 1 -%}{%- endif -%}
                      <span class="blog-carousel__read-time">
                        {{ clock_icon }}
                        {{ read_time }} min read
                      </span>
                    {%- endif -%}
                  </div>
                </div>
              </a>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..8) -%}
              <div class="blog-carousel__card">
                <div class="blog-carousel__card-img"><div class="blog-carousel__card-placeholder">{{ 'image' | placeholder_svg_tag }}</div></div>
                <div class="blog-carousel__card-body">
                  <span class="blog-carousel__tag">Topic Tag</span>
                  <h3 class="blog-carousel__card-title">Punchy SEO optimized blog post title</h3>
                  <div class="blog-carousel__card-meta">
                    <time>April 15, 2025</time>
                    <span class="blog-carousel__read-time">{{ clock_icon }}5 min read</span>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>

    {%- endif -%}

  </div>
</div>

<script>
(function () {
  var el = document.getElementById('BlogCarousel-{{ section.id }}');
  if (!el) return;
  if (el.getAttribute('data-layout') !== 'carousel') return;

  var track = el.querySelector('.blog-carousel__track');
  var prevBtn = el.querySelector('.blog-carousel__nav-btn--prev');
  var nextBtn = el.querySelector('.blog-carousel__nav-btn--next');
  if (!track) return;

  var cards = track.querySelectorAll('.blog-carousel__card');
  var cpvD  = parseFloat(el.getAttribute('data-cards-per-view')) || 4;
  var cpvT  = parseFloat(el.getAttribute('data-tab-cards')) || 2;
  var cpvM  = parseFloat(el.getAttribute('data-mob-cards')) / 10 || 1.2;
  var gap   = parseInt(el.getAttribute('data-card-gap')) || 16;
  var idx   = 0;

  function getCPV() {
    var w = el.querySelector('.blog-carousel__track-wrapper').offsetWidth;
    if (w < 750) return cpvM;
    if (w < 1000) return cpvT;
    return cpvD;
  }

  function slide() {
    var cpv = getCPV();
    var wr  = el.querySelector('.blog-carousel__track-wrapper');
    var tw  = wr.offsetWidth;
    var cw  = (tw - gap * (cpv - 1)) / cpv;
    var max = Math.max(0, cards.length - Math.floor(cpv));
    if (idx > max) idx = max;
    if (idx < 0)   idx = 0;
    cards.forEach(function (c) {
      c.style.width      = cw + 'px';
      c.style.flexBasis  = cw + 'px';
      c.style.flexShrink = '0';
      c.style.flexGrow   = '0';
      c.style.marginRight = gap + 'px';
    });
    track.style.transform = 'translateX(-' + idx * (cw + gap) + 'px)';
    if (prevBtn) prevBtn.disabled = idx === 0;
    if (nextBtn) nextBtn.disabled = idx >= max;
  }

  if (prevBtn) prevBtn.addEventListener('click', function () { idx--; slide(); });
  if (nextBtn) nextBtn.addEventListener('click', function () { idx++; slide(); });

  var rt;
  window.addEventListener('resize', function () { clearTimeout(rt); rt = setTimeout(slide, 150); });

  var sx = 0, dragging = false;
  track.addEventListener('touchstart', function (e) { sx = e.touches[0].clientX; dragging = true; }, { passive: true });
  track.addEventListener('touchend', function (e) {
    if (!dragging) return;
    dragging = false;
    var d = sx - e.changedTouches[0].clientX;
    if (Math.abs(d) > 50) { idx += d > 0 ? 1 : -1; slide(); }
  }, { passive: true });

  slide();
})();
</script>

{% schema %}
{
  "name": "Blog Carousel",
  "tag": "section",
  "class": "blog-carousel-section",
  "settings": [
    {
      "type": "header",
      "content": "Blog Source"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Select blog"
    },
    {
      "type": "range",
      "id": "posts_to_show",
      "label": "Posts to show",
      "min": 3,
      "max": 20,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "offset",
      "label": "Skip first N posts",
      "min": 0,
      "max": 10,
      "step": 1,
      "default": 0,
      "info": "Useful if those posts are already shown elsewhere on the page."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout_mode",
      "label": "Layout mode",
      "options": [
        { "value": "carousel", "label": "Carousel" },
        { "value": "grid",     "label": "Grid" }
      ],
      "default": "carousel"
    },
    {
      "type": "select",
      "id": "grid_style",
      "label": "Grid card style",
      "options": [
        { "value": "below",   "label": "Text below image" },
        { "value": "overlay", "label": "Text overlay on image" }
      ],
      "default": "below",
      "info": "Only applies when Layout mode is Grid."
    },
    {
      "type": "range",
      "id": "grid_cols",
      "label": "Grid columns (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4,
      "info": "Tablet shows max 2, mobile shows 1."
    },
    {
      "type": "range",
      "id": "cards_per_view",
      "label": "Cards per view — desktop (carousel)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "tab_cards",
      "label": "Cards per view — tablet (carousel)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "mob_cards",
      "label": "Cards per view — mobile (carousel)",
      "min": 10,
      "max": 20,
      "step": 1,
      "default": 12,
      "info": "Stored as tenths: 12 = 1.2 cards, 15 = 1.5 cards."
    },
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "full",      "label": "Full width" },
        { "value": "container", "label": "Container" },
        { "value": "boxed",     "label": "Boxed" },
        { "value": "custom",    "label": "Custom" }
      ],
      "default": "container"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "Custom width (px)",
      "min": 600,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Show header",
      "default": true
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading",
      "default": "Discover your next obsession"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size",
      "min": 18,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "checkbox",
      "id": "show_nav",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "header",
      "content": "Card Settings"
    },
    {
      "type": "select",
      "id": "card_aspect",
      "label": "Image aspect ratio",
      "options": [
        { "value": "portrait",  "label": "Portrait 3:4" },
        { "value": "square",    "label": "Square 1:1" },
        { "value": "landscape", "label": "Landscape 4:3" },
        { "value": "wide",      "label": "Wide 16:9" }
      ],
      "default": "square"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap between cards",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "show_tag",
      "label": "Show topic tag",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "label": "Show publish date",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_read_time",
      "label": "Show read time",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt",
      "default": false
    },
    {
      "type": "header",
      "content": "Navigation Buttons"
    },
    {
      "type": "range",
      "id": "nav_btn_size",
      "label": "Button size",
      "min": 28,
      "max": 56,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "nav_btn_radius",
      "label": "Button radius (0=square, 50=circle)",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "%",
