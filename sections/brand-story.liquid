<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">

{%- liquid
  assign section_width  = section.settings.section_width
  assign custom_width   = section.settings.custom_width
  assign padding_top    = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign margin_top     = section.settings.margin_top
  assign margin_bottom  = section.settings.margin_bottom
  assign image_position = section.settings.image_position
-%}

{%- capture width_style -%}
  {%- case section_width -%}
    {%- when 'full' -%}max-width: 100%;
    {%- when 'container' -%}max-width: var(--page-width, 1200px); margin-left: auto; margin-right: auto;
    {%- when 'boxed' -%}max-width: 1000px; margin-left: auto; margin-right: auto;
    {%- when 'custom' -%}max-width: {{ custom_width }}px; margin-left: auto; margin-right: auto;
  {%- endcase -%}
{%- endcapture -%}

<section
  class="bs"
  style="
    background-color: {{ section.settings.bg_color }};
    margin-top: {{ margin_top }}px;
    margin-bottom: {{ margin_bottom }}px;
  "
>
  <div
    class="bs__inner bs__inner--{{ image_position }}"
    style="{{ width_style }} padding-top: {{ padding_top }}px; padding-bottom: {{ padding_bottom }}px; padding-left: {{ section.settings.padding_horizontal }}px; padding-right: {{ section.settings.padding_horizontal }}px;"
  >

    {%- comment -%} IMAGE {%- endcomment -%}
    {%- if section.settings.image != blank -%}
      <div class="bs__image-wrap">
        <img
          src="{{ section.settings.image | image_url: width: 600 }}"
          srcset="
            {{ section.settings.image | image_url: width: 300 }} 300w,
            {{ section.settings.image | image_url: width: 500 }} 500w,
            {{ section.settings.image | image_url: width: 700 }} 700w
          "
          sizes="(max-width: 749px) 90vw, 40vw"
          alt="{{ section.settings.image.alt | escape }}"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
          loading="lazy"
          style="border-radius: {{ section.settings.image_border_radius }}%;"
        >
      </div>
    {%- endif -%}

    {%- comment -%} TEXT {%- endcomment -%}
    <div class="bs__content" style="text-align: {{ section.settings.text_align }};">

      {%- if section.settings.subheading != blank -%}
        <p
          class="bs__subheading"
          style="
            font-family: {{ section.settings.subheading_font }};
            font-size: {{ section.settings.subheading_size }}px;
            color: {{ section.settings.subheading_color }};
            letter-spacing: {{ section.settings.subheading_spacing }}em;
          "
        >{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2
          class="bs__heading"
          style="
            font-family: {{ section.settings.heading_font }};
            font-size: {{ section.settings.heading_size }}px;
            color: {{ section.settings.heading_color }};
            font-weight: {{ section.settings.heading_weight }};
          "
        >{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div
          class="bs__text"
          style="
            font-family: {{ section.settings.text_font }};
            font-size: {{ section.settings.text_size }}px;
            color: {{ section.settings.text_color }};
            line-height: {{ section.settings.text_line_height }};
          "
        >{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
        <a
          class="bs__btn"
          href="{{ section.settings.button_link }}"
          style="
            background-color: {{ section.settings.btn_bg }};
            color: {{ section.settings.btn_text_color }};
            border-color: {{ section.settings.btn_border_color }};
            border-radius: {{ section.settings.btn_radius }}px;
            font-size: {{ section.settings.btn_font_size }}px;
            font-weight: {{ section.settings.btn_font_weight }};
            font-family: {{ section.settings.btn_font }};
            padding: {{ section.settings.btn_padding_v }}px {{ section.settings.btn_padding_h }}px;
            --bs-btn-hover-bg: {{ section.settings.btn_hover_bg }};
            --bs-btn-hover-text: {{ section.settings.btn_hover_text_color }};
            --bs-btn-hover-border: {{ section.settings.btn_hover_border_color }};
          "
        >{{ section.settings.button_label }}</a>
      {%- endif -%}

    </div>

  </div>
</section>

<style>
  .bs { width: 100%; }
  .bs__inner {
    display: flex;
    align-items: center;
    gap: {{ section.settings.gap }}px;
  }
  .bs__inner--left  { flex-direction: row; }
  .bs__inner--right { flex-direction: row-reverse; }

  .bs__image-wrap {
    flex: 0 0 {{ section.settings.image_width }}%;
    max-width: {{ section.settings.image_width }}%;
  }
  .bs__image-wrap img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .bs__content { flex: 1; }

  .bs__subheading {
    margin: 0 0 10px;
    text-transform: uppercase;
  }
  .bs__heading {
    margin: 0 0 16px;
    line-height: 1.2;
  }
  .bs__text {
    margin: 0 0 28px;
  }
  .bs__text p { margin: 0 0 12px; }
  .bs__text p:last-child { margin-bottom: 0; }

  .bs__btn {
    display: inline-block;
    text-decoration: none;
    border: 1px solid transparent;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    letter-spacing: 0.04em;
  }
  .bs__btn:hover {
    background-color: var(--bs-btn-hover-bg) !important;
    color: var(--bs-btn-hover-text) !important;
    border-color: var(--bs-btn-hover-border) !important;
  }

  @media screen and (max-width: 749px) {
    .bs__inner {
      flex-direction: column !important;
      gap: 24px;
    }
    .bs__image-wrap {
      flex: 0 0 100%;
      max-width: {{ section.settings.image_width_mobile }}%;
      margin: 0 auto;
    }
  }
</style>

{% schema %}
{
  "name": "Brand Story",
  "tag": "section",
  "class": "brand-story-section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "default": "container",
      "options": [
        { "value": "full",      "label": "Full Width" },
        { "value": "container", "label": "Container" },
        { "value": "boxed",     "label": "Boxed" },
        { "value": "custom",    "label": "Custom" }
      ]
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "Custom width (px)",
      "min": 400,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "default": "left",
      "options": [
        { "value": "left",  "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between image & text",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0, "max": 148, "step": 4, "unit": "px", "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0, "max": 148, "step": 4, "unit": "px", "default": 60
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding left & right",
      "min": 0, "max": 100, "step": 4, "unit": "px", "default": 40
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": 0, "max": 148, "step": 4, "unit": "px", "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": 0, "max": 148, "step": 4, "unit": "px", "default": 0
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Image width (desktop %)",
      "min": 20, "max": 60, "step": 2, "unit": "%", "default": 36
    },
    {
      "type": "range",
      "id": "image_width_mobile",
      "label": "Image width (mobile %)",
      "min": 40, "max": 100, "step": 4, "unit": "%", "default": 64
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0, "max": 50, "step": 2, "unit": "%",
      "default": 50,
      "info": "50% = circle"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "default": "left",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Subheading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading text"
    },
    {
      "type": "select",
      "id": "subheading_font",
      "label": "Subheading font",
      "default": "'Manrope', sans-serif",
      "options": [
        { "value": "'Manrope', sans-serif",          "label": "Manrope" },
        { "value": "'Helvetica Neue', sans-serif",   "label": "Helvetica Neue" },
        { "value": "Georgia, serif",                 "label": "Georgia" },
        { "value": "'Times New Roman', serif",       "label": "Times New Roman" },
        { "value": "var(--font-body-family)",        "label": "Theme body font" },
        { "value": "var(--font-heading-family)",     "label": "Theme heading font" }
      ]
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 10, "max": 24, "step": 1, "unit": "px", "default": 12
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#928171"
    },
    {
      "type": "range",
      "id": "subheading_spacing",
      "label": "Letter spacing",
      "min": 0, "max": 0.4, "step": 0.1, "unit": "em", "default": 0.1
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Curated with passion"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Heading font",
      "default": "'Manrope', sans-serif",
      "options": [
        { "value": "'Manrope', sans-serif",          "label": "Manrope" },
        { "value": "'Helvetica Neue', sans-serif",   "label": "Helvetica Neue" },
        { "value": "Georgia, serif",                 "label": "Georgia" },
        { "value": "'Times New Roman', serif",       "label": "Times New Roman" },
        { "value": "var(--font-body-family)",        "label": "Theme body font" },
        { "value": "var(--font-heading-family)",     "label": "Theme heading font" }
      ]
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16, "max": 72, "step": 2, "unit": "px", "default": 32
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#030303"
    },
    {
      "type": "header",
      "content": "Body text"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Hier könnte man so ne kleine Section reinmachen mit Link zu Vision und bischen personal branding über dich.</p><p>Lorem ipsum dolor sit amet, consetetur sadipscing elitr, sed diam nonumy eirmod tempor invidunt ut labore et dolore magna aliquyam erat.</p>"
    },
    {
      "type": "select",
      "id": "text_font",
      "label": "Text font",
      "default": "'Manrope', sans-serif",
      "options": [
        { "value": "'Manrope', sans-serif",          "label": "Manrope" },
        { "value": "'Helvetica Neue', sans-serif",   "label": "Helvetica Neue" },
        { "value": "Georgia, serif",                 "label": "Georgia" },
        { "value": "'Times New Roman', serif",       "label": "Times New Roman" },
        { "value": "var(--font-body-family)",        "label": "Theme body font" }
      ]
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12, "max": 24, "step": 1, "unit": "px", "default": 15
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#2C2722"
    },
    {
      "type": "range",
      "id": "text_line_height",
      "label": "Line height",
      "min": 1.2, "max": 2.2, "step": 0.1, "default": 1.7
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Learn more about our vision"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "btn_font",
      "label": "Button font",
      "default": "'Manrope', sans-serif",
      "options": [
        { "value": "'Manrope', sans-serif",        "label": "Manrope" },
        { "value": "'Helvetica Neue', sans-serif", "label": "Helvetica Neue" },
        { "value": "Georgia, serif",               "label": "Georgia" },
        { "value": "var(--font-body-family)",      "label": "Theme body font" }
      ]
    },
    {
      "type": "range",
      "id": "btn_font_size",
      "label": "Button font size",
      "min": 10, "max": 22, "step": 1, "unit": "px", "default": 14
    },
    {
      "type": "select",
      "id": "btn_font_weight",
      "label": "Button font weight",
      "default": "500",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "range",
      "id": "btn_radius",
      "label": "Button border radius",
      "min": 0, "max": 50, "step": 2, "unit": "px", "default": 50
    },
    {
      "type": "range",
      "id": "btn_padding_v",
      "label": "Button padding (top/bottom)",
      "min": 4, "max": 32, "step": 2, "unit": "px", "default": 14
    },
    {
      "type": "range",
      "id": "btn_padding_h",
      "label": "Button padding (left/right)",
      "min": 8, "max": 80, "step": 2, "unit": "px", "default": 28
    },
    {
      "type": "header",
      "content": "Button colors"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Background",
      "default": "#928171"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "btn_border_color",
      "label": "Border color",
      "default": "#928171"
    },
    {
      "type": "header",
      "content": "Button hover colors"
    },
    {
      "type": "color",
      "id": "btn_hover_bg",
      "label": "Hover background",
      "default": "#2C2722"
    },
    {
      "type": "color",
      "id": "btn_hover_text_color",
      "label": "Hover text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "btn_hover_border_color",
      "label": "Hover border color",
      "default": "#2C2722"
    }
