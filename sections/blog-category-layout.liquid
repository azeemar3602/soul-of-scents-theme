{%- comment -%}
  Blog Category Layout Section
  - Featured layout: 1 large hero (left ~62%) + 2x2 small grid (right ~38%) for posts 1-5
  - Remaining posts grid: 4 cols desktop, 2 cols tablet, 1 col mobile
  - Pagination: 17 posts per page
  - Section Width: boxed | container | full_width | custom_width
{%- endcomment -%}

<style>
  .bcl-section {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.background_color }};
  }

  /* Width Modes */
  .bcl-width--boxed .bcl-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .bcl-width--container .bcl-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .bcl-width--full .bcl-container {
    max-width: 100%;
    margin: 0;
    padding: 0 20px;
  }
  .bcl-width--custom .bcl-container {
    max-width: {{ section.settings.custom_width }};
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Featured top section */
  .bcl-featured {
    display: grid;
    grid-template-columns: 62% 38%;
    gap: 16px;
    margin-bottom: 24px;
  }
  .bcl-small-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 16px;
  }

  /* Cards */
  .bcl-card {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    display: block;
    text-decoration: none;
    color: inherit;
    background: #111;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .bcl-card:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(0,0,0,.18); }
  .bcl-card__img-wrapper { position: relative; width: 100%; overflow: hidden; }
  .bcl-card--large .bcl-card__img-wrapper { height: 520px; }
  .bcl-card--small .bcl-card__img-wrapper { height: 248px; }
  .bcl-card--grid  .bcl-card__img-wrapper { height: 220px; }
  .bcl-card__img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease; }
  .bcl-card:hover .bcl-card__img { transform: scale(1.04); }
  .bcl-card__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.72) 0%, rgba(0,0,0,.18) 55%, transparent 100%);
  }
  .bcl-card__content {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 20px 20px 22px;
    color: #fff;
  }
  .bcl-card--grid .bcl-card__content { padding: 14px 16px 16px; }
  .bcl-card__tag { font-size: 11px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; opacity: .8; margin-bottom: 6px; display: block; }
  .bcl-card__title { font-size: 1.25rem; font-weight: 700; line-height: 1.3; margin: 0 0 8px; color: #fff; }
  .bcl-card--small .bcl-card__title,
  .bcl-card--grid  .bcl-card__title { font-size: 1rem; margin-bottom: 6px; }
  .bcl-card__excerpt { font-size: .875rem; opacity: .85; line-height: 1.5; margin-bottom: 10px; }
  .bcl-card--small .bcl-card__excerpt,
  .bcl-card--grid  .bcl-card__excerpt { display: none; }
  .bcl-card__meta { display: flex; align-items: center; gap: 14px; font-size: .75rem; opacity: .75; }
  .bcl-card__meta-item { display: flex; align-items: center; gap: 4px; }

  /* Remaining grid */
  .bcl-grid-section { margin-top: 8px; }
  .bcl-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  /* Pagination */
  .bcl-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: 48px;
    flex-wrap: wrap;
  }
  .bcl-pagination__item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: auto;
    height: auto;
    padding: 0;
    border-radius: 8px;
    font-size: .875rem;
    font-weight: 400;
    text-decoration: none;
    color: #928171;
      border: none;
      transition: color .2s;
  }
  .bcl-pagination__item:hover { background: none; color: #030303; border: none; }
  .bcl-pagination__item--current { background: none; color: #030303; font-weight: 700; border: none; pointer-events: none; }
  .bcl-pagination__item--disabled { opacity: .35; pointer-events: none; }
  .bcl-pagination__item--prev { display: none; }
  .bcl-pagination__item--next { background: none; border: none; color: #928171; } .bcl-pagination__item svg { display: none; }

  /* Responsive */
  @media (max-width: 900px) {
    .bcl-featured { grid-template-columns: 1fr; }
    .bcl-card--large .bcl-card__img-wrapper { height: 360px; }
    .bcl-small-grid { grid-template-columns: 1fr 1fr; grid-template-rows: auto; }
    .bcl-card--small .bcl-card__img-wrapper { height: 200px; }
    .bcl-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    .bcl-small-grid { grid-template-columns: 1fr; }
    .bcl-grid { grid-template-columns: 1fr; }
    .bcl-card--small .bcl-card__excerpt { display: none; }
  }
</style>

{%- assign target_blog = blogs[section.settings.blog] | default: blog -%}

{%- assign width_mode = section.settings.section_width -%}
{%- if width_mode == 'boxed' -%}
  {%- assign width_class = 'bcl-width--boxed' -%}
{%- elsif width_mode == 'full_width' -%}
  {%- assign width_class = 'bcl-width--full' -%}
{%- elsif width_mode == 'custom_width' -%}
  {%- assign width_class = 'bcl-width--custom' -%}
{%- else -%}
  {%- assign width_class = 'bcl-width--container' -%}
{%- endif -%}

{%- paginate target_blog.articles by 17 -%}

<section class="bcl-section {{ width_class }}" data-section-id="{{ section.id }}" data-section-type="blog-category-layout">
  <div class="bcl-container">

    {%- assign feat_articles = target_blog.articles | limit: 5 -%}
    {%- assign feat_count = feat_articles | size -%}

    {%- if feat_count > 0 -%}
    <div class="bcl-featured">

      {%- assign large = feat_articles[0] -%}
      <a href="{{ large.url }}" class="bcl-card bcl-card--large" aria-label="{{ large.title | escape }}">
        <div class="bcl-card__img-wrapper">
          {%- if large.image -%}
            <img class="bcl-card__img"
              src="{{ large.image | image_url: width: 900 }}"
              alt="{{ large.image.alt | default: large.title | escape }}"
              loading="eager" width="900" height="600">
          {%- else -%}
            <div style="background:linear-gradient(135deg,#1a1a2e,#16213e);width:100%;height:100%;position:absolute;inset:0;"></div>
          {%- endif -%}
        </div>
        <div class="bcl-card__overlay"></div>
        <div class="bcl-card__content">
          <span class="bcl-card__tag">{{ large.tags.first | default: "Article" }}</span>
          <h2 class="bcl-card__title">{{ large.title }}</h2>
          <p class="bcl-card__excerpt">{{ large.excerpt_or_content | strip_html | truncate: 120 }}</p>
          <div class="bcl-card__meta">
            <span class="bcl-card__meta-item">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              {{ large.published_at | date: "%b %d, %Y" }}
            </span>
            <span class="bcl-card__meta-item">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              {%- assign lw = large.content | strip_html | split: " " | size -%}
              {%- assign lm = lw | divided_by: 200 -%}
              {%- if lm < 1 -%}{%- assign lm = 1 -%}{%- endif -%}
              {{ lm }} min read
            </span>
          </div>
        </div>
      </a>

      {%- if feat_count > 1 -%}
      <div class="bcl-small-grid">
        {%- for i in (1..4) -%}
          {%- assign sm = feat_articles[i] -%}
          {%- if sm -%}
          <a href="{{ sm.url }}" class="bcl-card bcl-card--small" aria-label="{{ sm.title | escape }}">
            <div class="bcl-card__img-wrapper">
              {%- if sm.image -%}
                <img class="bcl-card__img"
                  src="{{ sm.image | image_url: width: 500 }}"
                  alt="{{ sm.image.alt | default: sm.title | escape }}"
                  loading="lazy" width="500" height="340">
              {%- else -%}
                <div style="background:linear-gradient(135deg,#1a1a2e,#16213e);width:100%;height:100%;position:absolute;inset:0;"></div>
              {%- endif -%}
            </div>
            <div class="bcl-card__overlay"></div>
            <div class="bcl-card__content">
              <span class="bcl-card__tag">{{ sm.tags.first | default: "Article" }}</span>
              <h3 class="bcl-card__title">{{ sm.title }}</h3>
              <div class="bcl-card__meta">
                <span class="bcl-card__meta-item">{{ sm.published_at | date: "%b %d, %Y" }}</span>
                <span class="bcl-card__meta-item">
                  {%- assign sw = sm.content | strip_html | split: " " | size -%}
                  {%- assign sm_m = sw | divided_by: 200 -%}
                  {%- if sm_m < 1 -%}{%- assign sm_m = 1 -%}{%- endif -%}
                  {{ sm_m }} min read
                </span>
              </div>
            </div>
          </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
      {%- endif -%}

    </div>
    {%- endif -%}

    {%- assign has_grid = false -%}
    {%- for article in target_blog.articles -%}
      {%- if forloop.index > 5 -%}
        {%- assign has_grid = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if has_grid -%}
    <div class="bcl-grid-section">
      <div class="bcl-grid">
        {%- for article in target_blog.articles -%}
          {%- if forloop.index > 5 -%}
          <a href="{{ article.url }}" class="bcl-card bcl-card--grid" aria-label="{{ article.title | escape }}">
            <div class="bcl-card__img-wrapper">
              {%- if article.image -%}
                <img class="bcl-card__img"
                  src="{{ article.image | image_url: width: 480 }}"
                  alt="{{ article.image.alt | default: article.title | escape }}"
                  loading="lazy" width="480" height="320">
              {%- else -%}
                <div style="background:linear-gradient(135deg,#1a1a2e,#16213e);width:100%;height:100%;position:absolute;inset:0;"></div>
              {%- endif -%}
            </div>
            <div class="bcl-card__overlay"></div>
            <div class="bcl-card__content">
              <span class="bcl-card__tag">{{ article.tags.first | default: "Article" }}</span>
              <h3 class="bcl-card__title">{{ article.title }}</h3>
              <div class="bcl-card__meta">
                <span class="bcl-card__meta-item">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  {{ article.published_at | date: "%b %d, %Y" }}
                </span>
                <span class="bcl-card__meta-item">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {%- assign aw = article.content | strip_html | split: " " | size -%}
                  {%- assign am = aw | divided_by: 200 -%}
                  {%- if am < 1 -%}{%- assign am = 1 -%}{%- endif -%}
                  {{ am }} min read
                </span>
              </div>
            </div>
          </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
    {%- endif -%}

    {%- if paginate.pages > 1 -%}
    <nav class="bcl-pagination" aria-label="Blog pagination">
      {%- if paginate.previous -%}
        <a href="{{ paginate.previous.url }}" class="bcl-pagination__item bcl-pagination__item--prev" aria-label="Previous page">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          Prev
        </a>
      {%- else -%}
        <span class="bcl-pagination__item bcl-pagination__item--prev bcl-pagination__item--disabled" aria-disabled="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
          Prev
        </span>
      {%- endif -%}

      {%- for part in paginate.parts -%}
        {%- if part.is_link -%}
          <a href="{{ part.url }}" class="bcl-pagination__item" aria-label="Page {{ part.title }}">{{ part.title | prepend: '0' | slice: -2, 2 }}</a>
        {%- elsif part.title == paginate.current_page -%}
          <span class="bcl-pagination__item bcl-pagination__item--current" aria-current="page">{{ part.title | prepend: '0' | slice: -2, 2 }}</span>
        {%- else -%}
          <span class="bcl-pagination__item bcl-pagination__item--disabled">{{ part.title | prepend: '0' | slice: -2, 2 }}</span>
        {%- endif -%}
      {%- endfor -%}

      {%- if paginate.next -%}
        <a href="{{ paginate.next.url }}" class="bcl-pagination__item bcl-pagination__item--next" aria-label="Next page">
          ›
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      {%- else -%}
        <span class="bcl-pagination__item bcl-pagination__item--next bcl-pagination__item--disabled" aria-disabled="true">
          ›
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
      {%- endif -%}
    </nav>
    {%- endif -%}

  </div>
</section>

{%- endpaginate -%}

{% schema %}
{
  "name": "Blog Category Layout",
  "tag": "section",
  "class": "blog-category-layout",
  "settings": [
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "header",
      "content": "Layout Width"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section Width",
      "options": [
        { "value": "boxed", "label": "Boxed" },
        { "value": "container", "label": "Container" },
        { "value": "full_width", "label": "Full Width" },
        { "value": "custom_width", "label": "Custom Width" }
      ],
      "default": "container",
      "info": "Boxed: 1100px max | Container: 1280px max | Full Width: 100% | Custom: set below"
    },
    {
      "type": "text",
      "id": "custom_width",
      "label": "Custom Max-Width",
      "default": "1400px",
      "info": "Only used when Custom Width is selected. E.g. 1400px or 90%"
    },
    {
      "type": "header",
      "content": "Colors and Spacing"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Blog Category Layout"
    }
  ]
}
{% endschema %}