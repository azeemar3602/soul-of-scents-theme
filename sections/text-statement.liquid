{{ 'text-statement.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign line1 = section.settings.line1
  assign line2 = section.settings.line2
  assign line1_color = section.settings.line1_color
  assign line2_color = section.settings.line2_color
  assign line2_weight = section.settings.line2_weight
  assign bg_color = section.settings.bg_color
  assign font_size = section.settings.font_size
  assign line_height = section.settings.line_height
  assign font_weight = section.settings.font_weight
  assign letter_spacing = section.settings.letter_spacing
  assign alignment = section.settings.alignment
  assign section_width = section.settings.section_width
  assign custom_width = section.settings.custom_width
  assign show_border_top = section.settings.show_border_top
  assign show_border_bottom = section.settings.show_border_bottom
  assign border_color = section.settings.border_color
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
-%}

{%- capture width_style -%}
  {%- case section_width -%}
    {%- when 'full' -%}
      max-width: 100%;
    {%- when 'container' -%}
      max-width: var(--page-width, 1200px);
    {%- when 'boxed' -%}
      max-width: 1000px;
    {%- when 'custom' -%}
      max-width: {{ custom_width }}px;
  {%- endcase -%}
{%- endcapture -%}

<div
  class="text-statement text-statement--{{ alignment }}{% if show_border_top %} text-statement--border-top{% endif %}{% if show_border_bottom %} text-statement--border-bottom{% endif %}"
  style="
    --ts-bg: {{ bg_color }};
    --ts-line1-color: {{ line1_color }};
    --ts-line2-color: {{ line2_color }};
    --ts-line2-weight: {{ line2_weight }};
    --ts-font-size: {{ font_size }}px;
    --ts-line-height: {{ line_height }};
    --ts-font-weight: {{ font_weight }};
    --ts-letter-spacing: {{ letter_spacing | divided_by: 100.0 }}em;
    --ts-border-color: {{ border_color }};
    --ts-padding-top: {{ padding_top }}px;
    --ts-padding-bottom: {{ padding_bottom }}px;
    --ts-margin-top: {{ margin_top }}px;
    --ts-margin-bottom: {{ margin_bottom }}px;
  "
>
  <div class="text-statement__inner" style="{{ width_style }}">
    <p class="text-statement__text">
      {%- if line1 != blank -%}
        <span class="text-statement__line1">{{ line1 }}</span>
        <br>
      {%- endif -%}
      {%- if line2 != blank -%}
        <span class="text-statement__line2">{{ line2 }}</span>
      {%- endif -%}
    </p>
  </div>
</div>

{% schema %}
{
  "name": "Text Statement",
  "tag": "section",
  "class": "text-statement-section",
  "settings": [
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "line1",
      "label": "Line 1 (light text)",
      "default": "We capture the one-of-a-kind signature of you"
    },
    {
      "type": "text",
      "id": "line2",
      "label": "Line 2 (bold text)",
      "default": "and contribute to an overall elevated, confident feel, drop by drop."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "line1_color",
      "label": "Line 1 color",
      "default": "#c8c8c8"
    },
    {
      "type": "color",
      "id": "line2_color",
      "label": "Line 2 color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e0e0e0"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "Line height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.4
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Line 1 font weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" }
      ],
      "default": "400"
    },
    {
      "type": "select",
      "id": "line2_weight",
      "label": "Line 2 font weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 10,
      "step": 1,
      "default": 0,
      "info": "Value in hundredths of an em."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "full", "label": "Full Width" },
        { "value": "container", "label": "Container" },
        { "value": "boxed", "label": "Boxed" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "container"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "Custom width (px)",
      "min": 600,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1200,
      "info": "Only applies when Custom width is selected."
    },
    {
      "type": "checkbox",
      "id": "show_border_top",
      "label": "Show top border",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_border_bottom",
      "label": "Show bottom border",
      "default": false
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Text Statement",
      "settings": {
        "line1": "We capture the one-of-a-kind signature of you",
        "line2": "and contribute to an overall elevated, confident feel, drop by drop.",
        "section_width": "container"
      }
    }
  ]
}
{% endschema %}