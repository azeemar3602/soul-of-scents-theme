{%- liquid
  assign section_width  = section.settings.section_width
  assign custom_width   = section.settings.custom_width
  assign padding_top    = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign margin_top     = section.settings.margin_top
  assign margin_bottom  = section.settings.margin_bottom
-%}

{%- capture width_style -%}
  {%- case section_width -%}
    {%- when 'full' -%}max-width: 100%;
    {%- when 'container' -%}max-width: var(--page-width, 1200px); margin-left: auto; margin-right: auto;
    {%- when 'boxed' -%}max-width: 1000px; margin-left: auto; margin-right: auto;
    {%- when 'narrow' -%}max-width: 700px; margin-left: auto; margin-right: auto;
    {%- when 'custom' -%}max-width: {{ custom_width }}px; margin-left: auto; margin-right: auto;
  {%- endcase -%}
{%- endcapture -%}

{%- if product.metafields.custom.curator_s_note_quote != blank -%}
  <section
    class="cnq"
    style="
      background-color: {{ section.settings.bg_color }};
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    "
  >
    <div class="cnq__inner" style="{{ width_style }} padding-left: {{ section.settings.padding_horizontal }}px; padding-right: {{ section.settings.padding_horizontal }}px;">

      {%- if section.settings.show_icon -%}
        <div class="cnq__icon" style="color: {{ section.settings.quote_icon_color }};">
          <svg width="{{ section.settings.icon_size }}" height="{{ section.settings.icon_size }}" viewBox="0 0 40 32" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M0 32V19.733C0 14.578 1.422 10.311 4.267 6.933 7.2 3.467 11.556 1.156 17.333 0l2.134 3.467C15.2 4.533 12.356 6.133 10.4 8.267 8.533 10.4 7.556 13.156 7.467 16.533H16V32H0Zm22.667 0V19.733c0-5.155 1.422-9.422 4.266-12.8C29.867 3.467 34.222 1.156 40 0l2.133 3.467c-4.267 1.066-7.111 2.666-9.067 4.8C31.2 10.4 30.222 13.156 30.133 16.533H38.667V32H22.667Z"/>
          </svg>
        </div>
      {%- endif -%}

      <blockquote
        class="cnq__text"
        style="
          font-family: {{ section.settings.quote_font }};
          font-size: {{ section.settings.quote_size }}px;
          font-style: {{ section.settings.quote_style }};
          font-weight: {{ section.settings.quote_weight }};
          color: {{ section.settings.quote_color }};
          line-height: {{ section.settings.quote_line_height }};
          letter-spacing: {{ section.settings.quote_letter_spacing }}em;
          text-align: {{ section.settings.text_align }};
        "
      >{{ product.metafields.custom.curator_s_note_quote }}</blockquote>

      {%- if section.settings.show_label -%}
        <p
          class="cnq__label"
          style="
            font-family: {{ section.settings.label_font }};
            font-size: {{ section.settings.label_size }}px;
            font-weight: {{ section.settings.label_weight }};
            color: {{ section.settings.label_color }};
            letter-spacing: {{ section.settings.label_letter_spacing }}em;
            text-transform: {{ section.settings.label_transform }};
            text-align: {{ section.settings.text_align }};
          "
        >{{ section.settings.label_text }}</p>
      {%- endif -%}

    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Curator's Note Quote",
  "tag": "section",
  "class": "curator-note-section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "default": "narrow",
      "options": [
        { "value": "full",      "label": "Full Width" },
        { "value": "container", "label": "Container" },
        { "value": "boxed",     "label": "Boxed (1000px)" },
        { "value": "narrow",    "label": "Narrow (700px)" },
        { "value": "custom",    "label": "Custom" }
      ]
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "Custom width (px)",
      "min": 300, "max": 1600, "step": 20, "unit": "px", "default": 800
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "default": "center",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    { "type": "range", "id": "padding_top",         "label": "Padding top",          "min": 0, "max": 120, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "padding_bottom",      "label": "Padding bottom",       "min": 0, "max": 120, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "padding_horizontal",  "label": "Padding left & right", "min": 0, "max": 80,  "step": 4, "unit": "px", "default": 20 },
    { "type": "range", "id": "margin_top",          "label": "Margin top",           "min": 0, "max": 120, "step": 4, "unit": "px", "default": 0  },
    { "type": "range", "id": "margin_bottom",       "label": "Margin bottom",        "min": 0, "max": 120, "step": 4, "unit": "px", "default": 0  },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Quote icon"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show quote icon",
      "default": true
    },
    {
      "type": "color",
      "id": "quote_icon_color",
      "label": "Icon color",
      "default": "#D7D4CF"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 16, "max": 64, "step": 4, "unit": "px", "default": 36
    },
    {
      "type": "header",
      "content": "Quote text"
    },
    {
      "type": "select",
      "id": "quote_font",
      "label": "Font family",
      "default": "Georgia, serif",
      "options": [
        { "value": "Georgia, serif",                "label": "Georgia (serif)" },
        { "value": "'Times New Roman', serif",       "label": "Times New Roman" },
        { "value": "'Manrope', sans-serif",          "label": "Manrope" },
        { "value": "'Helvetica Neue', sans-serif",   "label": "Helvetica Neue" },
        { "value": "var(--font-body-family)",        "label": "Theme body font" },
        { "value": "var(--font-heading-family)",     "label": "Theme heading font" }
      ]
    },
    {
      "type": "range",
      "id": "quote_size",
      "label": "Font size",
      "min": 14, "max": 48, "step": 1, "unit": "px", "default": 22
    },
    {
      "type": "select",
      "id": "quote_weight",
      "label": "Font weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "select",
      "id": "quote_style",
      "label": "Font style",
      "default": "italic",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "italic", "label": "Italic" }
      ]
    },
    {
      "type": "color",
      "id": "quote_color",
      "label": "Text color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "quote_line_height",
      "label": "Line height",
      "min": 1, "max": 2, "step": 0.1, "default": 1.6
    },
    { "type": "range", "id": "quote_letter_spacing", "label": "Letter spacing", "min": 0, "max": 0.2, "step": 0.1, "default": 0.0 },
    {
      "type": "header",
      "content": "Label"
    },
    {
      "type": "checkbox",
      "id": "show_label",
      "label": "Show label",
      "default": true
    },
    {
      "type": "text",
      "id": "label_text",
      "label": "Label text",
      "default": "Curator's note"
    },
    {
      "type": "select",
      "id": "label_font",
      "label": "Label font family",
      "default": "'Manrope', sans-serif",
      "options": [
        { "value": "'Manrope', sans-serif",          "label": "Manrope" },
        { "value": "Georgia, serif",                 "label": "Georgia (serif)" },
        { "value": "'Helvetica Neue', sans-serif",   "label": "Helvetica Neue" },
        { "value": "var(--font-body-family)",        "label": "Theme body font" }
      ]
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label font size",
      "min": 10, "max": 20, "step": 1, "unit": "px", "default": 13
    },
    {
      "type": "select",
      "id": "label_weight",
      "label": "Label font weight",
      "default": "400",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" }
      ]
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#928171"
    },
    { "type": "range", "id": "label_letter_spacing", "label": "Label letter spacing", "min": 0, "max": 0.3, "step": 0.1, "default": 0.1 },
    {
      "type": "select",
      "id": "label_transform",
      "label": "Label text transform",
      "default": "none",
      "options": [
        { "value": "none",       "label": "None" },
        { "value": "uppercase",  "label": "Uppercase" },
        { "value": "lowercase",  "label": "Lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Curator's Note Quote"
    }
  ]
}
{% endschema %}