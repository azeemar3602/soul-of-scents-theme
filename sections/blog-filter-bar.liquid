<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700&display=swap" rel="stylesheet">
{{ 'collection-filter-bar.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign section_width  = section.settings.section_width
  assign custom_width   = section.settings.custom_width
  assign padding_top    = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign margin_top     = section.settings.margin_top
  assign margin_bottom  = section.settings.margin_bottom
  assign current_blog   = blog
-%}

{%- capture width_style -%}
  {%- case section_width -%}
    {%- when 'full' -%}max-width: 100%;
    {%- when 'container' -%}max-width: var(--page-width, 1200px); margin-left: auto; margin-right: auto;
    {%- when 'boxed' -%}max-width: 1000px; margin-left: auto; margin-right: auto;
    {%- when 'custom' -%}max-width: {{ custom_width }}px; margin-left: auto; margin-right: auto;
  {%- endcase -%}
{%- endcapture -%}

<div class="cfb bfb" data-bfb style="margin-top: {{ margin_top }}px; margin-bottom: {{ margin_bottom }}px;">

  <div class="cfb__bar" style="{{ width_style }} padding-top: {{ padding_top }}px; padding-bottom: {{ padding_bottom }}px;">
    <span class="cfb__bar-title">
      {%- if section.settings.bar_title != blank -%}
        {{ section.settings.bar_title }}
      {%- elsif current_blog != blank -%}
        {{ current_blog.title | upcase }}
      {%- else -%}
        MAGAZINE
      {%- endif -%}
    </span>

    <button class="cfb__trigger" aria-expanded="false" aria-controls="bfb-panel" aria-label="Toggle topics" data-bfb-trigger>
      <span class="cfb__state-closed">
        <span class="cfb__trigger-label">{{ section.settings.trigger_label | default: 'ALL TOPICS' }}</span>
        <svg class="cfb__icon" width="10" height="7" viewBox="0 0 10 7" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M1 1L5 5.5L9 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
      </span>
      <span class="cfb__state-open">
        <span class="cfb__trigger-label">{{ section.settings.trigger_label | default: 'ALL TOPICS' }}</span>
        <svg class="cfb__icon" width="10" height="7" viewBox="0 0 10 7" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="transform:rotate(180deg)">
          <path d="M1 1L5 5.5L9 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
      </span>
    </button>
  </div>

  <div class="cfb__panel" id="bfb-panel" role="region" aria-label="Blog topics" aria-hidden="true" data-bfb-panel>
    <div class="cfb__panel-inner bfb__panel-inner" style="{{ width_style }}">

