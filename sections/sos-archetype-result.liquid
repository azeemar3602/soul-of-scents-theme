{%- comment -%}
  SOS Archetype Result Section (block-based)
  Used by templates/page.archetype-result.json and per-archetype templates
  (templates/page.archetype-the-seducer.json etc.).

  Each archetype page should be assigned to its own dedicated template so the
  block content (images, copy, layout) can be edited PER PAGE in the customizer.

  The Product source (RH collection) is auto-resolved from the page handle:
    /pages/the-mineralist  ->  collections['rh-the-mineralist']
  No per-page collection picking is needed.
{%- endcomment -%}

{%- liquid
  assign archetype_name = page.title | replace: 'RH - ', '' | strip

  comment
  Collection resolution (per page, not per section setting):
    1. page.metafields.custom.rh_collection  (per-page metafield override)
    2. collections['rh-' + page.handle]      (auto-resolve)
  endcomment
  assign source_col = blank
  if page.metafields.custom.rh_collection != blank
    assign source_col = page.metafields.custom.rh_collection.value
  elsif page.handle != blank
    assign auto_handle = 'rh-' | append: page.handle
    assign auto_col = collections[auto_handle]
    if auto_col != blank and auto_col.id != blank
      assign source_col = auto_col
    endif
  endif
-%}

<style>
  .sos-arch{ --fg:#030303; --bg:#fbf9f6; --card:#ffffff; --muted:#6b6258; --line:#ece8e3; }
  .sos-arch{ background:var(--bg); color:var(--fg); }
  .sos-arch__wrap{ max-width:1240px; margin:0 auto; padding:0 24px; }
  .sos-arch__block{ padding:48px 0; }
  .sos-arch__block--tight{ padding:24px 0; }

  /* HERO */
  .sos-arch-hero{ text-align:center; padding:80px 0 56px; }
  .sos-arch-hero__overline{ font-size:12px; letter-spacing:.18em; text-transform:uppercase; color:var(--muted); margin:0 0 14px; }
  .sos-arch-hero__title{ font-family:var(--g-font-2, 'EB Garamond', Georgia, serif); font-weight:400; font-size:clamp(48px, 7vw, 88px); line-height:1.02; letter-spacing:-.01em; margin:0; }
  .sos-arch-hero__title em{ font-style:italic; }
  .sos-arch-hero__subtitle{ font-size:16px; color:var(--muted); margin:18px auto 0; max-width:640px; line-height:1.55; }
  .sos-arch-hero__cta{ display:inline-flex; align-items:center; justify-content:center; height:46px; padding:0 28px; margin-top:28px; border:1px solid var(--fg); border-radius:4px; font-size:13px; letter-spacing:.06em; text-transform:uppercase; text-decoration:none; color:var(--fg); background:transparent; transition:opacity .2s; }
  .sos-arch-hero__cta:hover{ opacity:.7; }

  /* IMAGE ROW */
  .sos-arch-row{ display:grid; grid-template-columns:repeat(3, 1fr); gap:18px; align-items:start; }
  .sos-arch-row--2{ grid-template-columns:repeat(2, 1fr); }
  .sos-arch-row--1{ grid-template-columns:1fr; max-width:840px; margin:0 auto; }
  .sos-arch-row__cell{ overflow:hidden; border-radius:8px; background:var(--line); }
  .sos-arch-row__cell img{ width:100%; height:auto; object-fit:cover; display:block; }
  /* Per-image vertical rhythm: each column carries its own aspect via the image. */
  .sos-arch-row__cell--portrait{ aspect-ratio:4/5; }
  .sos-arch-row__cell--portrait img{ height:100%; }
  .sos-arch-row__cell--landscape{ aspect-ratio:5/4; }
  .sos-arch-row__cell--landscape img{ height:100%; }
  .sos-arch-row__cell--square{ aspect-ratio:1/1; }
  .sos-arch-row__cell--square img{ height:100%; }

  /* TEXT */
  .sos-arch-text{ max-width:760px; margin:0 auto; text-align:center; }
  .sos-arch-text--left{ text-align:left; }
  .sos-arch-text__quote{ font-family:var(--g-font-2, 'EB Garamond', Georgia, serif); font-style:italic; font-size:clamp(20px, 2.4vw, 26px); line-height:1.5; color:var(--fg); margin:0; }
  .sos-arch-text__body{ font-size:16px; line-height:1.7; color:var(--fg); }
  .sos-arch-text__body p{ margin:0 0 1em; }

  /* READ MORE / ACCORDION */
  .sos-arch-readmore{ text-align:center; }
  .sos-arch-readmore details{ max-width:760px; margin:0 auto; }
  .sos-arch-readmore summary{ display:inline-block; padding:12px 32px; border:1px solid var(--fg); border-radius:4px; cursor:pointer; font-size:13px; letter-spacing:.06em; text-transform:uppercase; list-style:none; transition:opacity .2s; }
  .sos-arch-readmore summary::-webkit-details-marker{ display:none; }
  .sos-arch-readmore summary:hover{ opacity:.7; }
  .sos-arch-readmore details[open] summary{ margin-bottom:24px; }
  .sos-arch-readmore__body{ font-size:16px; line-height:1.7; color:var(--fg); text-align:left; }
  .sos-arch-readmore__body p{ margin:0 0 1em; }

  /* PRODUCTS */
  .sos-arch-products{ padding:64px 0; }
  .sos-arch-products__head{ text-align:center; margin:0 0 36px; }
  .sos-arch-products__title{ font-family:var(--g-font-2, 'EB Garamond', Georgia, serif); font-weight:400; font-size:clamp(28px, 3.5vw, 40px); margin:0 0 8px; }
  .sos-arch-products__title em{ font-style:italic; }
  .sos-arch-products__sub{ font-size:14px; color:var(--muted); margin:0; }
  .sos-arch-products__grid{ display:grid; grid-template-columns:repeat(3, 1fr); gap:24px 20px; }
  .sos-arch-products__empty{ padding:40px; text-align:center; color:var(--muted); border:1px dashed var(--line); border-radius:8px; }

  /* SHARE */
  .sos-arch-share{ background:linear-gradient(135deg,#c2895b 0%,#a86a3f 100%); color:#fff; border-radius:8px; padding:40px; text-align:center; }
  .sos-arch-share__title{ font-family:var(--g-font-2, 'EB Garamond', Georgia, serif); font-weight:400; font-size:clamp(24px, 3vw, 32px); margin:0 0 14px; }
  .sos-arch-share__body{ font-size:15px; line-height:1.55; margin:0 0 24px; opacity:.95; }
  .sos-arch-share__btn{ display:inline-flex; height:44px; padding:0 28px; align-items:center; background:#fff; color:var(--fg); border-radius:4px; font-size:13px; letter-spacing:.06em; text-transform:uppercase; text-decoration:none; }

  /* SPACER */
  .sos-arch-spacer{ height:32px; }

  @media (max-width: 760px){
    .sos-arch-hero{ padding:56px 0 40px; }
    .sos-arch__block{ padding:32px 0; }
    .sos-arch-row{ grid-template-columns:repeat(2, 1fr); gap:10px; }
    .sos-arch-row--1{ grid-template-columns:1fr; }
    .sos-arch-products__grid{ grid-template-columns:repeat(2, 1fr); gap:12px; }
    .sos-arch-products{ padding:48px 0; }
    .sos-arch-share{ padding:28px 20px; }
  }
</style>

<section class="sos-arch" data-section-id="{{ section.id }}" data-archetype="{{ archetype_name | handleize }}">
  <div class="sos-arch__wrap">
    {%- for block in section.blocks -%}
      {%- case block.type -%}

        {%- when 'hero' -%}
          {%- capture hero_style -%}
            {%- if block.settings.max_width != blank -%}max-width:{{ block.settings.max_width }}px;margin-left:auto;margin-right:auto;{%- endif -%}
            {%- if block.settings.background_color != blank -%}background-color:{{ block.settings.background_color }};{%- endif -%}
            {%- if block.settings.padding_top != blank -%}padding-top:{{ block.settings.padding_top }}px;{%- endif -%}
            {%- if block.settings.padding_bottom != blank -%}padding-bottom:{{ block.settings.padding_bottom }}px;{%- endif -%}
          {%- endcapture -%}
          {%- capture title_style -%}
            {%- if block.settings.title_size != blank -%}font-size:{{ block.settings.title_size }}px;{%- endif -%}
            {%- if block.settings.title_color != blank -%}color:{{ block.settings.title_color }};{%- endif -%}
          {%- endcapture -%}
          {%- capture subtitle_style -%}
            {%- if block.settings.subtitle_size != blank -%}font-size:{{ block.settings.subtitle_size }}px;{%- endif -%}
            {%- if block.settings.subtitle_color != blank -%}color:{{ block.settings.subtitle_color }};{%- endif -%}
          {%- endcapture -%}
          <div class="sos-arch-hero" style="{{ hero_style | strip }}" {{ block.shopify_attributes }}>
            {%- if block.settings.overline != blank -%}
              <p class="sos-arch-hero__overline">{{ block.settings.overline }}</p>
            {%- endif -%}
            <h1 class="sos-arch-hero__title" style="{{ title_style | strip }}">
              {%- if block.settings.italicize_name -%}
                <em>{{ block.settings.archetype_name | default: archetype_name }}</em>
              {%- else -%}
                {{ block.settings.archetype_name | default: archetype_name }}
              {%- endif -%}
            </h1>
            {%- if block.settings.subtitle != blank -%}
              <p class="sos-arch-hero__subtitle" style="{{ subtitle_style | strip }}">{{ block.settings.subtitle }}</p>
            {%- endif -%}
            {%- if block.settings.cta_text != blank and block.settings.cta_url != blank -%}
              <a href="{{ block.settings.cta_url }}" class="sos-arch-hero__cta">{{ block.settings.cta_text }}</a>
            {%- endif -%}
          </div>

        {%- when 'image_row' -%}
          {%- comment -%} columns is a string ("1"/"2"/"3"); cast to int for comparison {%- endcomment -%}
          {%- assign cols = block.settings.columns | default: '3' | plus: 0 -%}
          {%- assign aspect = block.settings.aspect | default: 'natural' -%}
          {%- assign cell_class = 'sos-arch-row__cell' -%}
          {%- if aspect != 'natural' -%}
            {%- assign cell_class = cell_class | append: ' sos-arch-row__cell--' | append: aspect -%}
          {%- endif -%}
          <div class="sos-arch__block" {{ block.shopify_attributes }}>
            <div class="sos-arch-row sos-arch-row--{{ cols }}">
              {%- if block.settings.image_1 != blank -%}
                <div class="{{ cell_class }}"><img src="{{ block.settings.image_1 | image_url: width: 800 }}" alt="{{ block.settings.image_1.alt | default: archetype_name | escape }}" loading="lazy" width="{{ block.settings.image_1.width }}" height="{{ block.settings.image_1.height }}"></div>
              {%- endif -%}
              {%- if cols >= 2 and block.settings.image_2 != blank -%}
                <div class="{{ cell_class }}"><img src="{{ block.settings.image_2 | image_url: width: 800 }}" alt="{{ block.settings.image_2.alt | default: archetype_name | escape }}" loading="lazy" width="{{ block.settings.image_2.width }}" height="{{ block.settings.image_2.height }}"></div>
              {%- endif -%}
              {%- if cols >= 3 and block.settings.image_3 != blank -%}
                <div class="{{ cell_class }}"><img src="{{ block.settings.image_3 | image_url: width: 800 }}" alt="{{ block.settings.image_3.alt | default: archetype_name | escape }}" loading="lazy" width="{{ block.settings.image_3.width }}" height="{{ block.settings.image_3.height }}"></div>
              {%- endif -%}
            </div>
          </div>

        {%- when 'text' -%}
          {%- capture text_wrap_style -%}
            {%- if block.settings.max_width != blank -%}max-width:{{ block.settings.max_width }}px;{%- endif -%}
            {%- if block.settings.background_color != blank -%}background-color:{{ block.settings.background_color }};{%- endif -%}
            {%- if block.settings.padding_top != blank -%}padding-top:{{ block.settings.padding_top }}px;{%- endif -%}
            {%- if block.settings.padding_bottom != blank -%}padding-bottom:{{ block.settings.padding_bottom }}px;{%- endif -%}
          {%- endcapture -%}
          {%- capture text_style -%}
            {%- if block.settings.font_size != blank -%}font-size:{{ block.settings.font_size }}px;{%- endif -%}
            {%- if block.settings.line_height != blank -%}line-height:{{ block.settings.line_height }};{%- endif -%}
            {%- if block.settings.color != blank -%}color:{{ block.settings.color }};{%- endif -%}
            {%- if block.settings.font_weight != blank -%}font-weight:{{ block.settings.font_weight }};{%- endif -%}
          {%- endcapture -%}
          <div class="sos-arch__block" {{ block.shopify_attributes }}>
            <div class="sos-arch-text sos-arch-text--{{ block.settings.align | default: 'center' }}" style="{{ text_wrap_style | strip }}">
              {%- if block.settings.style == 'quote' -%}
                {%- comment -%} Strip the rich-text wrapper <p> so the quote class applies cleanly. {%- endcomment -%}
                {%- assign quote_text = block.settings.content | replace: '<p>', '' | replace: '</p>', '' -%}
                <p class="sos-arch-text__quote" style="{{ text_style | strip }}">{{ quote_text }}</p>
              {%- else -%}
                <div class="sos-arch-text__body rte" style="{{ text_style | strip }}">{{ block.settings.content }}</div>
              {%- endif -%}
            </div>
          </div>

        {%- when 'read_more' -%}
          <div class="sos-arch__block sos-arch__block--tight" {{ block.shopify_attributes }}>
            <div class="sos-arch-readmore">
              <details>
                <summary>{{ block.settings.label | default: 'Read more' }}</summary>
                <div class="sos-arch-readmore__body rte">{{ block.settings.content }}</div>
              </details>
            </div>
          </div>

        {%- when 'products' -%}
          <div class="sos-arch-products" {{ block.shopify_attributes }}>
            <div class="sos-arch-products__head">
              <h2 class="sos-arch-products__title">
                {%- if block.settings.title contains '|' -%}
                  {%- assign t_parts = block.settings.title | split: '|' -%}
                  {%- if t_parts.size == 3 -%}
                    {{ t_parts[0] | strip }} <em>{{ t_parts[1] | strip }}</em> {{ t_parts[2] | strip }}
                  {%- else -%}
                    {{ t_parts[0] | strip }}<em>{{ t_parts[1] | strip | prepend: ' ' }}</em>
                  {%- endif -%}
                {%- elsif block.settings.title != blank -%}
                  {{ block.settings.title }}
                {%- else -%}
                  The <em>{{ archetype_name }}'s</em> companions
                {%- endif -%}
              </h2>
              {%- if block.settings.subtitle != blank -%}
                <p class="sos-arch-products__sub">{{ block.settings.subtitle }}</p>
              {%- endif -%}
            </div>
            {%- assign limit = block.settings.product_limit | default: 6 -%}
            {%- if source_col != blank and source_col.products.size > 0 -%}
              <div class="sos-arch-products__grid">
                {%- for product in source_col.products limit: limit -%}
                  {%- render 'product-card', product: product, collection: source_col -%}
                {%- endfor -%}
              </div>
            {%- else -%}
              <div class="sos-arch-products__empty">
                Create a collection named "RH - {{ archetype_name }}" (handle: <code>rh-{{ page.handle }}</code>) to auto-bind products, or set a page metafield.
              </div>
            {%- endif -%}
          </div>

        {%- when 'share' -%}
          <div class="sos-arch__block" {{ block.shopify_attributes }}>
            <div class="sos-arch-share">
              <h3 class="sos-arch-share__title">{{ block.settings.title | default: 'Share your scent archetype with your friends!' }}</h3>
              {%- if block.settings.body != blank -%}
                <p class="sos-arch-share__body">{{ block.settings.body }}</p>
              {%- endif -%}
              {%- if block.settings.button_text != blank and block.settings.button_url != blank -%}
                <a href="{{ block.settings.button_url }}" class="sos-arch-share__btn">{{ block.settings.button_text }}</a>
              {%- endif -%}
            </div>
          </div>

        {%- when 'spacer' -%}
          <div class="sos-arch-spacer" style="height:{{ block.settings.height | default: 32 }}px;" {{ block.shopify_attributes }}></div>

      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Archetype Result",
  "tag": "section",
  "class": "section-sos-archetype",
  "settings": [],
  "blocks": [
    {
      "type": "hero",
      "name": "Hero",
      "limit": 2,
      "settings": [
        { "type": "text", "id": "overline", "label": "Overline" },
        { "type": "text", "id": "archetype_name", "label": "Archetype name", "info": "Leave blank to use the page title (recommended)." },
        { "type": "checkbox", "id": "italicize_name", "label": "Italicize the name", "default": true },
        { "type": "text", "id": "subtitle", "label": "Subtitle" },
        { "type": "text", "id": "cta_text", "label": "Optional button text" },
        { "type": "url", "id": "cta_url", "label": "Optional button URL" },
        { "type": "header", "content": "Hero styling" },
        { "type": "range", "id": "title_size", "label": "Title font size", "min": 32, "max": 140, "step": 2, "unit": "px", "default": 72 },
        { "type": "color", "id": "title_color", "label": "Title color" },
        { "type": "range", "id": "subtitle_size", "label": "Subtitle font size", "min": 12, "max": 32, "step": 1, "unit": "px", "default": 16 },
        { "type": "color", "id": "subtitle_color", "label": "Subtitle color" },
        { "type": "range", "id": "max_width", "label": "Hero max width", "min": 480, "max": 1400, "step": 20, "unit": "px", "default": 880 },
        { "type": "color", "id": "background_color", "label": "Background color" },
        { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },
        { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 56 }
      ]
    },
    {
      "type": "image_row",
      "name": "Image row",
      "settings": [
        {
          "type": "select",
          "id": "columns",
          "label": "Columns",
          "options": [
            { "value": "1", "label": "1 image" },
            { "value": "2", "label": "2 images" },
            { "value": "3", "label": "3 images" }
          ],
          "default": "3"
        },
        {
          "type": "select",
          "id": "aspect",
          "label": "Image shape",
          "info": "Pick one shape per row to vary visual rhythm between rows.",
          "options": [
            { "value": "natural",   "label": "Natural (use image's own aspect ratio)" },
            { "value": "square",    "label": "Square (1:1)" },
            { "value": "portrait",  "label": "Portrait (4:5)" },
            { "value": "landscape", "label": "Landscape (5:4)" }
          ],
          "default": "square"
        },
        { "type": "image_picker", "id": "image_1", "label": "Image 1" },
        { "type": "image_picker", "id": "image_2", "label": "Image 2" },
        { "type": "image_picker", "id": "image_3", "label": "Image 3" }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "select",
          "id": "style",
          "label": "Style",
          "options": [
            { "value": "body", "label": "Body paragraph" },
            { "value": "quote", "label": "Italic quote" }
          ],
          "default": "body"
        },
        {
          "type": "select",
          "id": "align",
          "label": "Alignment",
          "options": [
            { "value": "center", "label": "Center" },
            { "value": "left", "label": "Left" }
          ],
          "default": "center"
        },
        { "type": "richtext", "id": "content", "label": "Content" },
        { "type": "header", "content": "Typography" },
        { "type": "range", "id": "font_size", "label": "Font size", "min": 12, "max": 48, "step": 1, "unit": "px", "default": 18 },
        { "type": "range", "id": "line_height", "label": "Line height", "min": 1, "max": 2.5, "step": 0.05, "default": 1.55 },
        { "type": "color", "id": "color", "label": "Text color" },
        {
          "type": "select",
          "id": "font_weight",
          "label": "Font weight",
          "options": [
            { "value": "",     "label": "Default" },
            { "value": "300",  "label": "Light (300)" },
            { "value": "400",  "label": "Regular (400)" },
            { "value": "500",  "label": "Medium (500)" },
            { "value": "600",  "label": "Semibold (600)" },
            { "value": "700",  "label": "Bold (700)" }
          ],
          "default": ""
        },
        { "type": "header", "content": "Layout" },
        { "type": "range", "id": "max_width", "label": "Max width", "min": 320, "max": 1200, "step": 20, "unit": "px", "default": 760 },
        { "type": "color", "id": "background_color", "label": "Background color" },
        { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48 },
        { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 48 }
      ]
    },
    {
      "type": "read_more",
      "name": "Read more (accordion)",
      "limit": 2,
      "settings": [
        { "type": "text", "id": "label", "label": "Button label", "default": "Read more" },
        { "type": "richtext", "id": "content", "label": "Hidden content" }
      ]
    },
    {
      "type": "products",
      "name": "Product grid",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "title", "label": "Heading", "info": "Use a pipe character to split italic, e.g. 'The Mineralist | companions'." },
        { "type": "text", "id": "subtitle", "label": "Subheading" },
        { "type": "range", "id": "product_limit", "label": "Number of products", "min": 2, "max": 12, "step": 1, "default": 6 }
      ]
    },
    {
      "type": "share",
      "name": "Share section",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "title", "label": "Heading", "default": "Share your scent archetype with your friends!" },
        { "type": "text", "id": "body", "label": "Body text" },
        { "type": "text", "id": "button_text", "label": "Button text", "default": "Share now" },
        { "type": "url", "id": "button_url", "label": "Button URL" }
      ]
    },
    {
      "type": "spacer",
      "name": "Spacer",
      "settings": [
        { "type": "range", "id": "height", "label": "Height", "min": 8, "max": 120, "step": 4, "default": 32, "unit": "px" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Archetype Result",
      "blocks": [
        { "type": "hero", "settings": { "overline": "Your archetype", "italicize_name": true } },
        { "type": "products", "settings": { "title": "Recommended for you" } },
        { "type": "share" }
      ]
    }
  ]
}
{% endschema %}
