{{ 'product-slider.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign collection_handle = section.settings.collection
  assign products_to_show = section.settings.products_to_show
  assign section_width = section.settings.section_width
  assign custom_width = section.settings.custom_width
  assign heading_text = section.settings.heading_text
  assign default_view = section.settings.default_view
  assign products_per_row = section.settings.products_per_row
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign show_price = section.settings.show_price
  assign show_vendor = section.settings.show_vendor
  assign show_badges = section.settings.show_badges
  assign show_category_pills = section.settings.show_category_pills
  assign show_wishlist = section.settings.show_wishlist
  assign card_border_radius = section.settings.card_border_radius
  assign bg_color = section.settings.bg_color
  assign text_color = section.settings.text_color
  assign card_bg_color = section.settings.card_bg_color
  assign badge_color = section.settings.badge_color
  assign pill_bg_color = section.settings.pill_bg_color
  assign pill_text_color = section.settings.pill_text_color
  assign grid_per_page = section.settings.grid_per_page | default: 15
  assign nav_btn_size      = section.settings.nav_btn_size
  assign nav_btn_radius    = section.settings.nav_btn_radius
  assign nav_icon_size     = section.settings.nav_icon_size
  assign nav_stroke_width  = section.settings.nav_stroke_width
  assign nav_color         = section.settings.nav_color
  assign nav_bg_color      = section.settings.nav_bg_color
  assign nav_border_color  = section.settings.nav_border_color
  assign nav_border_width  = section.settings.nav_border_width
-%}

{%- capture width_style -%}
  {%- case section_width -%}
    {%- when 'full' -%}max-width:100%;
    {%- when 'container' -%}max-width:var(--page-width,1200px);
    {%- when 'boxed' -%}max-width:1000px;
    {%- when 'custom' -%}max-width:{{ custom_width }}px;
  {%- endcase -%}
{%- endcapture -%}

{%- if collection_handle != blank -%}
  {%- assign collection_obj = collections[collection_handle] -%}
{%- elsif collection != blank -%}
  {%- assign collection_obj = collection -%}
{%- endif -%}

<div
  id="ProductSlider-{{ section.id }}"
  class="product-slider"
  data-view="{{ default_view }}"
  style="
    --ps-padding-top: {{ padding_top }}px;
    --ps-padding-bottom: {{ padding_bottom }}px;
    --ps-margin-top: {{ margin_top }}px;
    --ps-margin-bottom: {{ margin_bottom }}px;
    --ps-card-radius: {{ card_border_radius }}px;
    --ps-bg: {{ bg_color }};
    --ps-text: {{ text_color }};
    --ps-card-bg: {{ card_bg_color }};
    --ps-badge-color: {{ badge_color }};
    --ps-pill-bg: {{ pill_bg_color }};
    --ps-pill-text: {{ pill_text_color }};
    --ps-products-per-row: {{ products_per_row }};
    --ps-nav-size: {{ nav_btn_size }}px;
    --ps-nav-radius: {{ nav_btn_radius }}%;
    --ps-nav-bg: {{ nav_bg_color }};
    --ps-nav-border-color: {{ nav_border_color }};
    --ps-nav-border-width: {{ nav_border_width }}px;
  "
  data-grid-per-page="{{ grid_per_page }}"
>
  <div class="product-slider__inner" style="{{ width_style }}">

    {%- if section.settings.show_header -%}
      <div class="product-slider__header">
        {%- if heading_text != blank -%}
          <h2 class="product-slider__title">{{ heading_text }}</h2>
        {%- endif -%}

        {%- if default_view == 'slider' -%}
          <div class="product-slider__nav" data-slider-nav>
            <button class="product-slider__nav-btn" type="button" data-dir="prev" aria-label="Previous products" disabled>
              <svg width="{{ nav_icon_size }}" height="{{ nav_icon_size }}" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="display:block;overflow:visible">
                <polyline points="15 18 9 12 15 6" fill="none" stroke="{{ nav_color }}" stroke-width="{{ nav_stroke_width }}" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <button class="product-slider__nav-btn" type="button" data-dir="next" aria-label="Next products">
              <svg width="{{ nav_icon_size }}" height="{{ nav_icon_size }}" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="display:block;overflow:visible">
                <polyline points="9 18 15 12 9 6" fill="none" stroke="{{ nav_color }}" stroke-width="{{ nav_stroke_width }}" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="product-slider__track-wrapper">
      <div class="product-slider__track product-slider__track--{{ default_view }}" data-slider-track>
        {%- if collection_obj and collection_obj.products.size > 0 -%}
          {%- for product in collection_obj.products limit: products_to_show -%}
            <div class="product-slider__card" data-hidden="false">
              <a href="{{ product.url }}" class="product-slider__card-link">
                <div class="product-slider__card-image">

                  {%- if show_category_pills and product.collections.size > 0 -%}
                    {%- assign brand_str = ',meo-fuscioni,meo-fuscuini,sarah-baker,thomas-de-monaco,vapor-mundum,frontpage,' -%}
                    {%- assign sos_archetype_handles = ',the-seducer,the-cosmopolitan,the-romantic,the-indulger,the-luxury-hedonist,the-nostalgic,the-mineralist,the-smooth-operator,the-maximalist,' -%}
                    <div class="product-slider__pills">
                      {%- for col in product.collections -%}
                        {%- assign sos_h_prefix = col.handle | slice: 0, 3 -%}
                        {%- assign sos_h_needle = ',' | append: col.handle | append: ',' -%}
                        {%- if sos_h_prefix == 'rh-' -%}{%- continue -%}{%- endif -%}
                        {%- if sos_archetype_handles contains sos_h_needle -%}{%- continue -%}{%- endif -%}
                        {%- unless brand_str contains col.handle -%}
                          <span class="product-slider__pill mood-tag--{{ col.title | handle }}" role="link" tabindex="0" onclick="event.preventDefault();event.stopPropagation();window.location.href='{{ col.url }}';">{{ col.title }}</span>
                        {%- endunless -%}
                      {%- endfor -%}
                    </div>
                  {%- endif -%}

                  {%- if show_badges -%}
                    {%- assign badge_html = '' -%}
                    {%- for tag in product.tags -%}
                      {%- assign tag_lower = tag | downcase -%}
                      {%- if tag contains 'badge:' -%}
                        {%- assign badge_text = tag | split: 'badge:' | last -%}
                        {%- capture badge_item -%}<span class="product-slider__badge product-slider__badge--{{ badge_text | handleize }}">{{ badge_text }}</span>{%- endcapture -%}
                        {%- assign badge_html = badge_html | append: badge_item -%}
                      {%- elsif tag_lower == 'new' or tag_lower == 'hot' or tag_lower == 'community favorite' -%}
                        {%- capture badge_item -%}<span class="product-slider__badge product-slider__badge--{{ tag | handleize }}">{{ tag }}</span>{%- endcapture -%}
                        {%- assign badge_html = badge_html | append: badge_item -%}
                      {%- endif -%}
                    {%- endfor -%}
                    {%- if badge_html != '' -%}
                      <div class="product-slider__badges">{{ badge_html }}</div>
                    {%- endif -%}
                  {%- endif -%}

                  {%- if show_wishlist -%}
                    <button class="product-slider__wishlist" type="button" data-product-id="{{ product.id }}" aria-label="Add {{ product.title | escape }} to wishlist" onclick="event.preventDefault();event.stopPropagation();var id=this.dataset.productId;this.classList.toggle('is-active');var w=JSON.parse(localStorage.getItem('ps-wishlist')||'{}');if(this.classList.contains('is-active')){w[id]=true}else{delete w[id]}localStorage.setItem('ps-wishlist',JSON.stringify(w));">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                      </svg>
                    </button>
                  {%- endif -%}

                  {%- if product.featured_image -%}
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      srcset="{{ product.featured_image | image_url: width: 300 }} 300w, {{ product.featured_image | image_url: width: 450 }} 450w, {{ product.featured_image | image_url: width: 600 }} 600w"
                      sizes="(max-width: 749px) 50vw, (max-width: 999px) 33vw, {{ 100 | divided_by: products_per_row }}vw"
                      alt="{{ product.title | escape }}"
                      width="{{ product.featured_image.width }}"
                      height="{{ product.featured_image.height }}"
                      loading="lazy"
                    >
                  {%- else -%}
                    <div class="product-slider__card-placeholder">{{ 'product-1' | placeholder_svg_tag }}</div>
                  {%- endif -%}
                </div>

                <div class="product-slider__card-info">
                  <h3 class="product-slider__product-title">{{ product.title }}</h3>
                  {%- if show_vendor and product.vendor != blank -%}
                    <p class="product-slider__vendor">{{ product.vendor }}</p>
                  {%- endif -%}
                  {%- if show_price -%}
                    <p class="product-slider__price">
                      {%- if product.compare_at_price > product.price -%}
                        <span class="product-slider__price--compare">{{ product.compare_at_price | money }}</span>
                      {%- endif -%}
                      <span class="{% if product.compare_at_price > product.price %}product-slider__price--sale{% endif %}">{{ product.price | money }}</span>
                    </p>
                  {%- endif -%}
                </div>
              </a>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..6) -%}
            <div class="product-slider__card" data-hidden="false">
              <div class="product-slider__card-link">
                <div class="product-slider__card-image">
                  <div class="product-slider__pills">
                    <span class="product-slider__pill">Category 1</span>
                    {%- if forloop.first -%}<span class="product-slider__pill">Category 2</span>{%- endif -%}
                  </div>
                  {%- if forloop.first -%}
                    <div class="product-slider__badges">
                      <span class="product-slider__badge product-slider__badge--community-favorite">Community Favorite</span>
                    </div>
                  {%- endif -%}
                  <button class="product-slider__wishlist" type="button" aria-label="Add to wishlist">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                    </svg>
                  </button>
                  <div class="product-slider__card-placeholder">{{ 'product-1' | placeholder_svg_tag }}</div>
                </div>
                <div class="product-slider__card-info">
                  <h3 class="product-slider__product-title">Scent Name</h3>
                  <p class="product-slider__vendor">Brand Name</p>
                  <p class="product-slider__price">€777</p>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>

    {%- if default_view == 'grid' -%}
      <nav class="product-slider__pagination" data-pagination aria-label="Product pages"></nav>
    {%- endif -%}

  </div>
</div>

<script>
  (function () {
    var section = document.getElementById('ProductSlider-{{ section.id }}');
    if (!section) return;

    var track = section.querySelector('[data-slider-track]');
    var cards = section.querySelectorAll('.product-slider__card');
    var prevBtn = section.querySelector('[data-dir="prev"]');
    var nextBtn = section.querySelector('[data-dir="next"]');
    var productsPerRow = parseInt('{{ products_per_row }}', 10) || 3;
    var currentView = '{{ default_view }}';
    var currentIndex = 0;
    var gap = 16;

    function getVisibleCards() {
      var visible = [];
      cards.forEach(function (card) {
        if (card.getAttribute('data-hidden') !== 'true') visible.push(card);
      });
      return visible;
    }

    function getPerRow() {
      if (window.innerWidth <= 749) return 1;
      if (window.innerWidth <= 999) return 2;
      return productsPerRow;
    }

    function slideTo(index) {
      if (currentView !== 'slider' || !track) return;
      var visible = getVisibleCards();
      var perRow = getPerRow();
      var maxIdx = Math.max(0, visible.length - perRow);
      currentIndex = Math.max(0, Math.min(index, maxIdx));
      if (visible.length === 0) { track.style.transform = 'translateX(0)'; return; }
      var cardWidth = visible[0].offsetWidth;
      var offset = currentIndex * (cardWidth + gap);
      track.style.transform = 'translateX(-' + offset + 'px)';
      if (prevBtn) prevBtn.disabled = currentIndex === 0;
      if (nextBtn) nextBtn.disabled = currentIndex >= maxIdx;
    }

    if (prevBtn) prevBtn.addEventListener('click', function () { slideTo(currentIndex - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function () { slideTo(currentIndex + 1); });

    var touchStartX = 0, touchDelta = 0;
    if (track) {
      track.addEventListener('touchstart', function (e) { touchStartX = e.touches[0].clientX; }, { passive: true });
      track.addEventListener('touchmove', function (e) { touchDelta = e.touches[0].clientX - touchStartX; }, { passive: true });
      track.addEventListener('touchend', function () {
        if (Math.abs(touchDelta) > 50) slideTo(touchDelta < 0 ? currentIndex + 1 : currentIndex - 1);
        touchDelta = 0;
      });
    }

    var resizeTimer;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function () { if (currentView === 'slider') slideTo(currentIndex); }, 150);
    });

    var pagination = section.querySelector('[data-pagination]');
    var gridPerPage = parseInt(section.getAttribute('data-grid-per-page'), 10) || 15;
    var currentPage = 1;

    function renderPagination() {
      if (!pagination || currentView !== 'grid') return;
      var totalCards = cards.length;
      var totalPages = Math.ceil(totalCards / gridPerPage);
      if (totalPages <= 1) { pagination.innerHTML = ''; showPage(1); return; }
      var html = '';
      html += '<button class="product-slider__page-btn product-slider__page-btn--prev' + (currentPage === 1 ? ' product-slider__page-btn--disabled' : '') + '" data-page="prev" aria-label="Previous page">&#9666; Prev</button>';
      for (var p = 1; p <= totalPages; p++) {
        html += '<button class="product-slider__page-btn' + (p === currentPage ? ' product-slider__page-btn--active' : '') + '" data-page="' + p + '">' + (p < 10 ? '0' + p : p) + '</button>';
      }
      html += '<button class="product-slider__page-btn' + (currentPage === totalPages ? ' product-slider__page-btn--disabled' : '') + '" data-page="next" aria-label="Next page">&#8250;</button>';
      pagination.innerHTML = html;
      pagination.querySelectorAll('.product-slider__page-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var val = btn.getAttribute('data-page');
          if (val === 'prev') { if (currentPage > 1) currentPage--; }
          else if (val === 'next') { if (currentPage < totalPages) currentPage++; }
          else { currentPage = parseInt(val, 10); }
          showPage(currentPage);
          renderPagination();
          section.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });
    }

    function showPage(page) {
      var start = (page - 1) * gridPerPage;
      var end = start + gridPerPage;
      cards.forEach(function (card, i) {
        card.style.display = (currentView === 'grid') ? (i >= start && i < end ? '' : 'none') : '';
      });
    }

    var wishlist = JSON.parse(localStorage.getItem('ps-wishlist') || '{}');
    section.querySelectorAll('.product-slider__wishlist[data-product-id]').forEach(function (btn) {
      if (wishlist[btn.dataset.productId]) btn.classList.add('is-active');
    });

    if (currentView === 'slider') { slideTo(0); }
    else if (currentView === 'grid') { showPage(1); renderPagination(); }
  })();
</script>

{% schema %}
{
  "name": "Product Slider",
  "tag": "section",
  "class": "product-slider-section",
  "settings": [
    { "type": "header", "content": "Product Source" },
    { "type": "collection", "id": "collection", "label": "Select collection" },
    { "type": "range", "id": "products_to_show", "label": "Maximum products to show", "min": 3, "max": 50, "step": 1, "default": 50 },
    { "type": "header", "content": "Section Layout" },
    { "type": "text", "id": "heading_text", "label": "Section heading", "default": "Spring essentials" },
    { "type": "checkbox", "id": "show_header", "label": "Show header bar", "default": true },
    { "type": "select", "id": "default_view", "label": "Default view mode", "options": [{ "value": "slider", "label": "Slider" }, { "value": "grid", "label": "Grid" }], "default": "slider" },
    { "type": "range", "id": "products_per_row", "label": "Products per row", "min": 2, "max": 5, "step": 1, "default": 3 },
    { "type": "range", "id": "grid_per_page", "label": "Products per page (grid)", "min": 6, "max": 30, "step": 3, "default": 15 },
    { "type": "select", "id": "section_width", "label": "Section width", "options": [{ "value": "full", "label": "Full Width" }, { "value": "container", "label": "Container" }, { "value": "boxed", "label": "Boxed" }, { "value": "custom", "label": "Custom" }], "default": "container" },
    { "type": "range", "id": "custom_width", "label": "Custom width (px)", "min": 600, "max": 1600, "step": 20, "unit": "px", "default": 1200 },
    { "type": "header", "content": "Navigation Buttons" },
    { "type": "color", "id": "nav_color", "label": "Icon color", "default": "#2C2722" },
    { "type": "color", "id": "nav_bg_color", "label": "Button background", "default": "#FFFFFF" },
    { "type": "color", "id": "nav_border_color", "label": "Button border color", "default": "#2C2722" },
    { "type": "range", "id": "nav_border_width", "label": "Button border width (px)", "min": 0, "max": 4, "step": 1, "default": 1 },
    { "type": "range", "id": "nav_btn_size", "label": "Button size (px)", "min": 28, "max": 64, "step": 2, "default": 40 },
    { "type": "range", "id": "nav_btn_radius", "label": "Button radius (0=square, 50=circle)", "min": 0, "max": 50, "step": 2, "unit": "%", "default": 50 },
    { "type": "range", "id": "nav_icon_size", "label": "Icon size (px)", "min": 8, "max": 32, "step": 1, "default": 16 },
    { "type": "range", "id": "nav_stroke_width", "label": "Icon stroke width", "min": 1, "max": 5, "step": 1, "default": 2 },
    { "type": "header", "content": "Card Settings" },
    { "type": "checkbox", "id": "show_price", "label": "Show price", "default": true },
    { "type": "checkbox", "id": "show_vendor", "label": "Show brand / vendor", "default": true },
    { "type": "checkbox", "id": "show_badges", "label": "Show badges (New, Hot, etc.)", "default": true },
    { "type": "checkbox", "id": "show_category_pills", "label": "Show category pills on cards", "default": true },
    { "type": "checkbox", "id": "show_wishlist", "label": "Show wishlist heart icon", "default": true },
    { "type": "range", "id": "card_border_radius", "label": "Card border radius", "min": 0, "max": 30, "step": 2, "unit": "px", "default": 16 },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Section background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#1a1a1a" },
    { "type": "color", "id": "card_bg_color", "label": "Card background", "default": "#f5f0eb" },
    { "type": "color", "id": "badge_color", "label": "Badge accent color", "default": "#2a9d8f" },
    { "type": "color", "id": "pill_bg_color", "label": "Category pill background", "default": "#ffffff" },
    { "type": "color", "id": "pill_text_color", "label": "Category pill text", "default": "#1a1a1a" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "margin_top", "label": "Margin top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_bottom", "label": "Margin bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 0 }
  ],
  "presets": [
    {
      "name": "Product Slider",
      "settings": {
        "heading_text": "Spring essentials",
        "section_width": "container",
        "products_to_show": 12,
        "products_per_row": 3
      }
    }
  ]
}
{% endschema %}