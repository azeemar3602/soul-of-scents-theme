{% doc %}
  @prompt
    {%- capture width_style -%}
      {%- case section_width -%}
        {%- when 'full' -%}
          max-width: 100%;
        {%- when 'container' -%}
          max-width: var(--page-width, 1200px);
        {%- when 'boxed' -%}
          max-width: 1000px;
        {%- when 'custom' -%}
          max-width: {{ custom_width }}px;
      {%- endcase -%}
    {%- endcapture -%}
    
    make this section with code ref section width, and like image , also add carousel option with nagination and grid for 3 images per row or only for 3 images, dont show all placeholders only added images for images, image aspect ratio not working
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign section_width = block.settings.section_width
  assign custom_width = block.settings.custom_width
  assign layout_type = block.settings.layout_type
  assign images_per_row = block.settings.images_per_row
  
  assign images = ''
  for i in (1..9)
    assign image_key = 'image_' | append: i
    assign image = block.settings[image_key]
    if image
      if images == ''
        assign images = image
      else
        assign images = images | append: ',' | append: image
      endif
    endif
  endfor
  
  assign image_array = images | split: ','
  assign total_images = image_array.size
%}

{% capture width_style %}
  {% case section_width %}
    {% when 'full' %}
      max-width: 100%;
    {% when 'container' %}
      max-width: var(--page-width, 1200px);
    {% when 'boxed' %}
      max-width: 1000px;
    {% when 'custom' %}
      max-width: {{ custom_width }}px;
  {% endcase %}
{% endcapture %}

{% style %}
  .ai-image-gallery-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-image-gallery-container-{{ ai_gen_id }} {
    {{ width_style }}
    margin: 0 auto;
    padding: 0 {{ block.settings.container_padding }}px;
  }

  .ai-image-gallery-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ images_per_row }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-image-gallery-carousel-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-image-gallery-carousel-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.grid_gap }}px;
    transition: transform 0.5s ease;
  }

  .ai-image-gallery-carousel-slide-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ images_per_row | minus: 1 }} * {{ block.settings.grid_gap }}px)) / {{ images_per_row }});
    min-width: 0;
  }

  .ai-image-gallery-item-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-image-gallery-item-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .ai-image-gallery-item-{{ ai_gen_id }}:hover img {
    transform: scale(1.05);
  }

  .ai-image-gallery-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-gallery-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-image-gallery-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-gallery-nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: {{ block.settings.navigation_spacing }}px;
  }

  .ai-image-gallery-nav-button-{{ ai_gen_id }} {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: {{ block.settings.nav_button_bg }};
    color: {{ block.settings.nav_button_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-image-gallery-nav-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_bg }};
    color: {{ block.settings.nav_button_hover_color }};
  }

  .ai-image-gallery-nav-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-image-gallery-dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-image-gallery-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
  }

  .ai-image-gallery-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  @media screen and (max-width: 768px) {
    .ai-image-gallery-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.images_per_row_mobile }}, 1fr);
    }

    .ai-image-gallery-carousel-slide-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.images_per_row_mobile | minus: 1 }} * {{ block.settings.grid_gap }}px)) / {{ block.settings.images_per_row_mobile }});
    }
  }
{% endstyle %}

<image-gallery-{{ ai_gen_id }}
  class="ai-image-gallery-{{ ai_gen_id }}"
  data-layout="{{ layout_type }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-gallery-container-{{ ai_gen_id }}">
    {% if total_images == 0 %}
      <div class="ai-image-gallery-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-image-gallery-empty-state-{{ ai_gen_id }}">
          Add images to your gallery
        </div>
      </div>
    {% else %}
      {% if layout_type == 'grid' %}
        <div class="ai-image-gallery-grid-{{ ai_gen_id }}">
          {% for i in (1..9) %}
            {% liquid
              assign image_key = 'image_' | append: i
              assign image = block.settings[image_key]
            %}
            {% if image %}
              <div class="ai-image-gallery-item-{{ ai_gen_id }}">
                <img
                  src="{{ image | image_url: width: 800 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                >
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% else %}
        <div class="ai-image-gallery-carousel-{{ ai_gen_id }}">
          <div class="ai-image-gallery-carousel-track-{{ ai_gen_id }}">
            {% for i in (1..9) %}
              {% liquid
                assign image_key = 'image_' | append: i
                assign image = block.settings[image_key]
              %}
              {% if image %}
                <div class="ai-image-gallery-carousel-slide-{{ ai_gen_id }}">
                  <div class="ai-image-gallery-item-{{ ai_gen_id }}">
                    <img
                      src="{{ image | image_url: width: 800 }}"
                      alt="{{ image.alt | escape }}"
                      loading="lazy"
                      width="{{ image.width }}"
                      height="{{ image.height }}"
                    >
                  </div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>

        {% if block.settings.show_navigation %}
          <div class="ai-image-gallery-nav-{{ ai_gen_id }}">
            <button
              class="ai-image-gallery-nav-button-{{ ai_gen_id }} ai-image-gallery-prev-{{ ai_gen_id }}"
              aria-label="Previous"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="15 18 9 12 15 6"></polyline>
              </svg>
            </button>

            {% if block.settings.show_dots %}
              <div class="ai-image-gallery-dots-{{ ai_gen_id }}"></div>
            {% endif %}

            <button
              class="ai-image-gallery-nav-button-{{ ai_gen_id }} ai-image-gallery-next-{{ ai_gen_id }}"
              aria-label="Next"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </button>
          </div>
        {% endif %}
      {% endif %}
    {% endif %}
  </div>
</image-gallery-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageGallery{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.imagesPerRow = {{ images_per_row }};
        this.imagesPerRowMobile = {{ block.settings.images_per_row_mobile }};
      }

      connectedCallback() {
        const layout = this.dataset.layout;
        
        if (layout === 'carousel') {
          this.initCarousel();
        }
      }

      initCarousel() {
        this.track = this.querySelector('.ai-image-gallery-carousel-track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-image-gallery-carousel-slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-image-gallery-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-image-gallery-next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-image-gallery-dots-{{ ai_gen_id }}');

        if (!this.track || this.slides.length === 0) return;

        this.updateImagesPerRow();
        this.totalSlides = this.slides.length;
        this.maxIndex = Math.max(0, this.totalSlides - this.currentImagesPerRow);

        if (this.dotsContainer) {
          this.createDots();
        }

        if (this.prevButton && this.nextButton) {
          this.prevButton.addEventListener('click', () => this.prev());
          this.nextButton.addEventListener('click', () => this.next());
        }

        window.addEventListener('resize', () => {
          this.updateImagesPerRow();
          this.updateCarousel();
        });

        this.updateCarousel();
      }

      updateImagesPerRow() {
        this.currentImagesPerRow = window.innerWidth <= 768 
          ? this.imagesPerRowMobile 
          : this.imagesPerRow;
        this.maxIndex = Math.max(0, this.totalSlides - this.currentImagesPerRow);
      }

      createDots() {
        this.dotsContainer.innerHTML = '';
        const numDots = Math.ceil(this.totalSlides / this.currentImagesPerRow);
        
        for (let i = 0; i < numDots; i++) {
          const dot = document.createElement('button');
          dot.classList.add('ai-image-gallery-dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          dot.addEventListener('click', () => {
            this.currentIndex = i * this.currentImagesPerRow;
            if (this.currentIndex > this.maxIndex) {
              this.currentIndex = this.maxIndex;
            }
            this.updateCarousel();
          });
          this.dotsContainer.appendChild(dot);
        }
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex = Math.max(0, this.currentIndex - this.currentImagesPerRow);
          this.updateCarousel();
        }
      }

      next() {
        if (this.currentIndex < this.maxIndex) {
          this.currentIndex = Math.min(this.maxIndex, this.currentIndex + this.currentImagesPerRow);
          this.updateCarousel();
        }
      }

      updateCarousel() {
        const slideWidth = this.slides[0].offsetWidth;
        const gap = {{ block.settings.grid_gap }};
        const offset = -(this.currentIndex * (slideWidth + gap));
        
        this.track.style.transform = `translateX(${offset}px)`;

        if (this.prevButton && this.nextButton) {
          this.prevButton.disabled = this.currentIndex === 0;
          this.nextButton.disabled = this.currentIndex >= this.maxIndex;
        }

        if (this.dotsContainer) {
          const dots = this.dotsContainer.querySelectorAll('.ai-image-gallery-dot-{{ ai_gen_id }}');
          const activeDotIndex = Math.floor(this.currentIndex / this.currentImagesPerRow);
          
          dots.forEach((dot, index) => {
            if (index === activeDotIndex) {
              dot.classList.add('active');
            } else {
              dot.classList.remove('active');
            }
          });
        }
      }
    }

    customElements.define('image-gallery-{{ ai_gen_id }}', ImageGallery{{ ai_gen_id }});
  })();
</script>

