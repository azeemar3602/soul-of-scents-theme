{% doc %}
  @prompt
    {% schema %}
    {
      "name": "Blog Carousel",
      "settings": [
        {
          "type": "text",
          "id": "section_title",
          "label": "Section Title",
          "default": "Discover your next obsession"
        },
        {
          "type": "checkbox",
          "id": "enable_carousel",
          "label": "Enable Carousel",
          "default": true
        }
      ],
      "presets": [
        {
          "name": "Blog Carousel"
        }
      ]
    }
    {% endschema %}
    
    <section class="blog-section">
      <div class="container">
        <div class="section-header">
          <h2>{{ section.settings.section_title }}</h2>
          {% if section.settings.enable_carousel %}
            <div class="carousel-nav">
              <button class="prev">‹</button>
              <button class="next">›</button>
            </div>
          {% endif %}
        </div>
        <div class="blog-carousel">
          {% assign blogs = blogs | default: all_blogs %}
          {% for article in blogs['news'].articles limit:4 %}
            <article class="blog-card" itemscope itemtype="https://schema.org/BlogPosting">
              <a href="{{ article.url }}" class="card-link">
                <div class="blog-image">
                  <img src="{{ article.featured_image | img_url: '800x' }}" 
                       alt="{{ article.title | escape }}" 
                       loading="lazy" 
                       itemprop="image" />
                </div>
                <div class="blog-content">
                  <p class="blog-tag">{{ article.tags | first }}</p>
                  <h3 itemprop="headline">{{ article.title }}</h3>
                  <div class="blog-meta">
                    <span class="publish-date">{{ article.published_at | date: "%b %d, %Y" }}</span>
                    <span class="reading-time" data-words="{{ article.content | strip_html | number_of_words }}">0 min read</span>
                  </div>
                </div>
              </a>
            </article>
          {% endfor %}
        </div>
      </div>
    </section>
    
    <style>
    .blog-section {
      padding: 80px 0;
      background-color: #fdfaf6;
    }
    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 40px;
    }
    .section-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: 2.5rem;
      color: #3a3a3a;
    }
    .carousel-nav button {
      font-size: 2rem;
      background: none;
      border: none;
      cursor: pointer;
      color: #8b8b8b;
      transition: 0.3s ease;
    }
    .carousel-nav button:hover {
      color: #000;
    }
    .blog-carousel {
      display: flex;
      gap: 24px;
      overflow-x: auto;
      scroll-behavior: smooth;
    }
    .blog-card {
      flex: 0 0 25%;
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 6px 20px rgba(0,0,0,0.08);
      overflow: hidden;
      transition: transform 0.3s ease;
    }
    .blog-card:hover {
      transform: translateY(-6px) scale(1.02);
    }
    .blog-image img {
      width: 100%;
      border-radius: 16px 16px 0 0;
    }
    .blog-content {
      padding: 16px;
      font-family: 'Manrope', sans-serif;
      color: #555;
    }
    .blog-tag {
      font-size: 0.85rem;
      color: #999;
      text-transform: uppercase;
      margin-bottom: 8px;
    }
    .blog-content h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      margin: 0 0 12px;
      line-height: 1.3;
      max-height: 3rem;
      overflow: hidden;
    }
    .blog-meta {
      font-size: 0.8rem;
      display: flex;
      gap: 12px;
      color: #888;
    }
    @media (max-width: 768px){
      .blog-card { flex: 0 0 100%; }
      .carousel-nav { display: none; }
    }
    </style>
    
    <script>
    document.addEventListener('DOMContentLoaded', function(){
      // Dynamic reading time calculation
      document.querySelectorAll('.reading-time').forEach(function(el){
        const words = parseInt(el.dataset.words);
        const minutes = Math.ceil(words / 200);
        el.textContent = minutes + ' min read';
      });
    
      // Carousel navigation
      const prevBtn = document.querySelector('.carousel-nav .prev');
      const nextBtn = document.querySelector('.carousel-nav .next');
      const carousel = document.querySelector('.blog-carousel');
    
      if(prevBtn && nextBtn && carousel){
        prevBtn.addEventListener('click', () => { carousel.scrollBy({ left: -carousel.offsetWidth, behavior: 'smooth' }); });
        nextBtn.addEventListener('click', () => { carousel.scrollBy({ left: carousel.offsetWidth, behavior: 'smooth' }); });
      }
    });
    </script>
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-blog-carousel-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-blog-carousel-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 {{ block.settings.gutter }}px;
  }

  .ai-blog-carousel-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-blog-carousel-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-blog-carousel-nav-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
  }

  .ai-blog-carousel-nav-btn-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border: 1px solid {{ block.settings.nav_border_color }};
    background: {{ block.settings.nav_bg_color }};
    color: {{ block.settings.nav_color }};
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    transition: all 0.3s ease;
  }

  .ai-blog-carousel-nav-btn-{{ ai_gen_id }}:hover {
    background: {{ block.settings.nav_hover_bg }};
    color: {{ block.settings.nav_hover_color }};
    border-color: {{ block.settings.nav_hover_bg }};
  }

  .ai-blog-carousel-wrapper-{{ ai_gen_id }} {
    overflow: hidden;
    position: relative;
  }

  .ai-blog-carousel-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    transition: transform 0.5s ease;
  }

  .ai-blog-carousel-card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - {{ block.settings.card_gap | times: 3 }}px) / 4);
    background: {{ block.settings.card_bg }};
    border-radius: {{ block.settings.card_radius }}px;
    overflow: hidden;
    box-shadow: {{ block.settings.card_shadow }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-blog-carousel-card-{{ ai_gen_id }}:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
  }

  .ai-blog-carousel-card-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .ai-blog-carousel-image-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    position: relative;
  }

  .ai-blog-carousel-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-blog-carousel-card-{{ ai_gen_id }}:hover .ai-blog-carousel-image-{{ ai_gen_id }} img {
    transform: scale(1.05);
  }

  .ai-blog-carousel-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-blog-carousel-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-blog-carousel-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-blog-carousel-tag-{{ ai_gen_id }} {
    font-size: {{ block.settings.tag_size }}px;
    color: {{ block.settings.tag_color }};
    text-transform: uppercase;
    margin-bottom: 8px;
    display: block;
    letter-spacing: 0.5px;
  }

  .ai-blog-carousel-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 12px;
    line-height: 1.4;
    font-weight: 600;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-blog-carousel-meta-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    font-size: {{ block.settings.meta_size }}px;
    color: {{ block.settings.meta_color }};
  }

  .ai-blog-carousel-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
  }

  .ai-blog-carousel-empty-{{ ai_gen_id }} p {
    margin: 16px 0 0;
    font-size: 14px;
  }

  @media (max-width: 1024px) {
    .ai-blog-carousel-card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.card_gap | times: 2 }}px) / 3);
    }
  }

  @media (max-width: 768px) {
    .ai-blog-carousel-card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.card_gap }}px) / 2);
    }

    .ai-blog-carousel-nav-{{ ai_gen_id }} {
      display: none;
    }

    .ai-blog-carousel-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }
  }

  @media (max-width: 480px) {
    .ai-blog-carousel-card-{{ ai_gen_id }} {
      flex: 0 0 100%;
    }
  }
{% endstyle %}

<blog-carousel-{{ ai_gen_id }} class="ai-blog-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-blog-carousel-container-{{ ai_gen_id }}">
    <div class="ai-blog-carousel-header-{{ ai_gen_id }}">
      {% if block.settings.section_title != blank %}
        <h2 class="ai-blog-carousel-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
      {% endif %}
      {% if block.settings.enable_carousel %}
        <div class="ai-blog-carousel-nav-{{ ai_gen_id }}">
          <button class="ai-blog-carousel-nav-btn-{{ ai_gen_id }} ai-blog-carousel-prev-{{ ai_gen_id }}" aria-label="Previous">
            ‹
          </button>
          <button class="ai-blog-carousel-nav-btn-{{ ai_gen_id }} ai-blog-carousel-next-{{ ai_gen_id }}" aria-label="Next">
            ›
          </button>
        </div>
      {% endif %}
    </div>

    {% if block.settings.blog != blank %}
      <div class="ai-blog-carousel-wrapper-{{ ai_gen_id }}">
        <div class="ai-blog-carousel-track-{{ ai_gen_id }}">
          {% for article in block.settings.blog.articles limit: block.settings.articles_limit %}
            <article class="ai-blog-carousel-card-{{ ai_gen_id }}" itemscope itemtype="https://schema.org/BlogPosting">
              <a href="{{ article.url }}" class="ai-blog-carousel-card-link-{{ ai_gen_id }}">
                <div class="ai-blog-carousel-image-{{ ai_gen_id }}">
                  {% if article.image %}
                    <img
                      src="{{ article.image | image_url: width: 800 }}"
                      alt="{{ article.title | escape }}"
                      loading="lazy"
                      width="800"
                      height="600"
                      itemprop="image"
                    >
                  {% else %}
                    <div class="ai-blog-carousel-placeholder-{{ ai_gen_id }}">
                      {{ 'image' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
                <div class="ai-blog-carousel-content-{{ ai_gen_id }}">
                  {% if article.tags.size > 0 %}
                    <span class="ai-blog-carousel-tag-{{ ai_gen_id }}">{{ article.tags | first }}</span>
                  {% endif %}
                  <h3 class="ai-blog-carousel-card-title-{{ ai_gen_id }}" itemprop="headline">{{ article.title }}</h3>
                  <div class="ai-blog-carousel-meta-{{ ai_gen_id }}">
                    <span class="ai-blog-carousel-date-{{ ai_gen_id }}">{{ article.published_at | date: '%b %d, %Y' }}</span>
                    <span class="ai-blog-carousel-reading-{{ ai_gen_id }}" data-words="{{ article.content | strip_html | number_of_words }}">
                      {{ article.content | strip_html | number_of_words | divided_by: 200 | at_least: 1 }} min read
                    </span>
                  </div>
                </div>
              </a>
            </article>
          {% endfor %}
        </div>
      </div>
    {% else %}
      <div class="ai-blog-carousel-empty-{{ ai_gen_id }}">
        {{ 'blog-apparel-1' | placeholder_svg_tag }}
        <p>Next, select a blog to display articles</p>
      </div>
    {% endif %}
  </div>
</blog-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class BlogCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.itemsPerView = 4;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-blog-carousel-track-{{ ai_gen_id }}');
        this.cards = this.querySelectorAll('.ai-blog-carousel-card-{{ ai_gen_id }}');
        this.prevBtn = this.querySelector('.ai-blog-carousel-prev-{{ ai_gen_id }}');
        this.nextBtn = this.querySelector('.ai-blog-carousel-next-{{ ai_gen_id }}');

        if (!this.track || this.cards.length === 0) return;

        this.updateItemsPerView();
        this.setupEventListeners();
        window.addEventListener('resize', () => this.updateItemsPerView());
      }

      updateItemsPerView() {
        const width = window.innerWidth;
        if (width <= 480) {
          this.itemsPerView = 1;
        } else if (width <= 768) {
          this.itemsPerView = 2;
        } else if (width <= 1024) {
          this.itemsPerView = 3;
        } else {
          this.itemsPerView = 4;
        }
        this.updateCarousel();
      }

      setupEventListeners() {
        if (this.prevBtn) {
          this.prevBtn.addEventListener('click', () => this.prev());
        }
        if (this.nextBtn) {
          this.nextBtn.addEventListener('click', () => this.next());
        }
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateCarousel();
        }
      }

      next() {
        const maxIndex = Math.max(0, this.cards.length - this.itemsPerView);
        if (this.currentIndex < maxIndex) {
          this.currentIndex++;
          this.updateCarousel();
        }
      }

      updateCarousel() {
        if (!this.track) return;
        const cardWidth = this.cards[0].offsetWidth;
        const gap = {{ block.settings.card_gap }};
        const offset = -(this.currentIndex * (cardWidth + gap));
        this.track.style.transform = `translateX(${offset}px)`;
      }
    }

    customElements.define('blog-carousel-{{ ai_gen_id }}', BlogCarousel{{ ai_gen_id }});
  })();
</script>

