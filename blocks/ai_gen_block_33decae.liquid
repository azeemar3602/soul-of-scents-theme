{% doc %}
  @prompt
    Create a Shopify Liquid section for a minimalist editorial-style content block similar to the provided design.
    
    Layout
    
    Section should be center aligned.
    
    Large white space for a clean luxury aesthetic.
    
    Content order:
    
    Heading
    
    Circular image
    
    Description text
    
    CTA button
    
    Section Width Control
    
    Implement width control using this logic:
    
    {%- capture width_style -%}
      {%- case section_width -%}
        {%- when 'full' -%}
          max-width: 100%;
        {%- when 'container' -%}
          max-width: var(--page-width, 1200px);
        {%- when 'boxed' -%}
          max-width: 1000px;
        {%- when 'custom' -%}
          max-width: {{ custom_width }}px;
      {%- endcase -%}
    {%- endcapture -%}
    
    
    The section container should apply this width dynamically.
    
    Heading
    
    Editable main heading
    
    Example layout:
    
    Line 1: Discover your
    
    Line 2: scent-archetype (italic style)
    
    Controls in schema:
    
    Heading text
    
    Font size
    
    Font weight
    
    Alignment
    
    Image
    
    Uploadable Shopify image picker
    
    Displayed in perfect circular shape
    
    Center aligned
    
    Image settings:
    
    Image size slider
    
    Border radius automatically 50%
    
    Optional shadow toggle
    
    Description Text
    
    Editable rich text field
    
    Max width around 600–700px
    
    Center aligned
    
    Typography settings:
    
    Font size
    
    Line height
    
    Color
    
    Button
    
    Editable Button label
    
    Editable Button link
    
    Center aligned
    
    Button style settings:
    
    Background color
    
    Text color
    
    Border radius
    
    Padding
    
    Example:
    Take the Quiz
    
    Spacing Controls
    
    Add full Shopify section controls:
    
    Padding (inner spacing)
    
    Padding Top
    
    Padding Bottom
    
    Padding Left
    
    Padding Right
    
    Margin (outer spacing)
    
    Margin Top
    
    Margin Bottom
    
    Margin Left
    
    Margin Right
    
    Additional Controls
    
    Background color picker
    
    Optional background image
    
    Responsive support for mobile
    
    Image scales properly on smaller screens
    
    Styling Requirements
    
    Minimalist editorial design
    
    Clean typography
    
    Large spacing between elements
    
    Circle image centered
    
    Button centered
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{%- capture width_style -%}
  {%- case block.settings.section_width -%}
    {%- when 'full' -%}
      max-width: 100%;
    {%- when 'container' -%}
      max-width: var(--page-width, 1200px);
    {%- when 'boxed' -%}
      max-width: 1000px;
    {%- when 'custom' -%}
      max-width: {{ block.settings.custom_width }}px;
  {%- endcase -%}
{%- endcapture -%}

{% style %}
  .ai-editorial-block-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    {% if block.settings.background_image %}
      background-image: url('{{ block.settings.background_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
    {% endif %}
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    margin-left: {{ block.settings.margin_left }}px;
    margin-right: {{ block.settings.margin_right }}px;
  }

  .ai-editorial-container-{{ ai_gen_id }} {
    {{ width_style }}
    margin: 0 auto;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
  }

  .ai-editorial-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: {{ block.settings.element_spacing }}px;
  }

  .ai-editorial-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    text-align: {{ block.settings.heading_alignment }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-editorial-heading-{{ ai_gen_id }} em {
    font-style: italic;
  }

  .ai-editorial-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    border-radius: 50%;
    overflow: hidden;
    {% if block.settings.image_shadow %}
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
    {% endif %}
  }

  .ai-editorial-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-editorial-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-editorial-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-editorial-description-{{ ai_gen_id }} {
    max-width: {{ block.settings.description_max_width }}px;
    font-size: {{ block.settings.description_size }}px;
    line-height: {{ block.settings.description_line_height }};
    color: {{ block.settings.description_color }};
    margin: 0;
  }

  .ai-editorial-description-{{ ai_gen_id }} p {
    margin: 0 0 1em;
  }

  .ai-editorial-description-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-editorial-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-editorial-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-editorial-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-editorial-image-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.image_size | times: 0.7 }}px;
      height: {{ block.settings.image_size | times: 0.7 }}px;
    }

    .ai-editorial-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-editorial-content-{{ ai_gen_id }} {
      gap: {{ block.settings.element_spacing | times: 0.7 }}px;
    }

    .ai-editorial-container-{{ ai_gen_id }} {
      padding-left: 20px;
      padding-right: 20px;
    }
  }
{% endstyle %}

<div class="ai-editorial-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-editorial-container-{{ ai_gen_id }}">
    <div class="ai-editorial-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-editorial-heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      <div class="ai-editorial-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 800 }}"
            alt="{{ block.settings.image.alt | escape }}"
            class="ai-editorial-image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.image_size }}"
            height="{{ block.settings.image_size }}"
          >
        {% else %}
          <div class="ai-editorial-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      {% if block.settings.description != blank %}
        <div class="ai-editorial-description-{{ ai_gen_id }}">
          {{ block.settings.description }}
        </div>
      {% endif %}

      {% if block.settings.button_label != blank %}
        <a
          href="{{ block.settings.button_link }}"
          class="ai-editorial-button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Editorial content",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Discover your<br><em>scent-archetype</em></p>"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Font size",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 54
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Font weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#222222"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_size",
      "label": "Size",
      "min": 100,
      "max": 600,
      "step": 20,
      "unit": "px",
      "default": 300
    },
    {
      "type": "checkbox",
      "id": "image_shadow",
      "label": "Enable shadow",
      "default": true
    },
    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Text",
      "default": "<p>Explore our curated collection and find the perfect fragrance that speaks to your unique personality and style.</p>"
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "description_line_height",
      "label": "Line height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.6
    },
    {
      "type": "range",
      "id": "description_max_width",
      "label": "Max width",
      "min": 400,
      "max": 900,
      "step": 50,
      "unit": "px",
      "default": 650
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Label",
      "default": "Take the Quiz"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Link"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "button_font_weight",
      "label": "Font weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "label": "Padding vertical",
      "min": 8,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "label": "Padding horizontal",
      "min": 16,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Background color",
      "default": "#bb5237"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Hover background color",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "full", "label": "Full width" },
        { "value": "container", "label": "Container" },
        { "value": "boxed", "label": "Boxed" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "container"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "Custom width",
      "min": 600,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1000,
      "info": "Only applies when 'Custom' width is selected"
    },
    {
      "type": "range",
      "id": "element_spacing",
      "label": "Spacing between elements",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "Left",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "Right",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Margin"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_left",
      "label": "Left",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_right",
      "label": "Right",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Editorial content"
    }
  ]
}
{% endschema %}