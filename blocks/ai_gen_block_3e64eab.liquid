{% doc %}
  @prompt
    "Create a split-screen vertical tabs section with a minimalist aesthetic.
    
    Functionality: > On the left, a large image with rounded corners. On the right, four headings: 'Authenticity', 'Artisanal Excellence', 'Fearless Expression', and 'Emotional Connection'. When a heading is hovered/clicked, it turns bold and black (others stay light gray/italic), reveals a description paragraph below it, and updates the left-side image.
    
    Layout & Spacing Controls: > Include Shopify schema settings for:
    
    Container Toggle: Switch between 'Full Width' and 'Fixed/Boxed Width'.
    
    Padding: Independent sliders for Top, Bottom, Left, and Right inner padding.
    
    Margin: Independent sliders for Top, Bottom, Left, and Right outer margins.
    
    Rounded Corners: A slider to adjust the border-radius of the main image."
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-split-tabs-{{ ai_gen_id }} {
    display: block;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    margin-left: {{ block.settings.margin_left }}px;
    margin-right: {{ block.settings.margin_right }}px;
  }

  .ai-split-tabs-container-{{ ai_gen_id }} {
    {% if block.settings.container_width == 'boxed' %}
      max-width: 1200px;
      margin-left: auto;
      margin-right: auto;
    {% endif %}
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-split-tabs-wrapper-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .ai-split-tabs-image-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-split-tabs-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .ai-split-tabs-image-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-split-tabs-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-split-tabs-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-split-tabs-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .ai-split-tabs-tab-{{ ai_gen_id }} {
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-split-tabs-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.inactive_color }};
    font-weight: 300;
    font-style: italic;
    margin: 0 0 12px 0;
    transition: all 0.3s ease;
  }

  .ai-split-tabs-tab-{{ ai_gen_id }}.active .ai-split-tabs-heading-{{ ai_gen_id }},
  .ai-split-tabs-tab-{{ ai_gen_id }}:hover .ai-split-tabs-heading-{{ ai_gen_id }} {
    color: {{ block.settings.active_color }};
    font-weight: 700;
    font-style: normal;
  }

  .ai-split-tabs-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: all 0.4s ease;
    margin: 0;
  }

  .ai-split-tabs-tab-{{ ai_gen_id }}.active .ai-split-tabs-description-{{ ai_gen_id }} {
    max-height: 500px;
    opacity: 1;
  }

  @media screen and (max-width: 768px) {
    .ai-split-tabs-wrapper-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-split-tabs-image-container-{{ ai_gen_id }} {
      aspect-ratio: 16 / 9;
    }

    .ai-split-tabs-content-{{ ai_gen_id }} {
      gap: 24px;
    }
  }
{% endstyle %}

<split-tabs-{{ ai_gen_id }} class="ai-split-tabs-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-split-tabs-container-{{ ai_gen_id }}">
    <div class="ai-split-tabs-wrapper-{{ ai_gen_id }}">
      <div class="ai-split-tabs-image-container-{{ ai_gen_id }}">
        {% if block.settings.tab_1_image %}
          <img
            src="{{ block.settings.tab_1_image | image_url: width: 1200 }}"
            alt="{{ block.settings.tab_1_heading | escape }}"
            class="ai-split-tabs-image-{{ ai_gen_id }} active"
            data-tab="1"
            loading="lazy"
            width="{{ block.settings.tab_1_image.width }}"
            height="{{ block.settings.tab_1_image.height }}"
          >
        {% else %}
          <div class="ai-split-tabs-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if block.settings.tab_2_image %}
          <img
            src="{{ block.settings.tab_2_image | image_url: width: 1200 }}"
            alt="{{ block.settings.tab_2_heading | escape }}"
            class="ai-split-tabs-image-{{ ai_gen_id }}"
            data-tab="2"
            loading="lazy"
            width="{{ block.settings.tab_2_image.width }}"
            height="{{ block.settings.tab_2_image.height }}"
          >
        {% endif %}

        {% if block.settings.tab_3_image %}
          <img
            src="{{ block.settings.tab_3_image | image_url: width: 1200 }}"
            alt="{{ block.settings.tab_3_heading | escape }}"
            class="ai-split-tabs-image-{{ ai_gen_id }}"
            data-tab="3"
            loading="lazy"
            width="{{ block.settings.tab_3_image.width }}"
            height="{{ block.settings.tab_3_image.height }}"
          >
        {% endif %}

        {% if block.settings.tab_4_image %}
          <img
            src="{{ block.settings.tab_4_image | image_url: width: 1200 }}"
            alt="{{ block.settings.tab_4_heading | escape }}"
            class="ai-split-tabs-image-{{ ai_gen_id }}"
            data-tab="4"
            loading="lazy"
            width="{{ block.settings.tab_4_image.width }}"
            height="{{ block.settings.tab_4_image.height }}"
          >
        {% endif %}
      </div>

      <div class="ai-split-tabs-content-{{ ai_gen_id }}">
        <div class="ai-split-tabs-tab-{{ ai_gen_id }} active" data-tab="1">
          <h3 class="ai-split-tabs-heading-{{ ai_gen_id }}">{{ block.settings.tab_1_heading }}</h3>
          <p class="ai-split-tabs-description-{{ ai_gen_id }}">{{ block.settings.tab_1_description }}</p>
        </div>

        <div class="ai-split-tabs-tab-{{ ai_gen_id }}" data-tab="2">
          <h3 class="ai-split-tabs-heading-{{ ai_gen_id }}">{{ block.settings.tab_2_heading }}</h3>
          <p class="ai-split-tabs-description-{{ ai_gen_id }}">{{ block.settings.tab_2_description }}</p>
        </div>

        <div class="ai-split-tabs-tab-{{ ai_gen_id }}" data-tab="3">
          <h3 class="ai-split-tabs-heading-{{ ai_gen_id }}">{{ block.settings.tab_3_heading }}</h3>
          <p class="ai-split-tabs-description-{{ ai_gen_id }}">{{ block.settings.tab_3_description }}</p>
        </div>

        <div class="ai-split-tabs-tab-{{ ai_gen_id }}" data-tab="4">
          <h3 class="ai-split-tabs-heading-{{ ai_gen_id }}">{{ block.settings.tab_4_heading }}</h3>
          <p class="ai-split-tabs-description-{{ ai_gen_id }}">{{ block.settings.tab_4_description }}</p>
        </div>
      </div>
    </div>
  </div>
</split-tabs-{{ ai_gen_id }}>

<script>
  (function() {
    class SplitTabs{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.tabs = this.querySelectorAll('.ai-split-tabs-tab-{{ ai_gen_id }}');
        this.images = this.querySelectorAll('.ai-split-tabs-image-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.tabs.forEach((tab) => {
          tab.addEventListener('mouseenter', () => this.switchTab(tab));
          tab.addEventListener('click', () => this.switchTab(tab));
        });
      }

      switchTab(activeTab) {
        const tabId = activeTab.getAttribute('data-tab');

        this.tabs.forEach((tab) => {
          tab.classList.remove('active');
        });

        this.images.forEach((image) => {
          image.classList.remove('active');
        });

        activeTab.classList.add('active');

        const activeImage = this.querySelector(`.ai-split-tabs-image-{{ ai_gen_id }}[data-tab="${tabId}"]`);
        if (activeImage) {
          activeImage.classList.add('active');
        }
      }
    }

    customElements.define('split-tabs-{{ ai_gen_id }}', SplitTabs{{ ai_gen_id }});
  })();
</script>

