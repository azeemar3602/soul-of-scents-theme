{% doc %}
  @prompt
    i need same section.
    
    {%- capture width_style -%}
      {%- case section_width -%}
        {%- when 'full' -%}
          max-width: 100%;
        {%- when 'container' -%}
          max-width: var(--page-width, 1200px);
        {%- when 'boxed' -%}
          max-width: 1000px;
        {%- when 'custom' -%}
          max-width: {{ custom_width }}px;
      {%- endcase -%}
    {%- endcapture -%}
    
    follow section width, also font editable, image radius in circle etc same like image
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% capture width_style %}
  {% case block.settings.section_width %}
    {% when 'full' %}
      max-width: 100%;
    {% when 'container' %}
      max-width: var(--page-width, 1200px);
    {% when 'boxed' %}
      max-width: 1000px;
    {% when 'custom' %}
      max-width: {{ block.settings.custom_width }}px;
  {% endcase %}
{% endcapture %}

{% style %}
  .ai-content-block-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-content-block__container-{{ ai_gen_id }} {
    {{ width_style }}
    margin: 0 auto;
    display: flex;
    flex-direction: {{ block.settings.layout }};
    align-items: {{ block.settings.vertical_alignment }};
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-content-block__image-wrapper-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: {{ block.settings.image_width }}%;
  }

  .ai-content-block__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {% if block.settings.image_shape == 'circle' %}50%{% else %}{{ block.settings.image_border_radius }}px{% endif %};
    object-fit: cover;
    {% if block.settings.image_shape == 'circle' %}
      aspect-ratio: 1 / 1;
    {% endif %}
  }

  .ai-content-block__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {% if block.settings.image_shape == 'circle' %}50%{% else %}{{ block.settings.image_border_radius }}px{% endif %};
    {% if block.settings.image_shape == 'circle' %}
      aspect-ratio: 1 / 1;
    {% endif %}
  }

  .ai-content-block__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-content-block__content-{{ ai_gen_id }} {
    flex: 1;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-content-block__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: {{ block.settings.heading_line_height }};
    text-transform: {{ block.settings.heading_transform }};
    letter-spacing: {{ block.settings.heading_letter_spacing }}em;
  }

  .ai-content-block__text-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.text_color }};
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-weight: {{ block.settings.text_font.weight }};
    font-size: {{ block.settings.text_size }}px;
    line-height: {{ block.settings.text_line_height }};
  }

  .ai-content-block__button-{{ ai_gen_id }} {
    display: inline-block;
    margin-top: {{ block.settings.button_spacing }}px;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-size: {{ block.settings.button_font_size }}px;
    text-transform: {{ block.settings.button_text_transform }};
    letter-spacing: {{ block.settings.button_letter_spacing }}em;
    transition: all 0.3s ease;
  }

  .ai-content-block__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover_color }};
    color: {{ block.settings.button_text_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-content-block__container-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-content-block__image-wrapper-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-content-block__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-content-block__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-content-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-content-block__container-{{ ai_gen_id }}">
    {% if block.settings.show_image %}
      <div class="ai-content-block__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 1000 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-content-block__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-content-block__image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-content-block__content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-content-block__heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-content-block__text-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </div>
      {% endif %}

      {% if block.settings.button_text != blank and block.settings.button_link != blank %}
        <a
          href="{{ block.settings.button_link }}"
          class="ai-content-block__button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

