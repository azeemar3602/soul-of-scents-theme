{% doc %}
  @prompt
    Create a dual image/product slider section with a setting to toggle between one row or two rows layout. The slider should maintain smooth horizontal scrolling in both modes. Include settings for: row layout toggle (1 row or 2 rows), scroll speed, image height, image width/ratio, image gap, border radius, and padding/margin controls. When set to 2 rows, products should stack vertically while maintaining the horizontal carousel scroll. Use clean, minimal design with light gray image backgrounds and rounded corners.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-dual-slider-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    margin-left: {{ block.settings.margin_left }}px;
    margin-right: {{ block.settings.margin_right }}px;
    overflow: hidden;
  }

  .ai-dual-slider-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-dual-slider-wrapper-{{ ai_gen_id }} {
    display: flex;
    {% if block.settings.row_layout == '2_rows' %}
      flex-direction: column;
      gap: {{ block.settings.image_gap }}px;
    {% else %}
      flex-direction: row;
      gap: {{ block.settings.image_gap }}px;
    {% endif %}
    overflow-x: auto;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-dual-slider-wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-dual-slider-row-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.image_gap }}px;
    {% if block.settings.row_layout == '2_rows' %}
      min-width: 100%;
    {% endif %}
  }

  .ai-dual-slider-item-{{ ai_gen_id }} {
    flex-shrink: 0;
    position: relative;
    background-color: #F5F5F5;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    {% if block.settings.image_ratio == 'square' %}
      aspect-ratio: 1 / 1;
    {% elsif block.settings.image_ratio == 'portrait' %}
      aspect-ratio: 3 / 4;
    {% elsif block.settings.image_ratio == 'landscape' %}
      aspect-ratio: 4 / 3;
    {% elsif block.settings.image_ratio == 'wide' %}
      aspect-ratio: 16 / 9;
    {% endif %}
    {% if block.settings.row_layout == '1_row' %}
      width: {{ block.settings.image_width }}px;
    {% else %}
      width: {{ block.settings.image_width }}px;
    {% endif %}
  }

  .ai-dual-slider-item-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-dual-slider-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #F5F5F5;
  }

  .ai-dual-slider-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .ai-dual-slider-item-{{ ai_gen_id }} {
      width: {{ block.settings.image_width | times: 0.7 }}px;
    }
  }
{% endstyle %}

<dual-slider-{{ ai_gen_id }}
  class="ai-dual-slider-{{ ai_gen_id }}"
  data-scroll-speed="{{ block.settings.scroll_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-dual-slider-container-{{ ai_gen_id }}">
    {% if block.settings.row_layout == '2_rows' %}
      <div class="ai-dual-slider-wrapper-{{ ai_gen_id }}">
        <div class="ai-dual-slider-row-{{ ai_gen_id }}" data-row="1">
          {% for i in (1..12) %}
            {% liquid
              assign image_key = 'image_' | append: i
              assign product_key = 'product_' | append: i
              assign image = block.settings[image_key]
              assign product = block.settings[product_key]
            %}
            
            {% if i <= 6 %}
              <div class="ai-dual-slider-item-{{ ai_gen_id }}">
                {% if image %}
                  <img
                    src="{{ image | image_url: width: 800 }}"
                    alt="{{ image.alt | escape }}"
                    loading="lazy"
                    width="{{ block.settings.image_width }}"
                    height="auto"
                  >
                {% elsif product and product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 800 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    loading="lazy"
                    width="{{ block.settings.image_width }}"
                    height="auto"
                  >
                {% else %}
                  <div class="ai-dual-slider-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>

        <div class="ai-dual-slider-row-{{ ai_gen_id }}" data-row="2">
          {% for i in (1..12) %}
            {% liquid
              assign image_key = 'image_' | append: i
              assign product_key = 'product_' | append: i
              assign image = block.settings[image_key]
              assign product = block.settings[product_key]
            %}
            
            {% if i > 6 %}
              <div class="ai-dual-slider-item-{{ ai_gen_id }}">
                {% if image %}
                  <img
                    src="{{ image | image_url: width: 800 }}"
                    alt="{{ image.alt | escape }}"
                    loading="lazy"
                    width="{{ block.settings.image_width }}"
                    height="auto"
                  >
                {% elsif product and product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 800 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    loading="lazy"
                    width="{{ block.settings.image_width }}"
                    height="auto"
                  >
                {% else %}
                  <div class="ai-dual-slider-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% else %}
      <div class="ai-dual-slider-wrapper-{{ ai_gen_id }}">
        <div class="ai-dual-slider-row-{{ ai_gen_id }}" data-row="1">
          {% for i in (1..12) %}
            {% liquid
              assign image_key = 'image_' | append: i
              assign product_key = 'product_' | append: i
              assign image = block.settings[image_key]
              assign product = block.settings[product_key]
            %}
            
            <div class="ai-dual-slider-item-{{ ai_gen_id }}">
              {% if image %}
                <img
                  src="{{ image | image_url: width: 800 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image_width }}"
                  height="auto"
                >
              {% elsif product and product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image_width }}"
                  height="auto"
                >
              {% else %}
                <div class="ai-dual-slider-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</dual-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class DualSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.scrollSpeed = parseFloat(this.dataset.scrollSpeed) || 1;
        this.isScrolling = false;
        this.animationFrameId = null;
      }

      connectedCallback() {
        this.wrapper = this.querySelector('.ai-dual-slider-wrapper-{{ ai_gen_id }}');
        this.rows = this.querySelectorAll('.ai-dual-slider-row-{{ ai_gen_id }}');
        
        if (this.wrapper && this.rows.length > 0) {
          this.startAutoScroll();
          this.setupInteractionHandlers();
        }
      }

      disconnectedCallback() {
        this.stopAutoScroll();
      }

      startAutoScroll() {
        const scroll = () => {
          if (!this.isScrolling) {
            this.rows.forEach((row, index) => {
              const direction = index === 0 ? 1 : -1;
              row.scrollLeft += this.scrollSpeed * direction;

              if (direction === 1 && row.scrollLeft >= row.scrollWidth - row.clientWidth) {
                row.scrollLeft = 0;
              } else if (direction === -1 && row.scrollLeft <= 0) {
                row.scrollLeft = row.scrollWidth - row.clientWidth;
              }
            });
          }
          this.animationFrameId = requestAnimationFrame(scroll);
        };
        
        this.animationFrameId = requestAnimationFrame(scroll);
      }

      stopAutoScroll() {
        if (this.animationFrameId) {
          cancelAnimationFrame(this.animationFrameId);
          this.animationFrameId = null;
        }
      }

      setupInteractionHandlers() {
        this.rows.forEach((row) => {
          row.addEventListener('mouseenter', () => {
            this.isScrolling = true;
          });

          row.addEventListener('mouseleave', () => {
            this.isScrolling = false;
          });

          row.addEventListener('touchstart', () => {
            this.isScrolling = true;
          });

          row.addEventListener('touchend', () => {
            setTimeout(() => {
              this.isScrolling = false;
            }, 1000);
          });
        });
      }
    }

    customElements.define('dual-slider-{{ ai_gen_id }}', DualSlider{{ ai_gen_id }});
  })();
</script>

