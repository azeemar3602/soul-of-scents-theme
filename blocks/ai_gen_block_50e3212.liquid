{% doc %}
  @prompt
    {%- capture width_style -%}
      {%- case section_width -%}
        {%- when 'full' -%}
          max-width: 100%;
        {%- when 'container' -%}
          max-width: var(--page-width, 1200px);
        {%- when 'boxed' -%}
          max-width: 1000px;
        {%- when 'custom' -%}
          max-width: {{ custom_width }}px;
      {%- endcase -%}
    {%- endcapture -%}
    
    follow this section width control, also same image style for text, and image with sizes option, text color, size, section control padding, margin options all functionality best section, subheading in light color as image missing, text size nor working
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  case block.settings.section_width
    when 'full'
      assign width_style = 'max-width: 100%;'
    when 'container'
      assign width_style = 'max-width: var(--page-width, 1200px);'
    when 'boxed'
      assign width_style = 'max-width: 1000px;'
    when 'custom'
      assign width_style = 'max-width: ' | append: block.settings.custom_width | append: 'px;'
  endcase
%}

{% style %}
  .ai-text-image-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-text-image-container-{{ ai_gen_id }} {
    {{ width_style }}
    margin-left: auto;
    margin-right: auto;
    padding-left: 15px;
    padding-right: 15px;
  }

  .ai-text-image-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: {{ block.settings.vertical_alignment }};
    gap: {{ block.settings.content_gap }}px;
    {% if block.settings.layout == 'image_right' %}
      flex-direction: row-reverse;
    {% endif %}
  }

  .ai-text-image-content-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-text-image-subheading-{{ ai_gen_id }} {
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
    line-height: 1.4;
    text-transform: {{ block.settings.subheading_transform }};
    font-weight: {{ block.settings.subheading_weight }};
  }

  .ai-text-image-subheading-{{ ai_gen_id }} p {
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0;
    line-height: 1.4;
    text-transform: {{ block.settings.subheading_transform }};
    font-weight: {{ block.settings.subheading_weight }};
  }

  .ai-text-image-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    line-height: 1.2;
  }

  .ai-text-image-heading-{{ ai_gen_id }} p {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0;
    line-height: 1.2;
  }

  .ai-text-image-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin: 0;
  }

  .ai-text-image-text-{{ ai_gen_id }} p {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin: 0;
  }

  .ai-text-image-media-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-text-image-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  {% if block.settings.image_ratio == 'adapt' %}
    .ai-text-image-image-wrapper-{{ ai_gen_id }} img {
      width: 100%;
      height: auto;
      display: block;
    }
  {% else %}
    .ai-text-image-image-wrapper-{{ ai_gen_id }} {
      padding-bottom: {% case block.settings.image_ratio %}
        {% when 'square' %}100%
        {% when 'landscape' %}75%
        {% when 'portrait' %}133.33%
        {% when 'wide' %}56.25%
      {% endcase %};
    }

    .ai-text-image-image-wrapper-{{ ai_gen_id }} img {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  {% endif %}

  .ai-text-image-placeholder-{{ ai_gen_id }} {
    {% if block.settings.image_ratio == 'adapt' %}
      aspect-ratio: 16 / 9;
    {% else %}
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    {% endif %}
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-text-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-text-image-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 768px) {
    .ai-text-image-wrapper-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.mobile_gap }}px;
    }

    .ai-text-image-subheading-{{ ai_gen_id }},
    .ai-text-image-subheading-{{ ai_gen_id }} p {
      font-size: {{ block.settings.subheading_size_mobile }}px;
    }

    .ai-text-image-heading-{{ ai_gen_id }},
    .ai-text-image-heading-{{ ai_gen_id }} p {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-text-image-text-{{ ai_gen_id }},
    .ai-text-image-text-{{ ai_gen_id }} p {
      font-size: {{ block.settings.text_size_mobile }}px;
    }

    .ai-text-image-section-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
      margin-top: {{ block.settings.margin_top_mobile }}px;
      margin-bottom: {{ block.settings.margin_bottom_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-text-image-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-image-container-{{ ai_gen_id }}">
    <div class="ai-text-image-wrapper-{{ ai_gen_id }}">
      <div class="ai-text-image-content-{{ ai_gen_id }}">
        {% if block.settings.subheading != blank %}
          <div class="ai-text-image-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
        {% endif %}
        {% if block.settings.heading != blank %}
          <h2 class="ai-text-image-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.text != blank %}
          <div class="ai-text-image-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
        {% endif %}
      </div>

      <div class="ai-text-image-media-{{ ai_gen_id }}">
        <div class="ai-text-image-image-wrapper-{{ ai_gen_id }}">
          {% if block.settings.image %}
            <img
              src="{{ block.settings.image | image_url: width: 1200 }}"
              alt="{{ block.settings.image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {% else %}
            <div class="ai-text-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-text-image-empty-state-{{ ai_gen_id }}">
                Next, add an image
              </div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

