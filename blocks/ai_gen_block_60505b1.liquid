{% doc %}
  @prompt
    {%- capture width_style -%}
      {%- case section_width -%}
        {%- when 'full' -%}
          max-width: 100%;
        {%- when 'container' -%}
          max-width: var(--page-width, 1200px);
        {%- when 'boxed' -%}
          max-width: 1000px;
        {%- when 'custom' -%}
          max-width: {{ custom_width }}px;
      {%- endcase -%}
    {%- endcapture -%}
    
    
    like image i need section with above code width options , image and video both option all section options etc
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  case block.settings.section_width
    when 'full'
      assign max_width = '100%'
    when 'container'
      assign max_width = 'var(--page-width, 1200px)'
    when 'boxed'
      assign max_width = '1000px'
    when 'custom'
      assign max_width = block.settings.custom_width | append: 'px'
  endcase
%}

{% style %}
  .ai-media-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-media-section__container-{{ ai_gen_id }} {
    max-width: {{ max_width }};
    margin: 0 auto;
    padding: 0 {{ block.settings.container_padding }}px;
  }

  .ai-media-section__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-media-section__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: {{ block.settings.image_fit }};
  }

  .ai-media-section__video-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-media-section__placeholder-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 400px;
  }

  .ai-media-section__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-media-section__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-media-section__content-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.content_vertical_alignment }};
    align-items: {{ block.settings.content_horizontal_alignment }};
    padding: 40px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-media-section__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 16px;
    max-width: 800px;
  }

  .ai-media-section__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    margin: 0 0 24px;
    max-width: 600px;
  }

  .ai-media-section__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    transition: background-color 0.3s ease;
  }

  .ai-media-section__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-media-section__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-media-section-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px 0 {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-media-section__content-overlay-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-media-section__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-media-section__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }

    .ai-media-section__placeholder-{{ ai_gen_id }} {
      min-height: 300px;
    }
  }
{% endstyle %}

<media-section-{{ ai_gen_id }} class="ai-media-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-media-section__container-{{ ai_gen_id }}">
    <div class="ai-media-section__wrapper-{{ ai_gen_id }}">
      {% if block.settings.media_type == 'image' %}
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 2000 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-media-section__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-media-section__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-media-section__empty-state-{{ ai_gen_id }}">
              Next, add an image
            </div>
          </div>
        {% endif %}
      {% elsif block.settings.media_type == 'video' %}
        {% if block.settings.video_url != blank %}
          <video
            class="ai-media-section__video-{{ ai_gen_id }}"
            {% if block.settings.video_autoplay %}autoplay{% endif %}
            {% if block.settings.video_loop %}loop{% endif %}
            {% if block.settings.video_muted %}muted{% endif %}
            {% if block.settings.video_controls %}controls{% endif %}
            playsinline
          >
            <source src="{{ block.settings.video_url }}" type="video/mp4">
            Your browser does not support the video tag.
          </video>
        {% else %}
          <div class="ai-media-section__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-media-section__empty-state-{{ ai_gen_id }}">
              Next, add a video URL
            </div>
          </div>
        {% endif %}
      {% endif %}

      {% if block.settings.enable_overlay %}
        <div class="ai-media-section__overlay-{{ ai_gen_id }}"></div>
      {% endif %}

      {% if block.settings.show_content %}
        <div class="ai-media-section__content-overlay-{{ ai_gen_id }}">
          {% if block.settings.heading != blank %}
            <h2 class="ai-media-section__heading-{{ ai_gen_id }}">
              {{ block.settings.heading }}
            </h2>
          {% endif %}

          {% if block.settings.text != blank %}
            <div class="ai-media-section__text-{{ ai_gen_id }}">
              {{ block.settings.text }}
            </div>
          {% endif %}

          {% if block.settings.button_text != blank %}
            <a
              href="{{ block.settings.button_link }}"
              class="ai-media-section__button-{{ ai_gen_id }}"
            >
              {{ block.settings.button_text }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</media-section-{{ ai_gen_id }}>

<script>
  (function() {
    class MediaSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const video = this.querySelector('.ai-media-section__video-{{ ai_gen_id }}');
        if (video && video.hasAttribute('autoplay')) {
          video.play().catch(function(error) {
            console.log('Video autoplay failed:', error);
          });
        }
      }
    }

    customElements.define('media-section-{{ ai_gen_id }}', MediaSection{{ ai_gen_id }});
  })();
</script>

