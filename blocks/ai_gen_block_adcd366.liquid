{% doc %}
  @prompt
    1. Visual Structure
    Alignment: Left-aligned text with generous white space (padding).
    
    Typography: A clean, modern Sans-Serif (e.g., Montserrat, Inter, or Helvetica).
    
    Text Hierarchy:
    
    Line 1 (Accent): Light weight, low-contrast color (Light Grey/Taupe).
    
    Line 2 (Main): Bold weight, high-contrast color (Pitch Black).
    
    Spacing: Tight line-height between the two sentences to make them feel like a single unit.
    
    2. Technical Specifications (Liquid/CSS)
    Container: Full-width or constrained to a standard site width (1200px-1400px).
    
    Background: Solid white (#FFFFFF).
    
    CSS Styles:
    
    .accent-text: font-weight: 300; color: #D1D1D1; font-size: 24px; margin-bottom: 4px;
    
    .main-text: font-weight: 700; color: #000000; font-size: 28px; line-height: 1.2;
    
    3. Content Strategy
    Header: We capture the one-of-a-kind signature of you
    
    Subheader: and contribute to an overall elevated, confident feel, drop by drop.
    
    Shopify "Schema" Settings to Include:
    To make this editable in the Theme Editor, the schema should include:
    
    text field for the "Accent Line"
    
    text field for the "Bold Line"
    
    range slider for Top/Bottom Padding
    
    color_picker for both text lines
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-signature-text-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_horizontal }}px;
  }

  .ai-signature-text__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-signature-text__accent-{{ ai_gen_id }} {
    font-weight: 300;
    color: {{ block.settings.accent_color }};
    font-size: {{ block.settings.accent_font_size }}px;
    margin: 0 0 4px 0;
    line-height: 1.3;
  }

  .ai-signature-text__main-{{ ai_gen_id }} {
    font-weight: 700;
    color: {{ block.settings.main_color }};
    font-size: {{ block.settings.main_font_size }}px;
    margin: 0;
    line-height: 1.2;
  }

  @media screen and (max-width: 749px) {
    .ai-signature-text__accent-{{ ai_gen_id }} {
      font-size: {{ block.settings.accent_font_size | times: 0.7 }}px;
    }

    .ai-signature-text__main-{{ ai_gen_id }} {
      font-size: {{ block.settings.main_font_size | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-signature-text-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-signature-text__container-{{ ai_gen_id }}">
    {% if block.settings.accent_text != blank %}
      <p class="ai-signature-text__accent-{{ ai_gen_id }}">{{ block.settings.accent_text }}</p>
    {% endif %}
    {% if block.settings.main_text != blank %}
      <p class="ai-signature-text__main-{{ ai_gen_id }}">{{ block.settings.main_text }}</p>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Signature text",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "accent_text",
      "label": "Accent line",
      "default": "We capture the one-of-a-kind signature of you"
    },
    {
      "type": "text",
      "id": "main_text",
      "label": "Bold line",
      "default": "and contribute to an overall elevated, confident feel, drop by drop."
    },
    {
      "type": "header",
      "content": "Accent line style"
    },
    {
      "type": "range",
      "id": "accent_font_size",
      "label": "Font size",
      "min": 14,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Text color",
      "default": "#D1D1D1"
    },
    {
      "type": "header",
      "content": "Bold line style"
    },
    {
      "type": "range",
      "id": "main_font_size",
      "label": "Font size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "color",
      "id": "main_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Signature text"
    }
  ]
}
{% endschema %}
