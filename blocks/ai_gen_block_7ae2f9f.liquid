{% doc %}
  @prompt
        .ai-text-image-image-wrapper-{{ ai_gen_id }} {
          padding-bottom: {% case block.settings.image_ratio %}
            {% when 'square' %}100%
            {% when 'landscape' %}75%
            {% when 'portrait' %}133.33%
            {% when 'wide' %}56.25%
          {% endcase %};
        }
    
    use this image options 
    
    {%- capture width_style -%}
      {%- case section_width -%}
        {%- when 'full' -%}
          max-width: 100%;
        {%- when 'container' -%}
          max-width: var(--page-width, 1200px);
        {%- when 'boxed' -%}
          max-width: 1000px;
        {%- when 'custom' -%}
          max-width: {{ custom_width }}px;
      {%- endcase -%}
    {%- endcapture -%}
    
    use for section, and text editble, colors, font, description font etc, margin padding as per image, text font size not working for both
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% capture section_width_style %}
  {% case block.settings.section_width %}
    {% when 'full' %}
      max-width: 100%;
    {% when 'container' %}
      max-width: var(--page-width, 1200px);
    {% when 'boxed' %}
      max-width: 1000px;
    {% when 'custom' %}
      max-width: {{ block.settings.custom_width }}px;
  {% endcase %}
{% endcapture %}

{% style %}
  .ai-text-image-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  .ai-text-image-container-{{ ai_gen_id }} {
    {{ section_width_style }}
    margin: 0 auto;
    padding-left: {{ block.settings.padding_horizontal }}px;
    padding-right: {{ block.settings.padding_horizontal }}px;
  }

  .ai-text-image-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: {{ block.settings.vertical_alignment }};
    gap: {{ block.settings.gap }}px;
    {% if block.settings.layout == 'image_right' %}
      flex-direction: row-reverse;
    {% endif %}
  }

  .ai-text-image-content-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-text-image-image-container-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-text-image-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    padding-bottom: {% case block.settings.image_ratio %}
      {% when 'square' %}100%
      {% when 'landscape' %}75%
      {% when 'portrait' %}133.33%
      {% when 'wide' %}56.25%
    {% endcase %};
  }

  .ai-text-image-image-wrapper-{{ ai_gen_id }} img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-text-image-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-text-image-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-text-image-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    line-height: {{ block.settings.heading_line_height }};
    text-transform: {{ block.settings.heading_transform }};
  }

  .ai-text-image-heading-{{ ai_gen_id }} p {
    margin: 0;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
    color: inherit;
    text-transform: inherit;
  }

  .ai-text-image-description-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.description_color }};
    font-size: {{ block.settings.description_size }}px;
    font-weight: {{ block.settings.description_weight }};
    line-height: {{ block.settings.description_line_height }};
  }

  .ai-text-image-description-{{ ai_gen_id }} p {
    margin: 0 0 16px;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
    color: inherit;
  }

  .ai-text-image-description-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-text-image-wrapper-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-text-image-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-text-image-heading-{{ ai_gen_id }} p {
      font-size: inherit;
    }

    .ai-text-image-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size_mobile }}px;
    }

    .ai-text-image-description-{{ ai_gen_id }} p {
      font-size: inherit;
    }

    .ai-text-image-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-text-image-container-{{ ai_gen_id }} {
      padding-left: {{ block.settings.padding_horizontal_mobile }}px;
      padding-right: {{ block.settings.padding_horizontal_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-text-image-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-image-container-{{ ai_gen_id }}">
    <div class="ai-text-image-wrapper-{{ ai_gen_id }}">
      <div class="ai-text-image-content-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <div class="ai-text-image-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</div>
        {% endif %}
        {% if block.settings.description != blank %}
          <div class="ai-text-image-description-{{ ai_gen_id }}">
            {{ block.settings.description }}
          </div>
        {% endif %}
      </div>
      <div class="ai-text-image-image-container-{{ ai_gen_id }}">
        <div class="ai-text-image-image-wrapper-{{ ai_gen_id }}">
          {% if block.settings.image %}
            <img
              src="{{ block.settings.image | image_url: width: 1200 }}"
              alt="{{ block.settings.image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {% else %}
            <div class="ai-text-image-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

