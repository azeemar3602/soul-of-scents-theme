{% doc %}
  @prompt
    spacer
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-spacer-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-spacer-inner-{{ ai_gen_id }} {
    height: {{ block.settings.desktop_height }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-spacer-inner-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}px;
    }
  }
{% endstyle %}

<spacer-block-{{ ai_gen_id }} class="ai-spacer-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-spacer-inner-{{ ai_gen_id }}"></div>
</spacer-block-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Spacer",
  "settings": [
    {
      "type": "header",
      "content": "Desktop"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Height",
      "min": 10,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Height",
      "min": 10,
      "max": 150,
      "step": 10,
      "unit": "px",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Spacer"
    }
  ]
}
{% endschema %}
