{% doc %}
  @prompt
    make same section with this tetx and section option function as per my theme,  font color, size , font family option etc, paddings, marging, text font size nor wowkring and heading missing, delete text because showing showing addd your text even i did not added text
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
  }

  .ai-text-section-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding-left: {{ block.settings.padding_horizontal }}px;
    padding-right: {{ block.settings.padding_horizontal }}px;
  }

  .ai-text-section-heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.heading_color }};
    font-family: {% if block.settings.heading_font_family == 'heading' %}var(--g-font-1){% else %}var(--g-font-2){% endif %};
    font-size: {{ block.settings.heading_font_size }}px;
    font-weight: {{ block.settings.heading_font_weight }};
    line-height: {{ block.settings.heading_line_height }};
    letter-spacing: {{ block.settings.heading_letter_spacing }}em;
    text-transform: {{ block.settings.heading_text_transform }};
    margin-top: 0;
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-text-section-content-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.text_color }};
    font-family: {% if block.settings.font_family == 'heading' %}var(--g-font-1){% else %}var(--g-font-2){% endif %};
    font-size: {{ block.settings.font_size }}px !important;
    font-weight: {{ block.settings.font_weight }};
    line-height: {{ block.settings.line_height }};
    letter-spacing: {{ block.settings.letter_spacing }}em;
    text-transform: {{ block.settings.text_transform }};
  }

  .ai-text-section-content-{{ ai_gen_id }} * {
    font-size: {{ block.settings.font_size }}px !important;
    color: {{ block.settings.text_color }};
  }

  .ai-text-section-content-{{ ai_gen_id }} h1,
  .ai-text-section-content-{{ ai_gen_id }} h2,
  .ai-text-section-content-{{ ai_gen_id }} h3,
  .ai-text-section-content-{{ ai_gen_id }} h4,
  .ai-text-section-content-{{ ai_gen_id }} h5,
  .ai-text-section-content-{{ ai_gen_id }} h6 {
    color: {{ block.settings.heading_color }} !important;
    margin-top: 0;
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-text-section-content-{{ ai_gen_id }} p {
    margin-top: 0;
    margin-bottom: {{ block.settings.paragraph_spacing }}px;
    font-size: {{ block.settings.font_size }}px !important;
  }

  .ai-text-section-content-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: {% if block.settings.link_underline %}underline{% else %}none{% endif %};
  }

  .ai-text-section-content-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-text-section-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-text-section-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size_mobile }}px;
    }

    .ai-text-section-content-{{ ai_gen_id }},
    .ai-text-section-content-{{ ai_gen_id }} *,
    .ai-text-section-content-{{ ai_gen_id }} p {
      font-size: {{ block.settings.font_size_mobile }}px !important;
    }
  }
{% endstyle %}

<div class="ai-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-section-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-text-section-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}
    
    {% if block.settings.content != blank %}
      <div class="ai-text-section-content-{{ ai_gen_id }}">
        {{ block.settings.content }}
      </div>
    {% endif %}
  </div>
</div>

