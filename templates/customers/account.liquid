<div class="page-width py-5">
    <h1 class="h3">{{ 'customer.account.title' | t }}</h1>

      {%- assign archetype_name = customer.metafields.custom.archetype_name.value -%}
        {%- assign archetype_date = customer.metafields.custom.archetype_date.value -%}
          {%- assign archetype_result_url = customer.metafields.custom.archetype_result_url.value -%}
            {%- assign archetype_image_url = customer.metafields.custom.archetype_image_url.value -%}

              {%- if archetype_name != blank -%}
                <div class="account-archetype-section">
                    <h2 class="account-archetype-section__title">Mein Archetyp</h2>
                        <div class="account-archetype-card">
                              <div class="account-archetype-card__left">
                                      {%- if archetype_image_url != blank -%}
                                                <img src="{{ archetype_image_url }}" alt="{{ archetype_name }}" class="account-archetype-card__image" width="80" height="80" loading="lazy">
                                                        {%- else -%}
                                                                  <div class="account-archetype-card__image-placeholder"></div>
                                                                          {%- endif -%}
                                                                                  <div class="account-archetype-card__info">
                                                                                            <p class="account-archetype-card__name">{{ archetype_name }}</p>
                                                                                                      {%- if archetype_date != blank -%}
                                                                                                                  <p class="account-archetype-card__date">Quiz abgeschlossen am {{ archetype_date | date: '%d. %B %Y' }}</p>
                                                                                                                            {%- endif -%}
                                                                                                                                    </div>
                                                                                                                                          </div>
                                                                                                                                                <div class="account-archetype-card__actions">
                                                                                                                                                        {%- if archetype_result_url != blank -%}
                                                                                                                                                                  <a href="{{ archetype_result_url }}" class="account-archetype-card__btn account-archetype-card__btn--primary">Archetyp anzeigen</a>
                                                                                                                                                                          {%- endif -%}
                                                                                                                                                                                  <a href="/pages/quiz" class="account-archetype-card__btn account-archetype-card__btn--secondary">Quiz wiederholen</a>
                                                                                                                                                                                        </div>
                                                                                                                                                                                            </div>
                                                                                                                                                                                              </div>
                                                                                                                                                                                                {%- else -%}
                                                                                                                                                                                                  <div class="account-archetype-section">
                                                                                                                                                                                                      <h2 class="account-archetype-section__title">Mein Archetyp</h2>
                                                                                                                                                                                                          <div class="account-archetype-empty">
                                                                                                                                                                                                                <p>Du hast den Quiz noch nicht abgeschlossen.</p>
                                                                                                                                                                                                                      <a href="/pages/quiz" class="account-archetype-card__btn account-archetype-card__btn--primary">Quiz starten</a>
                                                                                                                                                                                                                          </div>
                                                                                                                                                                                                                            </div>
                                                                                                                                                                                                                              {%- endif -%}

                                                                                                                                                                                                                                <div class="grid">
                                                                                                                                                                                                                                    <div class="grid__item medium-up--two-thirds">
                                                                                                                                                                                                                                          <div class="content-block">
                                                                                                                                                                                                                                                  <h2 class="h4">{{ 'customer.orders.title' | t }}</h2>
                                                                                                                                                                                                                                                          {%- paginate customer.orders by 20 -%}
                                                                                                                                                                                                                                                                  {%- if customer.orders.size != 0 -%}
                                                                                                                                                                                                                                                                          <table class="responsive-table">
                                                                                                                                                                                                                                                                                    <thead>
                                                                                                                                                                                                                                                                                                <tr>
                                                                                                                                                                                                                                                                                                              <th>{{ 'customer.orders.order_number' | t }}</th>
                                                                                                                                                                                                                                                                                                                            <th>{{ 'customer.orders.date' | t }}</th>
                                                                                                                                                                                                                                                                                                                                          <th>{{ 'customer.orders.payment_status' | t }}</th>
                                                                                                                                                                                                                                                                                                                                                        <th>{{ 'customer.orders.fulfillment_status' | t }}</th>
                                                                                                                                                                                                                                                                                                                                                                      <th>{{ 'customer.orders.total' | t }}</th>
                                                                                                                                                                                                                                                                                                                                                                                  </tr>
                                                                                                                                                                                                                                                                                                                                                                                            </thead>
                                                                                                                                                                                                                                                                                                                                                                                                      <tbody>
                                                                                                                                                                                                                                                                                                                                                                                                                  {%- for order in customer.orders -%}
                                                                                                                                                                                                                                                                                                                                                                                                                              <tr>
                                                                                                                                                                                                                                                                                                                                                                                                                                            <td data-label="{{ 'customer.orders.order_number' | t }}">{{ order.name | link_to: order.customer_url }}</td>
                                                                                                                                                                                                                                                                                                                                                                                                                                                          <td data-label="{{ 'customer.orders.date' | t }}">{{ order.created_at | date: format: 'month_day_year' }}</td>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                        <td data-label="{{ 'customer.orders.payment_status' | t }}">{{ order.financial_status_label }}</td>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      <td data-label="{{ 'customer.orders.fulfillment_status' | t }}">{{ order.fulfillment_status_label }}</td>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    <td data-label="{{ 'customer.orders.total' | t }}">{{ order.total_price | money }}</td>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                </tr>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            {%- endfor -%}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      </tbody>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              </table>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      {%- else -%}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <p>{{ 'customer.orders.none' | t }}</p>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        {%- endif -%}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                {%- if paginate.pages > 1 -%}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          <div class="pagination">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      {{ paginate | default_pagination | replace: '&laquo; Previous', '&larr;' | replace: 'Next &raquo;', '&rarr;' }}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        {%- endif -%}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                {%- endpaginate -%}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              <div class="grid__item medium-up--one-third">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    <div class="content-block">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <h3 class="h6 content-block__title">{{ 'customer.account.details' | t }}</h3>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    {{ customer.default_address | format_address }}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            