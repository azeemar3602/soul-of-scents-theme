    "bcb1cba3-80fc-49a2-a033-40cf0618e9c8": {
      "type": "faq-accordion",
      "blocks": {
        "template--14684877652053__bcb1cba3-80fc-49a2-a033-40cf0618e9c8-16659371170e440ef7-0": {
          "type": "faq",
          "settings": {
            "faq_title": "Is the shipping free?",
            "faq_des": "<p>Yes. Worldwide shipping is already included in the price. We use DHL express with 3 days delivery time.</p>"
          }
        },
        "template--14684877652053__bcb1cba3-80fc-49a2-a033-40cf0618e9c8-16659371170e440ef7-1": {
          "type": "faq",
          "settings": {
            "faq_title": "When will I receive my item?",
            "faq_des": "<p>When we have received your order, you will automatically receive an e-mail confirming your order. Orders made before 2 PM (CET) will be picked, packed and shipped the same day. Delivery time is usually 2-4 working days with DHL Express.</p>"
          }
        },
        "template--14684877652053__bcb1cba3-80fc-49a2-a033-40cf0618e9c8-16659371170e440ef7-2": {
          "type": "faq",
          "settings": {
            "faq_title": "Can I change or return my item?",
            "faq_des": "<p>If you want to change a product into another model, strap color etc., please contact us so we are able to reserve the new item in our stock immediately. You are always entitled to an exchange or refund within 30 days after you have received your package, as long as the item has not been used.</p>"
          }
        }
      },
