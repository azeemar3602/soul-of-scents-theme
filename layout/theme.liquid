<!doctype html>
<html class="no-js " lang="{{ shop.locale }}">
  <head>
	<!-- Added by AVADA SEO Suite -->
	{% include 'avada-seo' %}
	<!-- /Added by AVADA SEO Suite -->
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width,initial-scale=1, maximum-scale=1">
    <meta name="theme-color" content="{{ settings.color_header_bg }}">
    <meta name="format-detection" content="telephone=no">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="dns-prefetch" href="https://{{shop.domain }}" crossorigin>
    <link rel="dns-prefetch" href="https://{{shop.permanent_domain }}" crossorigin>
    <link rel="dns-prefetch" href="https://cdn.shopify.com" crossorigin>
    <link rel="dns-prefetch" href="https://fonts.shopifycdn.com" crossorigin>
    <link rel="preconnect" href="https//fonts.shopifycdn.com/" crossorigin>
    <link rel="preconnect" href="https//cdn.shopify.com" crossorigin>
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- unless settings.font_family.system? -%}
      <link rel="preload" as="font" href="{{ settings.font_family | font_url }}" type="font/woff2" crossorigin>
      <link rel="preload" as="font" href="{{ settings.font_family | font_url: 'woff' }}" type="font/woff" crossorigin>
    {%- endunless -%}
    {%- if settings.font_family2.system? == false and settings.font_family2 != settings.font_family -%}
      <link rel="preload" as="font" href="{{ settings.font_family2 | font_url }}" type="font/woff2" crossorigin>
      <link rel="preload" as="font" href="{{ settings.font_family2 | font_url: 'woff' }}" type="font/woff" crossorigin>
    {%- endif -%}
    {%- if settings.favicon != blank -%}
      <link rel="shortcut icon" href="{{ settings.favicon | image_url: width: 32, height: 32 }}" type="image/png">
    {%- endif -%}

    <title>
      {{ page_title }}
      {% if current_tags %}
        {% assign meta_tags = current_tags | join: ', ' %}
        &ndash;
        {{ 'general.meta.tags' | t: tags: meta_tags }}
      {% endif %}
      {% if current_page != 1 %}
        &ndash;
        {{ 'general.meta.page' | t: page: current_page }}
      {% endif %}
      {% unless page_title contains shop.name %}
        &ndash;
        {{ shop.name }}
      {% endunless %}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- else -%}
      <meta name="description" content="{{ settings.meta_description | escape }}">
    {%- endif -%}

    {%- render 'social-meta-tags' -%}
    {%- render 'header-css' -%}
    <link rel="preload" href="{{ 'lazysizes.min.js' | asset_url }}" as="script">
    <link rel="preload" href="{{ 'vendor.js' | asset_url }}" as="script">
    <link rel="preload" href="{{ 'swiper-bundle.min.js' | asset_url }}" as="script">
    <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>
    {{ content_for_header }}
    {{ 'judgeme-custom.css' | asset_url | stylesheet_tag }}
  </head>
  <body class="template-{{ template | replace: '.', ' ' | truncatewords: 1, '' | handle }} body-theme {% if settings.productpage == 'product-2' or settings.productpage == 'product-6' or settings.productpage == 'product-7' %} product-hide-breadcrumb {% endif %}">
    {% assign lazy = false %}
    <img {% if lazy %} loading="lazy" {% endif %} width="99998" height="99999" alt="index" style="pointer-events: none; position: absolute; top: 0; left: 0; width: 99vw; height: 99vh; max-width: 99vw; max-height: 99vh;" src="data:image/svg+xml;base64,">
    {%- render 'loading' -%}
    {%- sections 'header-group' -%}
    <div class="page-container page-element is-moved-by-drawer">
      <main class="main-content" id="MainContent" role="main">
        {%- if settings.enable_animationscroll -%}
          <div id="js-scroll">
        {%- endif -%}
        {%- if settings.enable_animationscroll -%}
          <div data-scroll-section>
        {%- endif -%}
        {%- render 'slideshow' -%}
        {%- if settings.enable_animationscroll -%}
          </div>
        {%- endif -%}
        {{ content_for_layout }}
        {%- if settings.enable_animationscroll -%}
          </div>
        {%- endif -%}
      </main>
      {%- sections 'footer-group' -%}
      {%- liquid
        section 'pnewsletter'
        section 'product-suggest'
        section 'cookie-policy'
        section 'custom-color'
      -%}
    </div>
    {%- liquid
      render 'back-to-top'
      render 'menu-mobile'
      render 'bottom-contents'
      render 'quickview'
      render 'popup-compare'
      render 'header-js'
    -%}

<script>
  (function() {
    var QUIZ_ID = 'KFeGjY';
    var QUIZ_PAGE = '/pages/quiz';
    var STORE_KEY = 'sos_archetype_data';

    function saveArchetypeData(responseId) {
      if (!responseId) return;
      var existing = {};
      try { existing = JSON.parse(localStorage.getItem(STORE_KEY) || '{}'); } catch(e) {}
      var resultUrl = window.location.origin + QUIZ_PAGE + '?r=' + responseId;
      var quizObj = window.quiz || {};
      var data = {
        responseId: responseId,
        resultUrl: resultUrl,
        savedAt: new Date().toISOString()
      };
      if (quizObj.variables && quizObj.variables.highest) {
        data.archetypeKey = quizObj.variables.highest;
      }
      localStorage.setItem(STORE_KEY, JSON.stringify(data));
      localStorage.setItem('sos_quiz_result_url', resultUrl);
    }

    function checkAndSave() {
      var rh = localStorage.getItem('revenuehunt-responseId-' + QUIZ_ID);
      if (rh) {
        try {
          var obj = JSON.parse(rh);
          if (obj && obj.value) saveArchetypeData(obj.value);
        } catch(e) {}
      }
    }

    window.addEventListener('message', function(event) {
      if (!event.data) return;
      var data;
      try { data = typeof event.data === 'string' ? JSON.parse(event.data) : event.data; } catch(e) { return; }
      if (data.channel !== 'revenuehunt:quiz-renderer') return;
      if (data.type === 'isResult') {
        setTimeout(function() {
          var quiz = window.quiz || {};
          var meta = quiz.metadata || {};
          var responseId = meta.responseId || '';
          if (responseId) { saveArchetypeData(responseId); return; }
          checkAndSave();
        }, 1500);
      }
    });

    if (window.location.pathname === QUIZ_PAGE) {
      var urlParams = new URLSearchParams(window.location.search);
      var r = urlParams.get('r');
      if (r) saveArchetypeData(r);
    }

    document.addEventListener('DOMContentLoaded', function() {
      checkAndSave();
    });
  })();
</script>

  </body>
